---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import PostsList from '../components/PostsList.astro';

const posts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<PageLayout
  title="Posts"
  eyebrow="Writing"
  lead="Research summaries and opinions — notes on the work I do and the ideas behind it."
  description="Essays and research summaries by Kuan-Hao Chao on computational genomics, DNA language models, and machine learning."
>
  {
    posts.length === 0 ? (
      <p class="muted">No posts yet — check back soon.</p>
    ) : (
      <PostsList posts={posts} />
    )
  }
</PageLayout>
