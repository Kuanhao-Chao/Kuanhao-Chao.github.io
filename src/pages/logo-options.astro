---

<BaseLayout
  title="Logo options"
  description="Private logo exploration page for Kuan-Hao Chao."
  noindex
>
  <section class="logo-hero container">
    <p class="eyebrow">Private design review</p>
    <h1>Logo options</h1>
    <p class="lead">
      Flat SVG directions exploring the site identity. The newest batch leans into clearer
      genomic iconography — the double helix, chromosomes, the base alphabet, sequence logos,
      and sequence-to-function — with a few that fold the initials K · H · C into the
      structure of DNA.
    </p>
  </section>

  <section class="container logo-grid" aria-label="Logo concepts">
    {
      options.map((option) => (
        <article class:list={['logo-card', option.baseline && 'logo-card--baseline']} id={`option-${option.id}`}>
          <div class="logo-card-head">
            <p class="option-id">{option.baseline ? 'Baseline' : `Option ${option.id}`}</p>
            <h2>{option.name}</h2>
          </div>

          <div class="preview-row">
            <div class="preview-large" set:html={option.svg} />
            <div class="preview-dark" set:html={option.svg} />
          </div>

          <div class="scale-row" aria-label={`${option.name} size previews`}>
            <div class="header-mock">
              <span class="header-mark" set:html={option.svg} />
              <span>Kuan-Hao Chao</span>
            </div>
            <span class="tiny tiny--32" set:html={option.svg} />
            <span class="tiny tiny--16" set:html={option.svg} />
          </div>

