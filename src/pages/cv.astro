---
import PageLayout from '../layouts/PageLayout.astro';
import Icon from '../components/Icon.astro';

const docs = [
  { id: 'cv', label: 'CV', url: 'https://storage.googleapis.com/storage.khchao.com/CV.pdf' },
  { id: 'resume', label: 'Résumé', url: 'https://storage.googleapis.com/storage.khchao.com/Resume.pdf' },
];
---
<PageLayout
  title="CV"
  eyebrow="Curriculum vitae"
  lead="Full academic CV and a one-page résumé. View inline below or download the PDF."
  description="Curriculum vitae and résumé of Kuan-Hao Chao."
>
  <div class="cv" data-cv>
    <div class="cv-tabs" role="tablist" aria-label="Document">
      {
        docs.map((doc, i) => (
          <button
            type="button"
            role="tab"
            id={`tab-${doc.id}`}
            aria-controls={`panel-${doc.id}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            data-tab={doc.id}
          >
            {doc.label}
          </button>
        ))
      }
    </div>

    {
      docs.map((doc, i) => (
        <section
          id={`panel-${doc.id}`}
          role="tabpanel"
          aria-labelledby={`tab-${doc.id}`}
          data-panel={doc.id}
          hidden={i !== 0}
        >
          <a class="btn btn--accent cv-download" href={doc.url} target="_blank" rel="noopener">
            <Icon name="file" size={18} /> Download {doc.label} (PDF)
          </a>
          <div class="cv-frame">
            <iframe src={doc.url} title={`${doc.label} (PDF)`} loading="lazy" />
          </div>
          <a class="cv-mobile" href={doc.url} target="_blank" rel="noopener">
            <span class="cv-mobile-ic"><Icon name="file" size={26} /></span>
            <span class="cv-mobile-text">
              <strong>Open the {doc.label} full screen</strong>
              <span class="muted">Opens the PDF in your device's viewer</span>
            </span>
            <Icon name="arrow-right" size={18} />
          </a>
        </section>
      ))
    }
  </div>
</PageLayout>

<style>
  .cv-tabs {
    display: inline-flex;
    gap: 0.25rem;
    padding: 0.25rem;
    border: 1px solid var(--color-rule);
    border-radius: 999px;
    margin-bottom: var(--space-6);
  }
  .cv-tabs button {
    border: none;
    background: transparent;
    padding: 0.45em 1.4em;
    border-radius: 999px;
    font-size: var(--fs-small);
    font-weight: var(--fw-medium);
    color: var(--color-muted);
    cursor: pointer;
    transition: all var(--transition);
  }
  .cv-tabs button[aria-selected='true'] {
    background: var(--color-ink);
    color: var(--color-bg);
  }
  .cv-download {
    margin-bottom: var(--space-5);
  }
  .cv-frame {
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--color-surface);
  }
  .cv-frame iframe {
    width: 100%;
    height: min(85vh, 1100px);
    border: none;
    display: block;
  }
  /* Touch devices (phones + tablets) render iframed PDFs unreliably — iOS often
     shows a blank or single-page box. Swap the embed for a tap-to-open card that
     hands the PDF to the device's native full-screen viewer. */
  .cv-mobile {
    display: none;
  }
  @media (pointer: coarse) {
    .cv-frame {
      display: none;
    }
    .cv-mobile {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1.25rem 1.4rem;
      border: 1px solid var(--color-rule);
      border-radius: var(--radius-lg);
      background: var(--color-surface);
      color: var(--color-ink);
    }
    .cv-mobile:hover {
      text-decoration: none;
      border-color: color-mix(in srgb, var(--color-accent) 45%, var(--color-rule));
    }
    .cv-mobile-ic {
      display: inline-flex;
      flex: none;
      color: var(--color-accent);
    }
    .cv-mobile-text {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
      flex: 1;
    }
    .cv-mobile-text .muted {
      font-size: var(--fs-small);
    }
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>('[data-cv]');
  if (root) {
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-tab]'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('[data-panel]'));
    tabs.forEach((tab) =>
      tab.addEventListener('click', () => {
        const id = tab.dataset.tab;
        tabs.forEach((t) => t.setAttribute('aria-selected', String(t === tab)));
        panels.forEach((p) => (p.hidden = p.dataset.panel !== id));
      })
    );
  }
</script>
