---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import PresentationItem from '../components/PresentationItem.astro';

const talks = (await getCollection('presentations')).sort(
  (a, b) => b.data.startDate.getTime() - a.data.startDate.getTime()
);

const years: { year: number; items: typeof talks }[] = [];
for (const t of talks) {
  const y = t.data.startDate.getUTCFullYear();
  let bucket = years.find((b) => b.year === y);
  if (!bucket) {
    bucket = { year: y, items: [] };
    years.push(bucket);
  }
  bucket.items.push(t);
}
---
<PageLayout
  title="Talks & posters"
  eyebrow="Speaking"
  lead="Conference talks, invited lectures, and posters on machine learning for genomics."
  description="Talks and posters by Kuan-Hao Chao at conferences including ISMB, RECOMB-Seq, and ProbGen."
>
  {
    years.map(({ year, items }) => (
      <section class="talk-year">
        <h2 class="year-label">{year}</h2>
        {items.map((entry) => <PresentationItem entry={entry} />)}
      </section>
    ))
  }
</PageLayout>

<style>
  .talk-year {
    margin-bottom: var(--space-12);
  }
  .year-label {
    font-size: var(--fs-h3);
    color: var(--color-muted);
    font-weight: var(--fw-medium);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-rule);
  }
</style>
