---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import TalksList from '../components/TalksList.astro';

const talks = (await getCollection('presentations')).sort(
  (a, b) => b.data.startDate.getTime() - a.data.startDate.getTime()
);

---
<PageLayout
  title="Talks & posters"
  eyebrow="Speaking"
  lead="Conference talks, invited lectures, and posters on machine learning for genomics."
  description="Talks and posters by Kuan-Hao Chao at conferences including ISMB, RECOMB-Seq, and ProbGen."
>
  <TalksList talks={talks} />
</PageLayout>
