---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ResearchCard from '../components/ResearchCard.astro';
import PublicationItem from '../components/PublicationItem.astro';
import NewsEntry from '../components/NewsEntry.astro';
import QuoteBlock from '../components/QuoteBlock.astro';
import Icon from '../components/Icon.astro';
import SequenceTrack from '../components/SequenceTrack.astro';
import PostItem from '../components/PostItem.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { site } from '../data/site';
import { experience, education, software, type SoftwareTool } from '../data/cv';
import { readingTime } from '../lib/format';

// Flagship tools for the homepage strip: those with a logo, newest first, each
// linked to its interactive explainer post. Logos resolve like software.astro.
const logoFiles = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/logos/software/*.png',
  { eager: true }
);
const featuredTools = [...software]
  .filter((t) => t.logo && t.posts?.[0])
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 4);
const toolLogo = (t: SoftwareTool) =>
  t.logo ? logoFiles[`../assets/logos/software/${t.logo}.png`]?.default : undefined;

const research = (await getCollection('research'))
  .filter((r) => r.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const allPublications = await getCollection('publications');
const pubs = allPublications
  .filter((p) => p.data.featured)
  .sort((a, b) => (a.data.selectedOrder ?? 99) - (b.data.selectedOrder ?? 99))
  .slice(0, 5);

const latestNews = (await getCollection('news'))
  .filter((n) => !n.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 6);
const news = await Promise.all(
  latestNews.map(async (entry) => ({ entry, Content: (await render(entry)).Content }))
);

const allPosts = await getCollection('posts');
const posts = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);
---
<BaseLayout type="profile">
  <Hero />

  <section class="section home-section container" data-reveal>
    <SectionHeading eyebrow="What I work on" title="Research" href="/research/" more="All research" />
    <div class="home-research">
      {research.map((entry) => <ResearchCard entry={entry} variant="home" />)}
    </div>
  </section>

  <section class="section home-section container" data-reveal>
    <SectionHeading
      eyebrow="Selected work"
      title="Publications"
      href="/publications/"
      more="All publications"
    />
    <ol class="home-pubs">
      {pubs.map((pub) => <li><PublicationItem pub={pub} compact /></li>)}
    </ol>
  </section>

  {featuredTools.length > 0 && (
    <section class="section home-section container" data-reveal>
      <SectionHeading eyebrow="Open source" title="Featured software" href="/software/" more="All software" />
      <ul class="home-tools">
        {featuredTools.map((t) => {
          const logo = toolLogo(t);
          return (
            <li>
              <a class="home-tool" href={`/posts/${t.posts![0]}/`}>
                {logo && (
                  <span class="home-tool-logo">
                    <Image src={logo} alt={`${t.name} logo`} width={44} height={44} />
                  </span>
                )}
                <span class="home-tool-text">
                  <span class="home-tool-name">{t.name}</span>
                  <span class="home-tool-blurb">{t.blurb}</span>
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  <QuoteBlock quote={site.philosophy} cite="my open-source philosophy" />

  <section class="section home-section container" data-reveal>
    <SectionHeading eyebrow="Background" title="Experience & education" />
    <div class="home-bg">
      <div>
        <p class="bg-label eyebrow">Experience</p>
        <ul class="bg-list">
          {
            experience.map((p) => (
              <li>
                <span class="bg-period">{p.period}</span>
                <span class="bg-role">{p.role}</span>
                <span class="bg-org muted">
                  {p.url ? <a href={p.url} target="_blank" rel="noopener noreferrer">{p.org}</a> : p.org}
                  {p.unit ? `, ${p.unit}` : ''}
                </span>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <p class="bg-label eyebrow">Education</p>
        <ul class="bg-list">
          {
            education.map((p) => (
              <li>
                <span class="bg-period">{p.period}</span>
                <span class="bg-role">{p.role}</span>
                <span class="bg-org muted">
                  {p.url ? <a href={p.url} target="_blank" rel="noopener noreferrer">{p.org}</a> : p.org}
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="section home-section container" data-reveal>
      <SectionHeading eyebrow="Writing" title="Posts" href="/posts/" more="All posts" />
      <div class="home-posts">
        {posts.map((entry) => (
          <PostItem entry={entry} minutes={readingTime(entry.body ?? '')} compact />
        ))}
      </div>
    </section>
  )}

  <section class="section home-section container" data-reveal>
    <SectionHeading eyebrow="Updates" title="Recent news" href="/news/" more="All news" />
    <div class="home-news">
      {news.map(({ entry, Content }) => (
        <NewsEntry entry={entry} variant="card">
          <Content />
        </NewsEntry>
      ))}
    </div>
  </section>

  <div class="home-seq"><SequenceTrack /></div>

  <section class="cta" data-reveal>
    <div class="container cta-inner">
      <h2 class="cta-title">Let's work together</h2>
      <p class="cta-text">
        I'm always glad to talk about computational genomics, machine learning, or
        mentoring research projects. Reach out anytime.
      </p>
      <div class="cta-actions">
        <a class="btn btn--accent" href="https://calendly.com/kuanhao-chao/30min" target="_blank" rel="noopener noreferrer">
          <Icon name="coffee" size={18} /> Book a coffee chat
        </a>
        <a class="btn" href={`mailto:${site.email}`}>
          <Icon name="mail" size={18} /> Email me
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .home-research {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1px;
    border-block: 1px solid var(--color-rule);
    background: var(--color-rule);
  }
  .home-pubs {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-rule);
  }
  .home-posts {
    border-top: 1px solid var(--color-rule);
  }
  .home-tools {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    border-block: 1px solid var(--color-rule);
    background: var(--color-rule);
  }
  .home-tool {
    display: flex;
    gap: 0.8rem;
    align-items: flex-start;
    height: 100%;
    padding: var(--space-5);
    background: var(--color-bg);
    color: inherit;
    text-decoration: none;
    transition: background var(--transition);
  }
  .home-tool:hover {
    background: var(--color-surface);
  }
  .home-tool-logo {
    flex: none;
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    padding: 5px;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
    background: var(--color-surface);
  }
  [data-theme='dark'] .home-tool-logo {
    background: var(--color-figure-mat);
  }
  .home-tool-logo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .home-tool-text {
    display: grid;
    gap: 0.2rem;
  }
  .home-tool-name {
    font-weight: var(--fw-semibold);
    color: var(--color-accent);
  }
  .home-tool-blurb {
    font-size: var(--fs-small);
    color: var(--color-muted);
    line-height: var(--lh-snug);
  }
  .home-bg {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
  }
  .bg-label {
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-rule);
    margin-bottom: var(--space-4);
  }
  .bg-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .bg-list li {
    display: grid;
    gap: 0.15rem;
  }
  .bg-period {
    font-size: var(--fs-meta);
    color: var(--color-muted);
    font-variant-numeric: tabular-nums;
  }
  .bg-role {
    font-weight: var(--fw-semibold);
  }
  .bg-org {
    font-size: var(--fs-small);
  }
  .home-news {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1rem, 2vw, 1.5rem);
  }
  .cta {
    padding-block: var(--section-y);
    border-top: 1px solid var(--color-rule);
    text-align: center;
  }
  .cta-title {
    font-size: var(--fs-h1);
  }
  .cta-text {
    max-width: 36rem;
    margin: 1rem auto 2rem;
    color: var(--color-muted);
  }
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
  .home-seq {
    margin-block: clamp(2rem, 4.5vw, 3rem);
    padding-block: 0.9rem;
    border-block: 1px solid var(--color-rule);
  }

  @media (min-width: 881px) {
    .home-section,
    .cta {
      padding-block: clamp(2.25rem, 3.25vw, 2.75rem);
    }
    .home-seq {
      margin-block: var(--space-8);
      padding-block: 0.5rem;
    }
  }

  @media (max-width: 1023px) and (min-width: 640px) {
    .home-research {
      grid-template-columns: repeat(6, minmax(0, 1fr));
    }
    .home-research :global(.rcard--home) {
      grid-column: span 2;
    }
    .home-research :global(.rcard--home:nth-child(n + 4)) {
      grid-column: span 3;
    }
  }
  @media (max-width: 860px) {
    .home-news,
    .home-tools {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 639px) {
    .home-research,
    .home-news,
    .home-tools,
    .home-bg {
      grid-template-columns: 1fr;
    }
    .home-research {
      gap: 1px;
    }
    .home-bg {
      gap: var(--space-8);
    }
    .bg-role {
      font-size: 1rem;
    }
    .bg-list {
      gap: 0.9rem;
    }
  }
</style>
