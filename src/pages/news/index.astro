---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import NewsList from '../../components/NewsList.astro';

const news = (await getCollection('news')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---
<PageLayout
  title="News"
  eyebrow="Updates"
  lead="Papers, talks, releases, and milestones — filter by type, search, or browse by year."
  description="News and updates from Kuan-Hao Chao: papers, talks, software releases, and milestones."
>
  <NewsList items={news} />
</PageLayout>
