---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import { dateRange } from '../lib/format';
import { mentorship, reviewing } from '../data/cv';

const teaching = (await getCollection('teaching')).sort(
  (a, b) => b.data.startDate.getTime() - a.data.startDate.getTime()
);
---
<PageLayout
  title="Teaching & mentorship"
  eyebrow="Giving back"
  lead="Courses I've taught, students I've mentored, and the peer-review community I contribute to. I'm always glad to mentor students interested in computational genomics + AI."
  description="Teaching, mentorship, and academic service by Kuan-Hao Chao."
>
  <section class="block">
    <h2 class="block-title">Teaching</h2>
    <ul class="rows">
      {
        teaching.map((t) => (
          <li class="row">
            <div class="row-date">{dateRange(t.data.startDate, t.data.endDate)}</div>
            <div>
              <p class="row-title">{t.data.title}</p>
              <p class="row-meta muted">
                {t.data.role} · {t.data.venue}
                {t.data.location ? ` · ${t.data.location}` : ''}
              </p>
            </div>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="block">
    <h2 class="block-title">Mentorship & community</h2>
    <ul class="rows">
      {
        mentorship.map((m) => (
          <li class="row row--stack">
            <p class="row-title">
              {m.url ? (
                <a href={m.url} target="_blank" rel="noopener">{m.name}</a>
              ) : (
                m.name
              )}
            </p>
            <p class="row-meta muted">{m.detail}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="block">
    <h2 class="block-title">Peer review</h2>
    <p class="muted review-intro">Reviewer and sub-reviewer for, among others:</p>
    <ul class="journals">
      {reviewing.map((j) => <li>{j}</li>)}
    </ul>
  </section>
</PageLayout>

<style>
  .block {
    margin-bottom: var(--space-16);
  }
  .block-title {
    font-size: var(--fs-h3);
    font-weight: var(--fw-semibold);
    padding-bottom: var(--space-4);
    margin-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-rule);
  }
  .rows {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .row {
    display: grid;
    grid-template-columns: 11rem 1fr;
    gap: 0 1.5rem;
    padding-block: var(--space-5);
    border-bottom: 1px solid var(--color-rule);
  }
  .row--stack {
    display: block;
  }
  .row-date {
    font-family: var(--font-display);
    color: var(--color-muted);
    font-size: 0.95rem;
  }
  .row-title {
    font-weight: var(--fw-semibold);
    font-size: 1.05rem;
  }
  .row-meta {
    margin-top: 0.3rem;
    font-size: var(--fs-small);
  }
  .review-intro {
    margin-bottom: var(--space-4);
  }
  .journals {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .journals li {
    font-size: var(--fs-small);
    padding: 0.35em 0.8em;
    border: 1px solid var(--color-rule);
    border-radius: 999px;
    color: var(--color-muted);
  }
  @media (max-width: 560px) {
    .row {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }
  }
</style>
