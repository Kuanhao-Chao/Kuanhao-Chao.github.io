---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  eyebrow?: string;
  lead?: string;
  description?: string;
  width?: 'wide' | 'narrow';
}
const { title, eyebrow, lead, description, width = 'wide' } = Astro.props;
---
<BaseLayout title={title} description={description ?? lead}>
  <header class="page-head">
    <div class:list={['container', width === 'narrow' && 'container--narrow']}>
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      {lead && <p class="lead page-lead">{lead}</p>}
    </div>
  </header>
  <div class:list={['container', width === 'narrow' && 'container--narrow', 'page-body']} data-reveal>
    <slot />
  </div>
</BaseLayout>

<style>
  .page-head {
    padding-top: clamp(2.5rem, 6vw, 4.5rem);
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--color-rule);
  }
  .page-head h1 {
    margin-top: 0.75rem;
  }
  .page-lead {
    margin-top: 1.25rem;
    max-width: var(--measure);
    color: var(--color-muted);
  }
  .container--narrow {
    max-width: var(--container-narrow);
  }
  .page-body {
    padding-top: var(--space-12);
    padding-bottom: var(--section-y);
  }
</style>
