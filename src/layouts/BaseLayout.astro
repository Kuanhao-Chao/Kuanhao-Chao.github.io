---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SiteBackground from '../components/SiteBackground.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import PageScan from '../components/PageScan.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article' | 'profile';
}
const { title, description, image, type } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} type={type} />
    <ClientRouter />
  </head>
  <body>
    <script is:inline>
      // Set before paint so [data-reveal] elements never flash visible→hidden.
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.classList.add('reveal-ready');
      }
    </script>
    <SiteBackground />
    <ReadingProgress />
    <PageScan />
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script>
      import { prefersReducedMotion, onVisible } from '../scripts/motion';
      // Scroll-reveal + section-divider pulses. Runs on the initial load and after
      // every client-side navigation; pending observers are dropped before a swap.
      let stoppers: Array<() => void> = [];
      function reveal() {
        if (prefersReducedMotion()) return;
        const observe = (selector: string, cls: string) => {
          for (const el of document.querySelectorAll(selector)) {
            let stop = () => {};
            stop = onVisible(el, () => {
              el.classList.add(cls);
              stop();
            });
            stoppers.push(stop);
          }
        };
        observe('[data-reveal]', 'is-visible');
        observe('[data-pulse]', 'is-pulsed');
      }
      function teardown() {
        for (const stop of stoppers) stop();
        stoppers = [];
      }
      document.addEventListener('astro:page-load', reveal);
      document.addEventListener('astro:before-swap', teardown);
    </script>
  </body>
</html>
