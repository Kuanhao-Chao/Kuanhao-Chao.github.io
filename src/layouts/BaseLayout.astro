---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SiteBackground from '../components/SiteBackground.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article' | 'profile';
}
const { title, description, image, type } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} type={type} />
  </head>
  <body>
    <script is:inline>
      // Set before paint so [data-reveal] elements never flash visible→hidden.
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.classList.add('reveal-ready');
      }
    </script>
    <SiteBackground />
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script>
      import { prefersReducedMotion, onVisible } from '../scripts/motion';
      if (!prefersReducedMotion()) {
        for (const el of document.querySelectorAll('[data-reveal]')) {
          let stop = () => {};
          stop = onVisible(el, () => {
            el.classList.add('is-visible');
            stop();
          });
        }
      }
    </script>
  </body>
</html>
