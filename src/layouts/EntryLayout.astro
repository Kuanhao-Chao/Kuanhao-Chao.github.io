---
import BaseLayout from './BaseLayout.astro';
import Icon from '../components/Icon.astro';

interface LinkItem {
  label: string;
  icon: string;
  href: string;
}
interface Props {
  title: string;
  eyebrow?: string;
  meta?: string[];
  backHref: string;
  backLabel: string;
  links?: LinkItem[];
  description?: string;
}
const { title, eyebrow, meta = [], backHref, backLabel, links = [], description } = Astro.props;
---
<BaseLayout title={title} description={description} type="article">
  <article class="entry">
    <div class="container container--narrow">
      <a class="back" href={backHref}>
        <Icon name="arrow-right" size={16} class="flip" />
        {backLabel}
      </a>

      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>

      {
        meta.length > 0 && (
          <p class="entry-meta muted">{meta.join(' · ')}</p>
        )
      }

      {
        links.length > 0 && (
          <div class="entry-links">
            {links.map((l) => (
              <a class="btn" href={l.href} target="_blank" rel="noopener">
                <Icon name={l.icon} size={16} />
                {l.label}
              </a>
            ))}
          </div>
        )
      }

      <div class="entry-body">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .entry {
    padding-top: clamp(2rem, 5vw, 3.5rem);
    padding-bottom: var(--section-y);
  }
  .back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--fs-small);
    color: var(--color-muted);
    margin-bottom: 2rem;
  }
  .back:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
  .back :global(.flip) {
    transform: rotate(180deg);
  }
  h1 {
    margin-top: 0.6rem;
  }
  .entry-meta {
    margin-top: 1rem;
    font-size: var(--fs-small);
  }
  .entry-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-rule);
  }
  .entry-body {
    margin-top: 2.5rem;
  }
</style>
