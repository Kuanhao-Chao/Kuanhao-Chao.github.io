---
/**
 * Captioned figure for research detail pages. Sizes to its own shape (per `variant`),
 * breaks out symmetrically wider than the text column when the figure is large, and
 * opens full-size on click. Caption is passed as the default slot (rich HTML allowed).
 *
 * Breakout is overflow-safe: width is capped to the viewport and the figure is centered
 * with symmetric (possibly negative) inline margins — no transforms, so it never adds a
 * horizontal scrollbar. Reuses the <dialog> lightbox idiom from photos.astro.
 */
import { Image } from 'astro:assets';

interface Props {
  src: ImageMetadata;
  alt: string;
  variant?: 'wide' | 'landscape' | 'square' | 'portrait';
}
const { src, alt, variant = 'landscape' } = Astro.props;
---
<figure class:list={['zfig', `zfig--${variant}`]}>
  <button type="button" class="zfig-btn" data-zoom aria-label={`Enlarge figure: ${alt}`}>
    <Image src={src} alt={alt} widths={[480, 760, 920]} sizes="(max-width: 720px) 92vw, 880px" />
    <span class="zfig-hint" aria-hidden="true">⤢ Enlarge</span>
  </button>
  <figcaption><slot /></figcaption>

  <dialog class="zfig-dialog" data-zoom-dialog aria-label={alt}>
    <button type="button" class="zfig-close" data-zoom-close aria-label="Close figure">✕</button>
    <Image src={src} alt={alt} widths={[900, 1500, 2400]} sizes="95vw" />
  </dialog>
</figure>

<style>
  /* Per-variant width cap; the figure centers on the viewport and never overflows it. */
  .zfig {
    --cap: 780px;
    --w: min(var(--cap), calc(100vw - 2rem));
    width: var(--w);
    margin-left: calc((100% - var(--w)) / 2);
    margin-right: calc((100% - var(--w)) / 2);
    margin-block: 2.4em;
  }
  .zfig--wide { --cap: 880px; }
  .zfig--landscape { --cap: 780px; }
  .zfig--square { --cap: 700px; }
  .zfig--portrait { --cap: 560px; }

  .zfig-btn {
    display: block;
    width: 100%;
    padding: 0;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
    background: var(--color-surface);
    cursor: zoom-in;
    overflow: hidden;
    position: relative;
  }
  .zfig-btn :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }
  .zfig-hint {
    position: absolute;
    right: 0.6rem;
    bottom: 0.6rem;
    font-size: var(--fs-meta);
    font-weight: var(--fw-medium);
    background: color-mix(in srgb, var(--color-ink) 74%, transparent);
    color: var(--color-on-ink);
    padding: 0.25em 0.6em;
    border-radius: 999px;
    opacity: 0;
    transition: opacity var(--transition);
  }
  .zfig-btn:hover .zfig-hint,
  .zfig-btn:focus-visible .zfig-hint {
    opacity: 1;
  }

  .zfig-dialog {
    border: none;
    padding: 0;
    background: transparent;
    max-width: 100vw;
    max-height: 100vh;
  }
  .zfig-dialog::backdrop {
    background: var(--color-dialog-backdrop);
  }
  .zfig-dialog[open] {
    display: grid;
    place-items: center;
  }
  .zfig-dialog :global(img) {
    max-width: 95vw;
    max-height: 92vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: var(--radius);
  }
  .zfig-close {
    position: fixed;
    top: 1.1rem;
    right: 1.1rem;
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 999px;
    border: none;
    background: var(--color-dialog-control-bg);
    color: var(--color-dialog-control-ink);
    font-size: 1.05rem;
    cursor: pointer;
    transition: background var(--transition);
  }
  .zfig-close:hover {
    background: var(--color-dialog-control-bg-hover);
  }
</style>

<script>
  // Click-to-zoom for every ZoomFigure on the page.
  for (const btn of document.querySelectorAll<HTMLButtonElement>('[data-zoom]')) {
    const dialog = btn.closest('.zfig')?.querySelector<HTMLDialogElement>('[data-zoom-dialog]');
    if (!dialog) continue;
    btn.addEventListener('click', () => dialog.showModal());
    dialog
      .querySelector<HTMLButtonElement>('[data-zoom-close]')
      ?.addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  }
</script>
