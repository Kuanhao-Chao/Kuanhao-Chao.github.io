---
/** Published clinical examples: animate Figure 2's variant-effect interpretation. */
import '../styles/lvz.css';
import '../styles/osai.css';

type Site = {
  label: string;
  kind: 'acceptor' | 'donor';
  refOpen: number;
  refSplice: number;
  altOpen: number;
  altSplice: number;
};

type Example = {
  id: string;
  label: string;
  variant: string;
  phenotype: string;
  consequence: string;
  delta: string;
  referenceSequence: string;
  alternateSequence: string;
  sites: [Site, Site];
};

const examples: Example[] = [
  {
    id: 'mybpc3',
    label: 'MYBPC3',
    variant: 'chr11:47364709 G>A',
    phenotype: 'cardiomyopathy-associated variant',
    consequence: 'reported 11-bp exon extension',
    delta: 'DS_AG 0.998 · DS_AL 0.957',
    referenceSequence: '… GCGGCCCCACCCAG | GTACATCTTTTG …',
    alternateSequence: '… GCAGCCCCACCCAG | GTACATCTTTTG …',
    sites: [
      { label: 'cryptic acceptor', kind: 'acceptor', refOpen: 0, refSplice: 0, altOpen: 0.998, altSplice: 0.942 },
      { label: 'annotated acceptor', kind: 'acceptor', refOpen: 0.968, refSplice: 0.998, altOpen: 0.011, altSplice: 0.079 },
    ],
  },
  {
    id: 'opa1',
    label: 'OPA1',
    variant: 'chr3:193644727 A>G',
    phenotype: 'optic-atrophy-associated variant',
    consequence: 'reported 54-bp cryptic exon',
    delta: 'DS_AG 0.890 · DS_DG 0.642',
    referenceSequence: '… AAGGGTAAG ··· AGTGAGGTAGAAAC …',
    alternateSequence: '… AAGGGTAAG ··· AGTGAGGTAGA[G]AAC …',
    sites: [
      { label: 'cryptic acceptor', kind: 'acceptor', refOpen: 0.099, refSplice: 0.093, altOpen: 0.989, altSplice: 0.970 },
      { label: 'cryptic donor', kind: 'donor', refOpen: 0.343, refSplice: 0.247, altOpen: 0.985, altSplice: 0.982 },
    ],
  },
];

const C = {
  open: '#237a3b',
  splice: '#c51f4b',
  variant: '#f58518',
  exon: '#1d6f8a',
  effect: '#8a9491',
  acceptor: '#7a6fbe',
  donor: '#158f83',
  output: '#2e6e5e',
};

const score = (n: number) => n.toFixed(3);

function strandArrow(y: number) {
  return `<path d="M55 ${y - 2} H685 V${y - 7} L699 ${y} L685 ${y + 7} V${y + 2} H55 Z" fill="var(--color-muted)" fill-opacity="0.42"/>`;
}

function desktopGeneContext(ex: Example, step: number) {
  const focus = step === 0 || step === 4;
  const opacity = focus ? 1 : 0.65;
  const changedOpacity = step >= 4 ? 1 : 0.14;
  let s = `<g opacity="${opacity}"><text x="18" y="62" class="lvz-small" style="text-anchor:start">reference gene</text>${strandArrow(66)}<rect x="120" y="52" width="48" height="28" fill="${C.exon}"/><rect x="445" y="52" width="62" height="28" fill="${C.exon}"/><rect x="590" y="52" width="72" height="28" fill="${C.exon}"/>`;
  s += `<text x="18" y="112" class="lvz-small" style="text-anchor:start">alternate gene</text>${strandArrow(116)}<rect x="120" y="102" width="48" height="28" fill="${C.exon}"/><rect x="445" y="102" width="62" height="28" fill="${C.exon}"/><rect x="590" y="102" width="72" height="28" fill="${C.exon}"/></g>`;
  if (ex.id === 'mybpc3') {
    s += `<g opacity="${changedOpacity}"><rect x="397" y="102" width="48" height="28" fill="${C.effect}"/><circle cx="397" cy="116" r="5" fill="${C.variant}"/><path d="M390 93 H452" stroke="${C.output}" stroke-dasharray="5 4"/><text x="421" y="88" class="lvz-small">11-bp extension</text></g>`;
  } else {
    s += `<g opacity="${changedOpacity}"><rect x="338" y="102" width="92" height="28" fill="${C.effect}"/><circle cx="430" cy="116" r="5" fill="${C.variant}"/><path d="M330 93 H438" stroke="${C.output}" stroke-dasharray="5 4"/><text x="384" y="88" class="lvz-small">54-bp cryptic exon</text></g>`;
  }
  return s;
}

function desktopSequence(ex: Example, step: number) {
  const panelOpacity = step === 1 || step === 2 || step === 3 || step === 4 ? 1 : 0.65;
  const refOpacity = step === 2 ? 1 : step === 3 ? 0.35 : 0.78;
  const altOpacity = step === 3 || step === 4 ? 1 : step === 2 ? 0.35 : 0.78;
  let s = `<g opacity="${panelOpacity}"><rect x="18" y="148" width="430" height="196" rx="6" fill="var(--color-bg)" stroke="var(--color-rule)"/><text x="34" y="170" class="lvz-tl">Matched sequence windows</text>`;
  s += `<g opacity="${refOpacity}"><text x="38" y="208" class="lvz-small">REFERENCE</text><line x1="105" y1="218" x2="426" y2="218" stroke="var(--color-ink)" stroke-width="2"/><text x="266" y="207" class="osai-mono">${ex.referenceSequence}</text></g>`;
  s += `<g opacity="${altOpacity}"><text x="38" y="279" class="lvz-small">ALTERNATE</text><line x1="105" y1="289" x2="426" y2="289" stroke="var(--color-ink)" stroke-width="2"/><text x="266" y="278" class="osai-mono">${ex.alternateSequence}</text></g>`;
  const mutationOpacity = step === 1 ? 1 : 0.5;
  s += `<g opacity="${mutationOpacity}"><rect x="152" y="307" width="162" height="26" rx="4" fill="${C.variant}" fill-opacity="0.08" stroke="${C.variant}"/><text x="233" y="325" class="lvz-small" fill="${C.variant}">one-base substitution · ${ex.variant.split(' ').at(-1)}</text></g></g>`;
  return s;
}

function desktopScoreSite(site: Site, x: number, step: number) {
  const color = site.kind === 'acceptor' ? C.acceptor : C.donor;
  const opacity = step === 2 || step === 3 ? 1 : 0.82;
  const refOpacity = step === 2 ? 1 : step === 3 ? 0.45 : 0.92;
  const altOpacity = step === 3 ? 1 : step === 2 ? 0.45 : 0.92;
  return `<g opacity="${opacity}"><rect x="${x}" y="148" width="132" height="196" rx="6" fill="${color}" fill-opacity="0.035" stroke="${color}"/><text x="${x + 66}" y="171" class="lvz-small" fill="${color}">${site.label}</text><g opacity="${refOpacity}"><text x="${x + 12}" y="203" class="lvz-small" style="text-anchor:start">reference</text><text x="${x + 12}" y="225" class="lvz-small" fill="${C.open}" style="text-anchor:start">OpenSpliceAI ${score(site.refOpen)}</text><text x="${x + 12}" y="246" class="lvz-small" fill="${C.splice}" style="text-anchor:start">SpliceAI ${score(site.refSplice)}</text></g><line x1="${x + 10}" y1="260" x2="${x + 122}" y2="260" stroke="var(--color-rule)"/><g opacity="${altOpacity}"><text x="${x + 12}" y="282" class="lvz-small" style="text-anchor:start">alternate</text><text x="${x + 12}" y="304" class="lvz-small" fill="${C.open}" style="text-anchor:start">OpenSpliceAI ${score(site.altOpen)}</text><text x="${x + 12}" y="325" class="lvz-small" fill="${C.splice}" style="text-anchor:start">SpliceAI ${score(site.altSplice)}</text></g></g>`;
}

function desktopFrame(ex: Example, step: number) {
  let s = `<text x="18" y="24" class="lvz-tl">${ex.label} · ${ex.variant}</text><text x="600" y="24" class="lvz-small">${ex.phenotype}</text>`;
  s += desktopGeneContext(ex, step) + desktopSequence(ex, step);
  s += desktopScoreSite(ex.sites[0], 466, step) + desktopScoreSite(ex.sites[1], 610, step);
  const outputOpacity = step === 5 ? 1 : step === 4 ? 0.72 : 0.34;
  s += `<g opacity="${outputOpacity}"><rect x="18" y="362" width="724" height="56" rx="6" fill="${C.output}" fill-opacity="0.055" stroke="${C.output}" stroke-width="${step === 5 ? 2.4 : 1.2}"/><text x="200" y="385" class="lvz-nt on" fill="${C.output}">${ex.consequence}</text><text x="200" y="406" class="lvz-small">OpenSpliceAI variant effect</text><text x="555" y="385" class="lvz-nt on" fill="${C.open}">${ex.delta}</text><text x="555" y="406" class="lvz-small">written with DP positions to VCF INFO</text></g>`;
  return `<svg viewBox="0 0 760 430" class="lvz-svg" role="img" aria-label="${ex.label} clinical variant-effect animation, highlighting step ${step + 1}" preserveAspectRatio="xMidYMid meet">${s}</svg>`;
}

function mobileGeneContext(ex: Example, step: number) {
  const changedOpacity = step >= 4 ? 1 : 0.14;
  const changedX = ex.id === 'mybpc3' ? 185 : 142;
  const changedW = ex.id === 'mybpc3' ? 38 : 82;
  return `<g opacity="${step === 0 || step === 4 ? 1 : 0.65}"><text x="14" y="46" class="lvz-small" style="text-anchor:start">REFERENCE</text><line x1="92" y1="43" x2="338" y2="43" stroke="var(--color-muted)"/><rect x="112" y="31" width="30" height="24" fill="${C.exon}"/><rect x="224" y="31" width="42" height="24" fill="${C.exon}"/><rect x="294" y="31" width="36" height="24" fill="${C.exon}"/><text x="14" y="94" class="lvz-small" style="text-anchor:start">ALTERNATE</text><line x1="92" y1="91" x2="338" y2="91" stroke="var(--color-muted)"/><rect x="112" y="79" width="30" height="24" fill="${C.exon}"/><rect x="224" y="79" width="42" height="24" fill="${C.exon}"/><rect x="294" y="79" width="36" height="24" fill="${C.exon}"/></g><g opacity="${changedOpacity}"><rect x="${changedX}" y="79" width="${changedW}" height="24" fill="${C.effect}"/><circle cx="${changedX}" cy="91" r="4" fill="${C.variant}"/><text x="180" y="124" class="lvz-small">${ex.consequence}</text></g>`;
}

function mobileScoreSite(site: Site, y: number, step: number) {
  const color = site.kind === 'acceptor' ? C.acceptor : C.donor;
  const opacity = step === 2 || step === 3 ? 1 : 0.82;
  const refOpacity = step === 2 ? 1 : step === 3 ? 0.45 : 0.92;
  const altOpacity = step === 3 ? 1 : step === 2 ? 0.45 : 0.92;
  return `<g opacity="${opacity}"><rect x="12" y="${y}" width="336" height="92" rx="5" fill="${color}" fill-opacity="0.035" stroke="${color}"/><text x="26" y="${y + 22}" class="lvz-tl" fill="${color}">${site.label}</text><g opacity="${refOpacity}"><text x="26" y="${y + 49}" class="lvz-small">ref</text><text x="88" y="${y + 49}" class="lvz-small" fill="${C.open}">OSAI ${score(site.refOpen)}</text><text x="223" y="${y + 49}" class="lvz-small" fill="${C.splice}">SpliceAI ${score(site.refSplice)}</text></g><g opacity="${altOpacity}"><text x="26" y="${y + 75}" class="lvz-small">alt</text><text x="88" y="${y + 75}" class="lvz-small" fill="${C.open}">OSAI ${score(site.altOpen)}</text><text x="223" y="${y + 75}" class="lvz-small" fill="${C.splice}">SpliceAI ${score(site.altSplice)}</text></g></g>`;
}

function mobileFrame(ex: Example, step: number) {
  let s = `<text x="12" y="20" class="lvz-tl">${ex.label} · ${ex.variant}</text>${mobileGeneContext(ex, step)}`;
  const seqOpacity = step >= 1 && step <= 4 ? 1 : 0.65;
  s += `<g opacity="${seqOpacity}"><rect x="12" y="140" width="336" height="138" rx="5" fill="var(--color-bg)" stroke="var(--color-rule)"/><text x="20" y="164" class="lvz-small" style="text-anchor:start">REFERENCE</text><text x="180" y="191" class="osai-mono">${ex.referenceSequence}</text><text x="20" y="220" class="lvz-small" style="text-anchor:start">ALTERNATE</text><text x="180" y="247" class="osai-mono">${ex.alternateSequence}</text><text x="180" y="267" class="lvz-small" fill="${C.variant}">${ex.variant.split(' ').at(-1)}</text></g>`;
  s += mobileScoreSite(ex.sites[0], 294, step) + mobileScoreSite(ex.sites[1], 398, step);
  const outputOpacity = step === 5 ? 1 : step === 4 ? 0.72 : 0.34;
  s += `<g opacity="${outputOpacity}"><rect x="12" y="508" width="336" height="92" rx="5" fill="${C.output}" fill-opacity="0.055" stroke="${C.output}" stroke-width="${step === 5 ? 2.4 : 1.2}"/><text x="180" y="536" class="lvz-nt on" fill="${C.output}">${ex.consequence}</text><text x="180" y="564" class="lvz-nt on" fill="${C.open}">${ex.delta}</text><text x="180" y="586" class="lvz-small">DS + DP fields → OpenSpliceAI VCF INFO</text></g>`;
  return `<svg viewBox="0 0 360 612" class="lvz-svg" role="img" aria-label="${ex.label} clinical variant-effect animation, highlighting step ${step + 1}" preserveAspectRatio="xMidYMid meet">${s}</svg>`;
}

const steps = [
  ['Locate the variant in its gene context', 'Reference and alternate gene tracks place the one-base substitution relative to nearby exons.'],
  ['Build matched reference and alternate sequences', 'The two sequence windows share coordinates and context, differing only at the highlighted allele.'],
  ['Read the reference splice-site probabilities', 'OpenSpliceAI and SpliceAI provide the baseline acceptor or donor probabilities at the affected sites.'],
  ['Measure how the alternate allele changes the scores', 'The alternate sequence activates a cryptic site and, for MYBPC3, suppresses the original acceptor.'],
  ['Translate the score changes into a splice consequence', 'The altered boundaries predict an 11-bp exon extension in MYBPC3 or a 54-bp cryptic exon in OPA1.'],
  ['Write OpenSpliceAI delta scores and positions', 'The largest class-specific probability changes become DS values, with their DP positions written to VCF INFO.'],
] as const;
---

<section id="variant-effect-animation" class="lvz osai osai-variant" role="group" aria-label="Interactive: OpenSpliceAI clinical variant-effect prediction" data-print-final-state="true">
  <div class="lvz-head"><p class="lvz-title">Read how a variant rewires splicing</p><label class="osai-selector"><span>Clinical case</span><select data-osai-variant-select>{examples.map((example) => <option value={example.id}>{example.label}</option>)}</select></label></div>
  <p class="lvz-caption" data-wgi-caption aria-live="polite">{steps[0][1]}</p>
  <nav class="lvz-progress" aria-label="Variant-effect steps">{steps.map(([title], i) => <button type="button" class="lvz-jump" data-wgi-jump aria-label={`Step ${i + 1}: ${title}`} title={title}>{i + 1}</button>)}</nav>
  {examples.map((example, exampleIndex) => (
    <div data-osai-variant-group={example.id} hidden={exampleIndex !== 0}>
      <p class="osai-print-example">{example.label}</p>
      {steps.map(([title, caption], i) => (
        <div class="lvz-step" data-wgi-step data-print-final={i === steps.length - 1 ? 'true' : undefined} data-caption={caption} hidden={i !== 0}>
          <p class="lvz-steptitle"><span class="lvz-num">{i + 1}</span>{title}</p>
          <div class="lvz-fig lvz-visual--desktop" set:html={desktopFrame(example, i)} />
          <div class="lvz-fig lvz-visual--mobile" set:html={mobileFrame(example, i)} />
        </div>
      ))}
    </div>
  ))}
  <div class="lvz-controls"><button type="button" class="lvz-btn" data-wgi-prev aria-label="Previous step">← Prev</button><button type="button" class="lvz-btn" data-wgi-play aria-pressed="false" aria-label="Play animation"><span data-wgi-play-icon>▶</span> <span data-wgi-play-label>Play</span></button><button type="button" class="lvz-btn" data-wgi-next aria-label="Next step">Next →</button><button type="button" class="lvz-btn" data-wgi-reset aria-label="Restart from first step">↺ Restart</button><span class="lvz-pos" data-wgi-pos>1 / {steps.length}</span></div>
  <div class="lvz-legend"><span><span class="lvz-sw" style={`background:${C.open}`}></span>OpenSpliceAI</span><span><span class="lvz-sw" style={`background:${C.splice}`}></span>SpliceAI</span><span><span class="lvz-sw" style={`background:${C.variant}`}></span>changed base</span><span><span class="lvz-sw" style={`background:${C.exon}`}></span>annotated exon</span><span><span class="lvz-sw" style={`background:${C.effect}`}></span>predicted exon change</span></div>
</section>

<style>
  @media print {
    .osai-variant[data-print-final-state='true'] [data-osai-variant-group] { display: block !important; margin-top: 0.8rem; break-inside: avoid-page; }
  }
</style>

<script>
  import { mountStepper } from '../scripts/wgiStepper';
  function boot() {
    for (const root of document.querySelectorAll<HTMLElement>('.osai-variant')) {
      if (root.dataset.osaiReady === 'true') continue;
      root.dataset.osaiReady = 'true';
      const groups = Array.from(root.querySelectorAll<HTMLElement>('[data-osai-variant-group]'));
      const select = root.querySelector<HTMLSelectElement>('[data-osai-variant-select]');
      let active = select?.value || groups[0]?.dataset.osaiVariantGroup || '';
      let current = 0;
      const activeSteps = () => Array.from(groups.find((group) => group.dataset.osaiVariantGroup === active)?.querySelectorAll<HTMLElement>('[data-wgi-step]') || []);
      const show = (i: number) => { current = i; groups.forEach((group) => { const on = group.dataset.osaiVariantGroup === active; group.hidden = !on; Array.from(group.querySelectorAll<HTMLElement>('[data-wgi-step]')).forEach((step, k) => { const selected = on && i === k; step.hidden = !selected; step.setAttribute('aria-current', selected ? 'step' : 'false'); }); }); };
      const api = mountStepper(root, { total: activeSteps().length, onShow: show, caption: (i) => activeSteps()[i]?.dataset.caption || '', interval: 7000 });
      select?.addEventListener('change', () => { api?.stop(); active = select.value; api?.show(current); });
    }
  }
  boot();
  document.addEventListener('astro:page-load', boot);
</script>
