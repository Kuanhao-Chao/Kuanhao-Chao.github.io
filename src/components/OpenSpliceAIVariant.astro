---
/** Published clinical examples: animate Figure 2's variant-effect interpretation. */
import '../styles/lvz.css';
import '../styles/osai.css';

type Site = {
  label: string;
  kind: 'acceptor' | 'donor';
  refOpen: number;
  refSplice: number;
  altOpen: number;
  altSplice: number;
};

type Example = {
  id: string;
  label: string;
  variant: string;
  phenotype: string;
  consequence: string;
  delta: string;
  referenceSequence: string;
  alternateSequence: string;
  sites: [Site, Site];
};

const examples: Example[] = [
  {
    id: 'mybpc3',
    label: 'MYBPC3',
    variant: 'chr11:47364709 G>A',
    phenotype: 'cardiomyopathy-associated variant',
    consequence: 'reported 11-bp exon extension',
    delta: 'DS_AG 0.998 · DS_AL 0.957',
    referenceSequence: '… GCGGCCCCACCCAG | GTACATCTTTTG …',
    alternateSequence: '… GCAGCCCCACCCAG | GTACATCTTTTG …',
    sites: [
      { label: 'cryptic acceptor', kind: 'acceptor', refOpen: 0, refSplice: 0, altOpen: 0.998, altSplice: 0.942 },
      { label: 'annotated acceptor', kind: 'acceptor', refOpen: 0.968, refSplice: 0.998, altOpen: 0.011, altSplice: 0.079 },
    ],
  },
  {
    id: 'opa1',
    label: 'OPA1',
    variant: 'chr3:193644727 A>G',
    phenotype: 'optic-atrophy-associated variant',
    consequence: 'reported 54-bp cryptic exon',
    delta: 'DS_AG 0.890 · DS_DG 0.642',
    referenceSequence: '… AAGGGTAAG ··· AGTGAGGTAGAAAC …',
    alternateSequence: '… AAGGGTAAG ··· AGTGAGGTAGA[G]AAC …',
    sites: [
      { label: 'cryptic acceptor', kind: 'acceptor', refOpen: 0.099, refSplice: 0.093, altOpen: 0.989, altSplice: 0.970 },
      { label: 'cryptic donor', kind: 'donor', refOpen: 0.343, refSplice: 0.247, altOpen: 0.985, altSplice: 0.982 },
    ],
  },
];

const C = {
  open: '#237a3b',
  splice: '#c51f4b',
  variant: '#f58518',
  exon: '#1d6f8a',
  effect: '#8a9491',
  acceptor: '#7a6fbe',
  donor: '#158f83',
  output: '#2e6e5e',
};

const score = (n: number) => n.toFixed(3);

function desktopTrackArrow(y: number) {
  return `<path d="M148 ${y - 2} H796 V${y - 7} L810 ${y} L796 ${y + 7} V${y + 2} H148 Z" fill="var(--color-muted)" fill-opacity="0.4"/>`;
}

function desktopGeneContext(ex: Example, step: number) {
  const opacity = step === 0 || step === 4 ? 1 : step === 5 ? 0.82 : 0.62;
  const changedOpacity = step >= 4 ? 1 : 0.12;
  let s = `<g opacity="${opacity}"><rect x="20" y="44" width="820" height="142" rx="6" fill="var(--color-bg)" stroke="var(--color-rule)"/><text x="38" y="70" class="lvz-tl">Gene context</text><text x="38" y="110" class="lvz-small" style="text-anchor:start">REFERENCE</text>${desktopTrackArrow(106)}<rect x="210" y="92" width="52" height="28" fill="${C.exon}"/><rect x="520" y="92" width="64" height="28" fill="${C.exon}"/><rect x="704" y="92" width="72" height="28" fill="${C.exon}"/><text x="38" y="158" class="lvz-small" style="text-anchor:start">ALTERNATE</text>${desktopTrackArrow(154)}<rect x="210" y="140" width="52" height="28" fill="${C.exon}"/><rect x="520" y="140" width="64" height="28" fill="${C.exon}"/><rect x="704" y="140" width="72" height="28" fill="${C.exon}"/></g>`;
  if (ex.id === 'mybpc3') {
    s += `<g opacity="${changedOpacity}"><rect x="472" y="140" width="48" height="28" fill="${C.effect}"/><circle cx="472" cy="154" r="5" fill="${C.variant}"/><path d="M464 132 H528" stroke="${C.output}" stroke-dasharray="5 4"/><text x="496" y="128" class="lvz-small">11-bp extension</text></g>`;
  } else {
    s += `<g opacity="${changedOpacity}"><rect x="418" y="140" width="102" height="28" fill="${C.effect}"/><circle cx="520" cy="154" r="5" fill="${C.variant}"/><path d="M410 132 H528" stroke="${C.output}" stroke-dasharray="5 4"/><text x="469" y="128" class="lvz-small">54-bp cryptic exon</text></g>`;
  }
  return s;
}

function desktopSequence(ex: Example, step: number) {
  const panelOpacity = step >= 1 && step <= 4 ? 1 : step === 5 ? 0.82 : 0.62;
  const refOpacity = step === 2 ? 1 : step === 3 ? 0.38 : 0.82;
  const altOpacity = step === 3 || step === 4 ? 1 : step === 2 ? 0.38 : 0.82;
  const mutationOpacity = step === 1 ? 1 : 0.52;
  return `<g opacity="${panelOpacity}"><rect x="20" y="204" width="820" height="162" rx="6" fill="var(--color-bg)" stroke="var(--color-rule)"/><text x="38" y="230" class="lvz-tl">Matched sequence windows</text><g opacity="${mutationOpacity}"><rect x="644" y="216" width="178" height="26" rx="4" fill="${C.variant}" fill-opacity="0.08" stroke="${C.variant}"/><text x="733" y="234" class="lvz-small" fill="${C.variant}">one-base substitution · ${ex.variant.split(' ').at(-1)}</text></g><g opacity="${refOpacity}"><text x="38" y="275" class="lvz-small" style="text-anchor:start">REFERENCE</text><line x1="142" y1="286" x2="814" y2="286" stroke="var(--color-ink)" stroke-width="2"/><text x="478" y="274" class="osai-mono">${ex.referenceSequence}</text></g><g opacity="${altOpacity}"><text x="38" y="332" class="lvz-small" style="text-anchor:start">ALTERNATE</text><line x1="142" y1="343" x2="814" y2="343" stroke="var(--color-ink)" stroke-width="2"/><text x="478" y="331" class="osai-mono">${ex.alternateSequence}</text></g></g>`;
}

function desktopScoreSite(site: Site, x: number, step: number) {
  const color = site.kind === 'acceptor' ? C.acceptor : C.donor;
  const opacity = step === 2 || step === 3 ? 1 : step === 5 ? 0.9 : 0.8;
  const refOpacity = step === 2 ? 1 : step === 3 ? 0.42 : 0.92;
  const altOpacity = step === 3 ? 1 : step === 2 ? 0.42 : 0.92;
  return `<g opacity="${opacity}"><rect x="${x}" y="422" width="382" height="116" rx="6" fill="${color}" fill-opacity="0.035" stroke="${color}"/><text x="${x + 16}" y="446" class="lvz-tl" fill="${color}" style="text-anchor:start">${site.label}</text><text x="${x + 170}" y="446" class="lvz-small">REFERENCE</text><text x="${x + 305}" y="446" class="lvz-small">ALTERNATE</text><line x1="${x + 16}" y1="457" x2="${x + 366}" y2="457" stroke="var(--color-rule)"/><text x="${x + 16}" y="484" class="lvz-small" fill="${C.open}" style="text-anchor:start">OpenSpliceAI</text><text x="${x + 16}" y="515" class="lvz-small" fill="${C.splice}" style="text-anchor:start">SpliceAI</text><g opacity="${refOpacity}"><text x="${x + 170}" y="484" class="lvz-nt on" fill="${C.open}">${score(site.refOpen)}</text><text x="${x + 170}" y="515" class="lvz-nt on" fill="${C.splice}">${score(site.refSplice)}</text></g><g opacity="${altOpacity}"><text x="${x + 305}" y="484" class="lvz-nt on" fill="${C.open}">${score(site.altOpen)}</text><text x="${x + 305}" y="515" class="lvz-nt on" fill="${C.splice}">${score(site.altSplice)}</text></g></g>`;
}

function desktopFrame(ex: Example, step: number) {
  let s = `<text x="20" y="24" class="lvz-tl">${ex.label} · ${ex.variant}</text><text x="840" y="24" class="lvz-small" style="text-anchor:end">${ex.phenotype}</text>`;
  s += desktopGeneContext(ex, step) + desktopSequence(ex, step);
  s += `<g opacity="${step === 2 || step === 3 ? 1 : step === 5 ? 0.86 : 0.68}"><rect x="20" y="384" width="820" height="172" rx="6" fill="var(--color-bg)" stroke="var(--color-rule)"/><text x="38" y="410" class="lvz-tl">Reference and alternate splice-site scores</text></g>`;
  s += desktopScoreSite(ex.sites[0], 38, step) + desktopScoreSite(ex.sites[1], 440, step);
  const outputOpacity = step === 5 ? 1 : step === 4 ? 0.72 : 0.3;
  s += `<g opacity="${outputOpacity}"><rect x="20" y="574" width="820" height="86" rx="6" fill="${C.output}" fill-opacity="0.055" stroke="${C.output}" stroke-width="${step === 5 ? 2.4 : 1.2}"/><text x="38" y="600" class="lvz-tl" fill="${C.output}" style="text-anchor:start">Predicted splice consequence</text><text x="236" y="630" class="lvz-nt on" fill="${C.output}">${ex.consequence}</text><text x="236" y="649" class="lvz-small">sequence-level interpretation</text><line x1="430" y1="590" x2="430" y2="644" stroke="var(--color-rule)"/><text x="635" y="620" class="lvz-nt on" fill="${C.open}">${ex.delta}</text><text x="635" y="644" class="lvz-small">DS values with DP positions → VCF INFO</text></g>`;
  return `<svg viewBox="0 0 860 678" class="lvz-svg" role="img" aria-label="${ex.label} clinical variant-effect animation, highlighting step ${step + 1}" preserveAspectRatio="xMidYMid meet">${s}</svg>`;
}

function mobileTrackArrow(y: number) {
  return `<path d="M108 ${y - 1.5} H322 V${y - 5} L332 ${y} L322 ${y + 5} V${y + 1.5} H108 Z" fill="var(--color-muted)" fill-opacity="0.4"/>`;
}

function mobileGeneContext(ex: Example, step: number) {
  const opacity = step === 0 || step === 4 ? 1 : step === 5 ? 0.82 : 0.62;
  const changedOpacity = step >= 4 ? 1 : 0.12;
  const changedX = ex.id === 'mybpc3' ? 208 : 170;
  const changedW = ex.id === 'mybpc3' ? 36 : 74;
  return `<g opacity="${opacity}"><rect x="12" y="40" width="336" height="168" rx="5" fill="var(--color-bg)" stroke="var(--color-rule)"/><text x="24" y="66" class="lvz-tl">Gene context</text><text x="24" y="104" class="lvz-small" style="text-anchor:start">REFERENCE</text>${mobileTrackArrow(100)}<rect x="126" y="88" width="28" height="24" fill="${C.exon}"/><rect x="244" y="88" width="38" height="24" fill="${C.exon}"/><rect x="304" y="88" width="26" height="24" fill="${C.exon}"/><text x="24" y="156" class="lvz-small" style="text-anchor:start">ALTERNATE</text>${mobileTrackArrow(152)}<rect x="126" y="140" width="28" height="24" fill="${C.exon}"/><rect x="244" y="140" width="38" height="24" fill="${C.exon}"/><rect x="304" y="140" width="26" height="24" fill="${C.exon}"/></g><g opacity="${changedOpacity}"><rect x="${changedX}" y="140" width="${changedW}" height="24" fill="${C.effect}"/><circle cx="${ex.id === 'mybpc3' ? changedX : changedX + changedW}" cy="152" r="4" fill="${C.variant}"/><text x="180" y="193" class="lvz-small">${ex.consequence}</text></g>`;
}

function mobileScoreSite(site: Site, y: number, step: number) {
  const color = site.kind === 'acceptor' ? C.acceptor : C.donor;
  const opacity = step === 2 || step === 3 ? 1 : step === 5 ? 0.9 : 0.8;
  const refOpacity = step === 2 ? 1 : step === 3 ? 0.42 : 0.92;
  const altOpacity = step === 3 ? 1 : step === 2 ? 0.42 : 0.92;
  return `<g opacity="${opacity}"><rect x="22" y="${y}" width="316" height="112" rx="5" fill="${color}" fill-opacity="0.035" stroke="${color}"/><text x="34" y="${y + 23}" class="lvz-tl" fill="${color}" style="text-anchor:start">${site.label}</text><text x="198" y="${y + 23}" class="lvz-small">REF</text><text x="286" y="${y + 23}" class="lvz-small">ALT</text><line x1="34" y1="${y + 35}" x2="326" y2="${y + 35}" stroke="var(--color-rule)"/><text x="34" y="${y + 66}" class="lvz-small" fill="${C.open}" style="text-anchor:start">OpenSpliceAI</text><text x="34" y="${y + 94}" class="lvz-small" fill="${C.splice}" style="text-anchor:start">SpliceAI</text><g opacity="${refOpacity}"><text x="198" y="${y + 66}" class="lvz-nt on" fill="${C.open}">${score(site.refOpen)}</text><text x="198" y="${y + 94}" class="lvz-nt on" fill="${C.splice}">${score(site.refSplice)}</text></g><g opacity="${altOpacity}"><text x="286" y="${y + 66}" class="lvz-nt on" fill="${C.open}">${score(site.altOpen)}</text><text x="286" y="${y + 94}" class="lvz-nt on" fill="${C.splice}">${score(site.altSplice)}</text></g></g>`;
}

function mobileFrame(ex: Example, step: number) {
  let s = `<text x="12" y="20" class="lvz-tl">${ex.label} · ${ex.variant}</text>${mobileGeneContext(ex, step)}`;
  const seqOpacity = step >= 1 && step <= 4 ? 1 : step === 5 ? 0.82 : 0.62;
  const refOpacity = step === 2 ? 1 : step === 3 ? 0.38 : 0.82;
  const altOpacity = step === 3 || step === 4 ? 1 : step === 2 ? 0.38 : 0.82;
  s += `<g opacity="${seqOpacity}"><rect x="12" y="226" width="336" height="166" rx="5" fill="var(--color-bg)" stroke="var(--color-rule)"/><text x="24" y="252" class="lvz-tl">Matched sequence windows</text><g opacity="${refOpacity}"><text x="24" y="281" class="lvz-small" style="text-anchor:start">REFERENCE</text><text x="180" y="306" class="osai-mono">${ex.referenceSequence}</text></g><g opacity="${altOpacity}"><text x="24" y="334" class="lvz-small" style="text-anchor:start">ALTERNATE</text><text x="180" y="359" class="osai-mono">${ex.alternateSequence}</text></g><text x="180" y="381" class="lvz-small" fill="${C.variant}">one-base substitution · ${ex.variant.split(' ').at(-1)}</text></g>`;
  s += `<g opacity="${step === 2 || step === 3 ? 1 : step === 5 ? 0.86 : 0.68}"><rect x="12" y="410" width="336" height="306" rx="5" fill="var(--color-bg)" stroke="var(--color-rule)"/><text x="24" y="436" class="lvz-tl">Splice-site scores</text></g>`;
  s += mobileScoreSite(ex.sites[0], 452, step) + mobileScoreSite(ex.sites[1], 584, step);
  const outputOpacity = step === 5 ? 1 : step === 4 ? 0.72 : 0.3;
  s += `<g opacity="${outputOpacity}"><rect x="12" y="734" width="336" height="132" rx="5" fill="${C.output}" fill-opacity="0.055" stroke="${C.output}" stroke-width="${step === 5 ? 2.4 : 1.2}"/><text x="24" y="760" class="lvz-tl" fill="${C.output}" style="text-anchor:start">Predicted splice consequence</text><text x="180" y="794" class="lvz-nt on" fill="${C.output}">${ex.consequence}</text><line x1="32" y1="811" x2="328" y2="811" stroke="var(--color-rule)"/><text x="180" y="837" class="lvz-nt on" fill="${C.open}">${ex.delta}</text><text x="180" y="855" class="lvz-small">DS + DP fields → OpenSpliceAI VCF INFO</text></g>`;
  return `<svg viewBox="0 0 360 880" class="lvz-svg" role="img" aria-label="${ex.label} clinical variant-effect animation, highlighting step ${step + 1}" preserveAspectRatio="xMidYMid meet">${s}</svg>`;
}

const steps = [
  ['Locate the variant in its gene context', 'Reference and alternate gene tracks place the one-base substitution relative to nearby exons.'],
  ['Build matched reference and alternate sequences', 'The two sequence windows share coordinates and context, differing only at the highlighted allele.'],
  ['Read the reference splice-site probabilities', 'OpenSpliceAI and SpliceAI provide the baseline acceptor or donor probabilities at the affected sites.'],
  ['Measure how the alternate allele changes the scores', 'The alternate sequence activates a cryptic site and, for MYBPC3, suppresses the original acceptor.'],
  ['Translate the score changes into a splice consequence', 'The altered boundaries predict an 11-bp exon extension in MYBPC3 or a 54-bp cryptic exon in OPA1.'],
  ['Write OpenSpliceAI delta scores and positions', 'The largest class-specific probability changes become DS values, with their DP positions written to VCF INFO.'],
] as const;
---

<section id="variant-effect-animation" class="lvz osai osai-variant" role="group" aria-label="Interactive: OpenSpliceAI clinical variant-effect prediction" data-print-final-state="true">
  <div class="lvz-head"><p class="lvz-title">Read how a variant rewires splicing</p><label class="osai-selector"><span>Clinical case</span><select data-osai-variant-select>{examples.map((example) => <option value={example.id}>{example.label}</option>)}</select></label></div>
  <p class="lvz-caption" data-wgi-caption aria-live="polite">{steps[0][1]}</p>
  <nav class="lvz-progress" aria-label="Variant-effect steps">{steps.map(([title], i) => <button type="button" class="lvz-jump" data-wgi-jump aria-label={`Step ${i + 1}: ${title}`} title={title}>{i + 1}</button>)}</nav>
  {examples.map((example, exampleIndex) => (
    <div data-osai-variant-group={example.id} hidden={exampleIndex !== 0}>
      <p class="osai-print-example">{example.label}</p>
      {steps.map(([title, caption], i) => (
        <div class="lvz-step" data-wgi-step data-print-final={i === steps.length - 1 ? 'true' : undefined} data-caption={caption} hidden={i !== 0}>
          <p class="lvz-steptitle"><span class="lvz-num">{i + 1}</span>{title}</p>
          <div class="lvz-fig lvz-visual--desktop" set:html={desktopFrame(example, i)} />
          <div class="lvz-fig lvz-visual--mobile" set:html={mobileFrame(example, i)} />
        </div>
      ))}
    </div>
  ))}
  <div class="lvz-controls"><button type="button" class="lvz-btn" data-wgi-prev aria-label="Previous step">← Prev</button><button type="button" class="lvz-btn" data-wgi-play aria-pressed="false" aria-label="Play animation"><span data-wgi-play-icon>▶</span> <span data-wgi-play-label>Play</span></button><button type="button" class="lvz-btn" data-wgi-next aria-label="Next step">Next →</button><button type="button" class="lvz-btn" data-wgi-reset aria-label="Restart from first step">↺ Restart</button><span class="lvz-pos" data-wgi-pos>1 / {steps.length}</span></div>
  <div class="lvz-legend"><span><span class="lvz-sw" style={`background:${C.open}`}></span>OpenSpliceAI</span><span><span class="lvz-sw" style={`background:${C.splice}`}></span>SpliceAI</span><span><span class="lvz-sw" style={`background:${C.variant}`}></span>changed base</span><span><span class="lvz-sw" style={`background:${C.exon}`}></span>annotated exon</span><span><span class="lvz-sw" style={`background:${C.effect}`}></span>predicted exon change</span></div>
</section>

<style>
  @media print {
    .osai-variant[data-print-final-state='true'] [data-osai-variant-group] { display: block !important; margin-top: 0.8rem; break-inside: avoid-page; }
  }
</style>

<script>
  import { mountStepper } from '../scripts/wgiStepper';
  function boot() {
    for (const root of document.querySelectorAll<HTMLElement>('.osai-variant')) {
      if (root.dataset.osaiReady === 'true') continue;
      root.dataset.osaiReady = 'true';
      const groups = Array.from(root.querySelectorAll<HTMLElement>('[data-osai-variant-group]'));
      const select = root.querySelector<HTMLSelectElement>('[data-osai-variant-select]');
      let active = select?.value || groups[0]?.dataset.osaiVariantGroup || '';
      let current = 0;
      const activeSteps = () => Array.from(groups.find((group) => group.dataset.osaiVariantGroup === active)?.querySelectorAll<HTMLElement>('[data-wgi-step]') || []);
      const show = (i: number) => { current = i; groups.forEach((group) => { const on = group.dataset.osaiVariantGroup === active; group.hidden = !on; Array.from(group.querySelectorAll<HTMLElement>('[data-wgi-step]')).forEach((step, k) => { const selected = on && i === k; step.hidden = !selected; step.setAttribute('aria-current', selected ? 'step' : 'false'); }); }); };
      const api = mountStepper(root, { total: activeSteps().length, onShow: show, caption: (i) => activeSteps()[i]?.dataset.caption || '', interval: 7000 });
      select?.addEventListener('change', () => { api?.stop(); active = select.value; api?.show(current); });
    }
  }
  boot();
  document.addEventListener('astro:page-load', boot);
</script>
