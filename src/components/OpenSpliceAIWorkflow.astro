---
/** Published OpenSpliceAI six-command lifecycle, shown as a branching workflow. */
import '../styles/lvz.css';
import '../styles/osai.css';

const C = { data: '#4c78a8', model: '#2e6e5e', train: '#54a24b', cal: '#b07d00', predict: '#3b7f91', variant: '#d1495b' };

function node(x: number, y: number, w: number, title: string, detail: string, color: string, focused = false, quiet = false) {
  const opacity = quiet ? 0.62 : focused ? 1 : 0.42;
  return `<g opacity="${opacity}"><rect x="${x}" y="${y}" width="${w}" height="58" rx="5" fill="${color}" fill-opacity="${focused ? 0.16 : 0.05}" stroke="${color}" stroke-width="${focused ? 2.6 : 1.2}"/><text x="${x + w / 2}" y="${y + 23}" class="lvz-nt on" fill="${color}">${title}</text><text x="${x + w / 2}" y="${y + 44}" class="lvz-small">${detail}</text></g>`;
}

function path(d: string, color = 'var(--color-muted)') {
  return `<path d="${d}" fill="none" stroke="${color}" stroke-width="1.6" opacity="0.48"/>`;
}

function desktopFrame(step: number) {
  let s = `<rect x="8" y="8" width="744" height="116" rx="6" fill="${C.data}" fill-opacity="0.025" stroke="var(--color-rule)"/><text x="24" y="31" class="lvz-tl" fill="${C.data}">DATA</text>`;
  s += `<rect x="8" y="134" width="744" height="156" rx="6" fill="${C.train}" fill-opacity="0.025" stroke="var(--color-rule)"/><text x="24" y="157" class="lvz-tl" fill="${C.train}">MODEL</text>`;
  s += `<rect x="8" y="300" width="744" height="142" rx="6" fill="${C.predict}" fill-opacity="0.025" stroke="var(--color-rule)"/><text x="24" y="323" class="lvz-tl" fill="${C.predict}">APPLICATION</text>`;
  s += `<rect x="500" y="16" width="232" height="28" rx="4" fill="${C.model}" fill-opacity="0.05" stroke="${C.model}" opacity="0.65"/><text x="616" y="35" class="lvz-small">one context-keyed SpliceAI class</text>`;

  s += node(75, 50, 145, 'FASTA + GFF', 'genome inputs', C.data, false, true) + path('M220 79 H268', C.data);
  s += node(270, 50, 145, 'create-data', 'build X / Y tensors', C.data, step === 0) + path('M415 79 H468', C.data);
  s += node(470, 50, 145, 'HDF5 shards', 'train · validation · test', C.data, false, true);

  s += node(75, 184, 130, 'HDF5', 'species dataset', C.data, false, true);
  s += path('M205 213 H245 V181 H280', C.train) + path('M245 213 V251 H280', C.train);
  s += node(280, 152, 145, 'train', 'random weights', C.train, step === 1);
  s += node(280, 222, 145, 'transfer', 'pretrained weights', C.train, step === 2);
  s += path('M425 181 H456 V213 H475', C.model) + path('M425 251 H456 V213', C.model);
  s += node(475, 184, 125, 'checkpoint', 'plain state_dict', C.model, false, true) + path('M600 213 H625', C.cal);
  s += node(625, 184, 105, 'calibrate', 'optional τ', C.cal, step === 3);

  s += node(75, 342, 130, 'model source', 'checkpoint / directory', C.model, false, true);
  s += path('M205 371 H248 V348 H275', C.predict) + path('M248 371 V408 H275', C.variant);
  s += node(275, 319, 145, 'predict', 'tiled FASTA', C.predict, step === 4) + path('M420 348 H475', C.predict);
  s += node(475, 319, 145, 'BED tracks', 'donor + acceptor', C.predict, false, true);
  s += node(275, 379, 145, 'variant', 'VCF ref vs alt', C.variant, step === 5) + path('M420 408 H475', C.variant);
  s += node(475, 379, 145, 'annotated VCF', 'DS + DP fields', C.variant, false, true);
  return `<svg viewBox="0 0 760 450" class="lvz-svg" role="img" aria-label="OpenSpliceAI three-lane command lifecycle, highlighting step ${step + 1}" preserveAspectRatio="xMidYMid meet">${s}</svg>`;
}

function mobileFrame(step: number) {
  let s = `<rect x="8" y="8" width="344" height="176" rx="6" fill="${C.data}" fill-opacity="0.025" stroke="var(--color-rule)"/><text x="22" y="30" class="lvz-tl" fill="${C.data}">DATA</text>`;
  s += node(22, 42, 132, 'FASTA + GFF', 'genome inputs', C.data, false, true) + path('M154 71 H184', C.data) + node(184, 42, 154, 'create-data', 'X / Y tensors', C.data, step === 0);
  s += path('M261 100 V116', C.data) + node(103, 116, 154, 'HDF5 shards', 'train · validation · test', C.data, false, true);

  s += `<rect x="8" y="196" width="344" height="252" rx="6" fill="${C.train}" fill-opacity="0.025" stroke="var(--color-rule)"/><text x="22" y="218" class="lvz-tl" fill="${C.train}">MODEL</text>`;
  s += node(22, 232, 145, 'train', 'random weights', C.train, step === 1) + node(193, 232, 145, 'transfer', 'pretrained weights', C.train, step === 2);
  s += path('M94 290 V312 H180', C.model) + path('M266 290 V312 H180', C.model);
  s += node(103, 312, 154, 'checkpoint', 'plain state_dict', C.model, false, true) + path('M180 370 V386', C.cal);
  s += node(103, 386, 154, 'calibrate', 'optional temperature τ', C.cal, step === 3);

  s += `<rect x="8" y="460" width="344" height="224" rx="6" fill="${C.predict}" fill-opacity="0.025" stroke="var(--color-rule)"/><text x="22" y="482" class="lvz-tl" fill="${C.predict}">APPLICATION</text>`;
  s += node(103, 496, 154, 'model source', 'checkpoint / directory', C.model, false, true);
  s += path('M180 554 V572 H94', C.model) + path('M180 572 H266', C.model);
  s += node(22, 572, 145, 'predict', 'FASTA → BED', C.predict, step === 4) + node(193, 572, 145, 'variant', 'VCF → DS / DP', C.variant, step === 5);
  return `<svg viewBox="0 0 360 696" class="lvz-svg" role="img" aria-label="OpenSpliceAI three-lane command lifecycle, highlighting step ${step + 1}" preserveAspectRatio="xMidYMid meet">${s}</svg>`;
}

const steps = [
  ['Create model-ready data from a genome', 'The create-data command combines FASTA and GFF/GTF inputs and writes reusable training, validation, and test HDF5 shards.'],
  ['Train a model from random weights', 'The train path reads HDF5 shards and produces a plain PyTorch state_dict checkpoint.'],
  ['Adapt a pretrained model to another species', 'Transfer is an alternative to training from scratch and can freeze earlier residual units while adapting later layers.'],
  ['Calibrate checkpoint probabilities when needed', 'Calibration is optional post-hoc temperature scaling, not a required stage before prediction.'],
  ['Predict splice sites across long sequences', 'The predict path accepts FASTA, uses overlapping tiles, and emits separate donor and acceptor BED tracks.'],
  ['Score variants as a parallel downstream use', 'The variant path compares reference and alternate VCF alleles and writes delta scores and positions into VCF INFO.'],
] as const;
---

<section class="lvz osai osai-workflow" role="group" aria-label="Interactive: OpenSpliceAI model lifecycle" data-print-final-state="true">
  <div class="lvz-head"><p class="lvz-title">Move from a genome to reusable predictions</p><span class="lvz-tag">Six-command toolkit</span></div>
  <p class="lvz-caption" data-wgi-caption aria-live="polite">{steps[0][1]}</p>
  <nav class="lvz-progress" aria-label="Model lifecycle steps">{steps.map(([title], i) => <button type="button" class="lvz-jump" data-wgi-jump aria-label={`Step ${i + 1}: ${title}`} title={title}>{i + 1}</button>)}</nav>
  {steps.map(([title, caption], i) => (
    <div class="lvz-step" data-wgi-step data-print-final={i === steps.length - 1 ? 'true' : undefined} data-caption={caption} hidden={i !== 0}>
      <p class="lvz-steptitle"><span class="lvz-num">{i + 1}</span>{title}</p>
      <div class="lvz-fig lvz-visual--desktop" set:html={desktopFrame(i)} />
      <div class="lvz-fig lvz-visual--mobile" set:html={mobileFrame(i)} />
    </div>
  ))}
  <div class="lvz-controls"><button type="button" class="lvz-btn" data-wgi-prev aria-label="Previous step">← Prev</button><button type="button" class="lvz-btn" data-wgi-play aria-pressed="false" aria-label="Play animation"><span data-wgi-play-icon>▶</span> <span data-wgi-play-label>Play</span></button><button type="button" class="lvz-btn" data-wgi-next aria-label="Next step">Next →</button><button type="button" class="lvz-btn" data-wgi-reset aria-label="Restart from first step">↺ Restart</button><span class="lvz-pos" data-wgi-pos>1 / {steps.length}</span></div>
  <div class="lvz-legend"><span><span class="lvz-sw" style={`background:${C.data}`}></span>data</span><span><span class="lvz-sw" style={`background:${C.train}`}></span>training</span><span><span class="lvz-sw" style={`background:${C.cal}`}></span>calibration</span><span><span class="lvz-sw" style={`background:${C.predict}`}></span>genome prediction</span><span><span class="lvz-sw" style={`background:${C.variant}`}></span>variant scoring</span></div>
</section>

<script>
  import { mountStepper } from '../scripts/wgiStepper';
  function boot() {
    for (const root of document.querySelectorAll<HTMLElement>('.osai-workflow')) {
      const steps = Array.from(root.querySelectorAll<HTMLElement>('[data-wgi-step]'));
      const captions = steps.map((step) => step.dataset.caption || '');
      mountStepper(root, { total: steps.length, onShow: (i) => steps.forEach((step, k) => { const current = i === k; step.hidden = !current; step.setAttribute('aria-current', current ? 'step' : 'false'); }), caption: (i) => captions[i], interval: 6500 });
    }
  }
  boot();
  document.addEventListener('astro:page-load', boot);
</script>
