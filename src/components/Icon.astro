const isBrand = name in brand;
const inner = isBrand ? `<path d="${brand[name]}"/>` : stroke[name] ?? '';
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={isBrand ? 'currentColor' : 'none'}
  stroke={isBrand ? 'none' : 'currentColor'}
  stroke-width={isBrand ? undefined : 1.7}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  role={title ? 'img' : undefined}
  aria-hidden={title ? undefined : 'true'}
  aria-label={title}
  set:html={(title ? `<title>${title}</title>` : '') + inner}
/>
