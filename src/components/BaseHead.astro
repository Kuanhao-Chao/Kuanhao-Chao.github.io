---
import { site, socials, identity } from '../data/site';
import type { ScholarMeta } from '../lib/scholar';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article' | 'profile';
  // When true, emit `noindex, nofollow` so the page is hidden from all search
  // engines (used by the unlisted `reports` section). Defaults to indexable.
  noindex?: boolean;
  scholarMeta?: ScholarMeta;
}

const {
  title,
  description = site.description,
  image = '/og.jpg',
  type = 'website',
  noindex = false,
  scholarMeta,
} = Astro.props;

const pageTitle = title ? `${title} · ${site.name}` : `${site.name} · ${site.role}`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
// The default share card is a known 1200×630; only assert dimensions for it.
const isDefaultImage = image === '/og.jpg';

const personLd = {
  '@type': 'Person',
  '@id': `${site.url}/#person`,
  name: site.name,
  alternateName: [site.nameZh, 'kuanhao chao', 'khc'],
  jobTitle: identity.jobTitle,
  worksFor: {
    '@type': 'Organization',
    name: identity.worksFor.name,
    url: identity.worksFor.url,
  },
  alumniOf: identity.alumniOf.map((a) => ({
    '@type': 'CollegeOrUniversity',
    name: a.name,
    url: a.url,
  })),
  knowsAbout: identity.knowsAbout,
  email: `mailto:${site.email}`,
  url: site.url,
  image: `${site.url}/headshot.jpg`,
  description: site.description,
  sameAs: socials.filter((s) => !['email', 'calendly'].includes(s.key)).map((s) => s.href),
};

const websiteLd = {
  '@type': 'WebSite',
  '@id': `${site.url}/#website`,
  name: site.name,
  url: site.url,
  inLanguage: 'en',
  publisher: { '@id': `${site.url}/#person` },
};

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [personLd, websiteLd],
};
---
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
{/*
  Browser-enforced security policy. GitHub Pages cannot send HTTP response headers, so
  these <meta> equivalents deliver what is possible: a referrer policy and a site-wide CSP.
  Header-only protections — frame-ancestors / X-Frame-Options (clickjacking),
  X-Content-Type-Options (nosniff), HSTS, and Permissions-Policy — cannot be set from a
  static host and are documented as an accepted limitation in scripts/audit-security.mjs.
  The CSP keeps 'unsafe-inline' on script/style because the pre-paint theme scripts,
  ClientRouter's injected bootstrap, and Astro/KaTeX inline styles require it; it is
  therefore defense-in-depth against external-resource injection (blocks foreign scripts,
  images, iframes, form posts, <base> hijack, plugin objects), not a full XSS mitigation.
  Gated to production so it never interferes with the dev server's HMR websocket.
*/}
<meta name="referrer" content="strict-origin-when-cross-origin" />
{import.meta.env.PROD && (
  <meta
    http-equiv="Content-Security-Policy"
    content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; frame-src https://storage.googleapis.com; connect-src 'self'; base-uri 'self'; form-action 'self'; object-src 'none'"
  />
)}
<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta name="author" content={site.name} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<meta name="generator" content={Astro.generator} />

<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
<link rel="icon" href="/favicon-16.png" type="image/png" sizes="16x16" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${site.name} — News`}
  href={new URL('rss.xml', Astro.site).href}
/>
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${site.name} — Posts`}
  href={new URL('posts/rss.xml', Astro.site).href}
/>

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
{isDefaultImage && <meta property="og:image:width" content="1200" />}
{isDefaultImage && <meta property="og:image:height" content="630" />}
<meta property="og:image:alt" content={`${site.name} — ${site.role}`} />
<meta property="og:site_name" content={site.name} />
<meta property="og:locale" content="en_US" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={identity.twitter} />
<meta name="twitter:creator" content={identity.twitter} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<meta name="color-scheme" content="light dark" />
<meta name="theme-color" content="#fafaf8" data-theme-color />

{
  scholarMeta && (
    <>
      <meta name="citation_title" content={scholarMeta.title} />
      {scholarMeta.authors.map((author) => (
        <meta name="citation_author" content={author} />
      ))}
      <meta name="citation_publication_date" content={scholarMeta.publicationDate} />
      {scholarMeta.pdfUrl && <meta name="citation_pdf_url" content={scholarMeta.pdfUrl} />}
      {scholarMeta.technicalReportInstitution && (
        <meta
          name="citation_technical_report_institution"
          content={scholarMeta.technicalReportInstitution}
        />
      )}
      {scholarMeta.technicalReportNumber && (
        <meta
          name="citation_technical_report_number"
          content={scholarMeta.technicalReportNumber}
        />
      )}
      {scholarMeta.references?.map((ref) => (
        <meta name="citation_reference" content={ref} />
      ))}
    </>
  )
}

<script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
