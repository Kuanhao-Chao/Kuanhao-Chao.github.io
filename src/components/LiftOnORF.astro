---
/** Published LiftOn method: search alternative ORFs after CDS chaining. */
import '../styles/lvz.css';

interface Props { autoPlay?: boolean }
const { autoPlay = false } = Astro.props;

const C = { current: '#4c78a8', candidate: '#f58518', chosen: '#54a24b', ref: '#2e6e5e', bad: '#d1495b', utr: '#a8b2b0' };

type Scenario = {
  id: string;
  label: string;
  trigger: string;
  outcome: string;
  currentStart: number;
  currentStop: number;
  selectedStart: number;
  selectedStop: number;
  mutation: number;
  mutationLabel: string;
  selectedFrame: number;
};

const scenarios: Scenario[] = [
  { id: 'frameshift', label: 'Frameshift', trigger: 'an indel introduces a premature stop', outcome: 'move the CDS stop before the disrupted translation', currentStart: 190, currentStop: 680, selectedStart: 190, selectedStop: 505, mutation: 492, mutationLabel: '+1 indel', selectedFrame: 1 },
  { id: 'stop-gain-early', label: 'Stop gain · earlier stop', trigger: 'a point mutation creates an early stop', outcome: 'use the first valid stop codon', currentStart: 190, currentStop: 680, selectedStart: 190, selectedStop: 505, mutation: 492, mutationLabel: 'early *', selectedFrame: 0 },
  { id: 'stop-gain-start', label: 'Stop gain · downstream start', trigger: 'an early stop disrupts the original translation', outcome: 'switch to a downstream start codon', currentStart: 190, currentStop: 680, selectedStart: 345, selectedStop: 680, mutation: 248, mutationLabel: 'early *', selectedFrame: 1 },
  { id: 'stop-loss', label: 'Stop loss · 3′ extension', trigger: 'the annotated stop codon is lost', outcome: 'extend into the 3′ UTR to a new stop', currentStart: 190, currentStop: 635, selectedStart: 190, selectedStop: 702, mutation: 635, mutationLabel: 'lost *', selectedFrame: 0 },
  { id: 'start-loss-down', label: 'Start loss · downstream start', trigger: 'the annotated start codon is lost', outcome: 'use a downstream start in the coding region', currentStart: 190, currentStop: 680, selectedStart: 345, selectedStop: 680, mutation: 190, mutationLabel: 'lost M', selectedFrame: 1 },
  { id: 'start-loss-up', label: 'Start loss · upstream start', trigger: 'the annotated start codon is lost', outcome: 'extend into the 5′ UTR to an upstream start', currentStart: 345, currentStop: 680, selectedStart: 180, selectedStop: 680, mutation: 345, mutationLabel: 'lost M', selectedFrame: 0 },
];

const exons: [number, number][] = [[170, 105], [330, 52], [430, 105], [620, 95]];

function transcript(y: number, start: number, stop: number, color: string, label: string, mutation?: { x: number; text: string }) {
  let s = `<text x="18" y="${y + 5}" class="lvz-tl">${label}</text><line x1="165" y1="${y}" x2="725" y2="${y}" stroke="var(--color-muted)" opacity="0.7"/>`;
  exons.forEach(([x, w]) => {
    s += `<rect x="${x}" y="${y - 11}" width="${w}" height="22" rx="2" fill="${C.utr}" fill-opacity="0.24" stroke="${C.utr}"/>`;
    const a = Math.max(x, start), b = Math.min(x + w, stop);
    if (b > a) s += `<rect x="${a}" y="${y - 11}" width="${b - a}" height="22" rx="2" fill="${color}" fill-opacity="0.8" stroke="${color}"/>`;
  });
  s += `<text x="${start + 7}" y="${y + 4}" class="lvz-in" fill="var(--color-ink)">M</text><text x="${stop - 7}" y="${y + 4}" class="lvz-in" fill="var(--color-ink)">*</text>`;
  if (mutation) {
    s += `<path d="M${mutation.x - 8} ${y - 17} l16 16 M${mutation.x + 8} ${y - 17} l-16 16" stroke="${C.bad}" stroke-width="2.5"/><text x="${mutation.x}" y="${y - 24}" class="lvz-small" fill="${C.bad}">${mutation.text}</text>`;
  }
  return s;
}

function candidates(scenario: Scenario, step: number) {
  const ranges: [number, number][] = [[205, 520], [270, 650], [360, 595]];
  let s = '';
  ranges.forEach(([start, stop], frame) => {
    const y = 112 + frame * 62;
    const selected = frame === scenario.selectedFrame;
    s += `<text x="78" y="${y + 5}" class="lvz-tl">Frame ${frame}</text>`;
    s += `<rect x="${start}" y="${y - 13}" width="${stop - start}" height="26" rx="4" fill="${selected && step >= 2 ? C.chosen : C.candidate}" fill-opacity="${selected && step >= 2 ? 0.22 : 0.12}" stroke="${selected && step >= 2 ? C.chosen : C.candidate}" stroke-width="${selected && step >= 2 ? 2.5 : 1.2}"/>`;
    s += `<text x="${start + 12}" y="${y + 5}" class="lvz-in">M</text><text x="${stop - 12}" y="${y + 5}" class="lvz-in">*</text>`;
    if (step === 1) {
      s += `<rect x="${start + 42}" y="${y - 8}" width="65" height="16" rx="3" fill="${C.candidate}" fill-opacity="0.08" stroke="${C.candidate}" stroke-dasharray="3 2"/><path d="M${start + 70} ${y - 10} l14 20 M${start + 84} ${y - 10} l-14 20" stroke="${C.bad}"/>`;
    }
    if (step >= 3) s += `<text x="690" y="${y + 5}" class="lvz-small" fill="${selected ? C.chosen : 'var(--color-muted)'}">${selected ? 'highest id(o)' : `id(o${frame})`}</text>`;
  });
  return s;
}

function desktopFrame(scenario: Scenario, step: number) {
  let s = '';
  if (step === 0) {
    s += transcript(80, scenario.currentStart, scenario.currentStop, C.current, 'Current chained CDS', { x: scenario.mutation, text: scenario.mutationLabel });
    s += `<text x="445" y="142" class="lvz-nt" fill="${C.bad}">${scenario.trigger}</text>`;
    s += `<rect x="165" y="182" width="560" height="70" rx="6" fill="${C.bad}" fill-opacity="0.04" stroke="${C.bad}" stroke-dasharray="5 3"/><text x="445" y="212" class="lvz-nt on">ORF rescue is triggered</text><text x="445" y="236" class="lvz-small">the genomic sequence remains unchanged</text>`;
  } else if (step <= 3) {
    s += `<text x="18" y="35" class="lvz-tl" fill="${C.ref}">${step === 1 ? 'Candidate starts and stops in all three frames' : step === 2 ? 'Longest valid ORF retained per frame' : 'Candidate identity against the reference protein'}</text>`;
    s += candidates(scenario, step);
    if (step === 3) s += `<text x="390" y="302" class="lvz-nt on" fill="${C.chosen}">o* = arg max id(o, reference protein)</text>`;
  } else {
    s += transcript(78, scenario.currentStart, scenario.currentStop, C.current, 'Before ORF rescue', { x: scenario.mutation, text: scenario.mutationLabel });
    s += `<path d="M445 112 V150" stroke="${C.chosen}" stroke-width="2"/><path d="M439 143 l6 8 6-8" fill="none" stroke="${C.chosen}" stroke-width="2"/>`;
    s += transcript(188, scenario.selectedStart, scenario.selectedStop, C.chosen, 'After ORF rescue');
    s += `<text x="445" y="248" class="lvz-nt on" fill="${C.chosen}">${scenario.outcome}</text>`;
    s += `<text x="445" y="282" class="lvz-small">adopt only if id(o*) &gt; id(current); then map boundaries back through exon coordinates</text>`;
  }
  return `<svg viewBox="0 0 760 320" class="lvz-svg" role="img" aria-label="${scenario.label}, ORF search step ${step + 1}" preserveAspectRatio="xMidYMid meet">${s}</svg>`;
}

function mobileFrame(scenario: Scenario, step: number) {
  let s = '';
  if (step === 0 || step === 4) {
    const beforeStart = Math.round((scenario.currentStart - 160) * 0.55 + 20);
    const beforeStop = Math.round((scenario.currentStop - 160) * 0.55 + 20);
    const afterStart = Math.round((scenario.selectedStart - 160) * 0.55 + 20);
    const afterStop = Math.round((scenario.selectedStop - 160) * 0.55 + 20);
    const lane = (y: number, start: number, stop: number, color: string, label: string) => `<text x="12" y="${y}" class="lvz-tl">${label}</text><rect x="18" y="${y + 22}" width="324" height="30" rx="4" fill="${C.utr}" fill-opacity="0.2" stroke="${C.utr}"/><rect x="${start}" y="${y + 22}" width="${Math.max(18, stop - start)}" height="30" rx="4" fill="${color}" fill-opacity="0.78"/><text x="${start + 10}" y="${y + 42}" class="lvz-in">M</text><text x="${stop - 9}" y="${y + 42}" class="lvz-in">*</text>`;
    s += lane(40, beforeStart, beforeStop, C.current, step === 0 ? 'Current chained CDS' : 'Before ORF rescue');
    if (step === 0) s += `<text x="180" y="145" class="lvz-nt" fill="${C.bad}">${scenario.trigger}</text><rect x="18" y="180" width="324" height="74" rx="6" fill="${C.bad}" fill-opacity="0.04" stroke="${C.bad}" stroke-dasharray="4 3"/><text x="180" y="212" class="lvz-nt on">ORF rescue is triggered</text><text x="180" y="235" class="lvz-small">annotation changes; genome sequence does not</text>`;
    else s += `<path d="M180 120 V165" stroke="${C.chosen}" stroke-width="2"/><path d="M174 158 l6 8 6-8" fill="none" stroke="${C.chosen}" stroke-width="2"/>${lane(195, afterStart, afterStop, C.chosen, 'After ORF rescue')}<text x="180" y="300" class="lvz-nt on" fill="${C.chosen}">${scenario.outcome}</text><text x="180" y="335" class="lvz-small">adopt only when id(o*) &gt; id(current)</text>`;
  } else {
    const selected = scenario.selectedFrame;
    [0, 1, 2].forEach((frame) => {
      const y = 28 + frame * 96;
      const chosen = frame === selected && step >= 2;
      s += `<rect x="12" y="${y}" width="336" height="78" rx="5" fill="var(--color-bg)" stroke="${chosen ? C.chosen : 'var(--color-rule)'}" stroke-width="${chosen ? 2 : 1}"/><text x="30" y="${y + 25}" class="lvz-tl">Frame ${frame}</text><rect x="105" y="${y + 18}" width="${150 + frame * 28}" height="24" rx="3" fill="${chosen ? C.chosen : C.candidate}" fill-opacity="0.2" stroke="${chosen ? C.chosen : C.candidate}"/><text x="118" y="${y + 35}" class="lvz-in">M</text><text x="${242 + frame * 28}" y="${y + 35}" class="lvz-in">*</text>`;
      if (step === 1) s += `<text x="180" y="${y + 64}" class="lvz-small">retain this frame's longest valid ORF</text>`;
      if (step === 2 && chosen) s += `<text x="180" y="${y + 64}" class="lvz-small" fill="${C.chosen}">candidate o*</text>`;
      if (step === 3) s += `<text x="180" y="${y + 64}" class="lvz-small" fill="${chosen ? C.chosen : 'var(--color-muted)'}">${chosen ? 'highest identity' : `id(o${frame})`}</text>`;
    });
    if (step === 3) s += `<text x="180" y="340" class="lvz-nt on" fill="${C.chosen}">o* = highest-identity candidate</text>`;
  }
  return `<svg viewBox="0 0 360 370" class="lvz-svg" role="img" aria-label="${scenario.label}, ORF search step ${step + 1}" preserveAspectRatio="xMidYMid meet">${s}</svg>`;
}

const stepText = [
  ['Detect a damaging coding pattern', 'Frameshift, stop-gain, stop-loss, or start-loss patterns trigger a search for better-supported CDS boundaries.'],
  ['Scan all three reading frames', 'LiftOn searches frames 0, 1, and 2 for start codons and their corresponding stops.'],
  ['Retain the longest valid ORF from each frame', 'At most one candidate per frame proceeds: the longest valid open reading frame found there.'],
  ['Compare every candidate with the reference protein', 'After translation and alignment, the candidate with the highest reference-protein identity becomes o*.'],
  ['Adopt the candidate only when identity improves', 'LiftOn updates strand-aware CDS coordinates only when id(o*) exceeds the current model’s identity.'],
] as const;
---

<section
  class="lvz lvz-orf"
  role="group"
  aria-label="Interactive: LiftOn open reading frame search"
  data-autoplay={autoPlay ? 'true' : undefined}
  data-print-final-state="true"
>
  <div class="lvz-head">
    <p class="lvz-title">Repair the open reading frame</p>
    <label class="lvz-scenario">
      <span>Figure 1 outcome</span>
      <select data-orf-select>
        {scenarios.map((scenario) => <option value={scenario.id}>{scenario.label}</option>)}
      </select>
    </label>
  </div>
  <p class="lvz-caption" data-wgi-caption aria-live="polite">{stepText[0][1]}</p>

  <nav class="lvz-progress" aria-label="Open reading frame search steps">
    {stepText.map(([title], i) => (
      <button type="button" class="lvz-jump" data-wgi-jump aria-label={`Step ${i + 1}: ${title}`} title={title}>{i + 1}</button>
    ))}
  </nav>

  {scenarios.map((scenario, scenarioIndex) => (
    <div data-orf-scenario={scenario.id} hidden={scenarioIndex !== 0}>
      <p class="lvz-print-scenario">{scenario.label}</p>
      {stepText.map(([title, caption], i) => (
        <div class="lvz-step" data-wgi-step data-print-final={i === stepText.length - 1 ? 'true' : undefined} data-caption={caption} hidden={i !== 0}>
          <p class="lvz-steptitle"><span class="lvz-num">{i + 1}</span>{title}</p>
          <div class="lvz-fig lvz-visual--desktop" set:html={desktopFrame(scenario, i)} />
          <div class="lvz-fig lvz-visual--mobile" set:html={mobileFrame(scenario, i)} />
        </div>
      ))}
    </div>
  ))}

  <div class="lvz-controls">
    <button type="button" class="lvz-btn" data-wgi-prev aria-label="Previous step">← Prev</button>
    <button type="button" class="lvz-btn" data-wgi-play aria-pressed="false" aria-label="Play animation"><span data-wgi-play-icon>▶</span> <span data-wgi-play-label>Play</span></button>
    <button type="button" class="lvz-btn" data-wgi-next aria-label="Next step">Next →</button>
    <button type="button" class="lvz-btn" data-wgi-reset aria-label="Restart from first step">↺ Restart</button>
    <span class="lvz-pos" data-wgi-pos>1 / {stepText.length}</span>
  </div>

  <div class="lvz-legend">
    <span><span class="lvz-sw" style={`background:${C.current}`}></span>current CDS</span>
    <span><span class="lvz-sw" style={`background:${C.candidate}`}></span>candidate ORF</span>
    <span><span class="lvz-sw" style={`background:${C.chosen}`}></span>LiftOn output</span>
    <span><span class="lvz-sw" style={`background:${C.utr}`}></span>UTR</span>
    <span><span class="lvz-sw" style={`background:${C.bad}`}></span>damaging change</span>
  </div>
</section>

<style>
  .lvz-orf { --lvz-mobile-min-width: 0px; }
  .lvz-scenario { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--color-muted); font-size: var(--fs-meta); }
  .lvz-scenario select { min-width: 13rem; border: 1px solid var(--color-rule); border-radius: var(--radius); background: var(--color-bg); color: var(--color-ink); padding: 0.35rem 1.8rem 0.35rem 0.55rem; font: inherit; }
  .lvz-print-scenario { display: none; }
  @media (max-width: 560px) {
    .lvz-orf .lvz-head { align-items: stretch; }
    .lvz-scenario { align-items: stretch; flex-direction: column; gap: 0.25rem; }
    .lvz-scenario select { min-width: 0; width: 100%; }
  }
</style>

<script>
  import { mountStepper } from '../scripts/wgiStepper';
  function boot() {
    for (const root of document.querySelectorAll<HTMLElement>('.lvz-orf')) {
      if (root.dataset.orfReady === 'true') continue;
      root.dataset.orfReady = 'true';
      const groups = Array.from(root.querySelectorAll<HTMLElement>('[data-orf-scenario]'));
      const select = root.querySelector<HTMLSelectElement>('[data-orf-select]');
      let active = select?.value || groups[0]?.dataset.orfScenario || '';
      let current = 0;
      const activeSteps = () => Array.from(groups.find((item) => item.dataset.orfScenario === active)?.querySelectorAll<HTMLElement>('[data-wgi-step]') || []);
      const show = (i: number) => {
        current = i;
        groups.forEach((group) => {
          const on = group.dataset.orfScenario === active;
          group.hidden = !on;
          Array.from(group.querySelectorAll<HTMLElement>('[data-wgi-step]')).forEach((step, k) => {
            const selected = on && k === i;
            step.hidden = !selected;
            step.setAttribute('aria-current', selected ? 'step' : 'false');
          });
        });
      };
      const api = mountStepper(root, { total: activeSteps().length, onShow: show, caption: (i) => activeSteps()[i]?.dataset.caption || '', interval: 6500, autoPlay: root.dataset.autoplay === 'true' });
      select?.addEventListener('change', () => { api?.stop(); active = select.value; api?.show(current); });
    }
  }
  boot();
  document.addEventListener('astro:page-load', boot);
</script>
