---
import '../styles/shorkie.css';

const chapters = [
  {
    title: 'Find the useful evolutionary neighborhood',
    body: 'Four alternative corpora test a central hypothesis: useful context should be broad enough to reveal conserved grammar, but close enough to remain relevant to budding yeast.',
    marker: 'Evolution',
  },
  {
    title: 'Turn fungal genomes into a reconstruction task',
    body: 'Repeat-masked chromosomes become overlapping 16,384 bp windows. Shorkie hides 15% of their bases and learns to recover them from sequence and species context.',
    marker: 'Pretrain',
  },
  {
    title: 'Carry the learned sequence features into yeast',
    body: 'The pretrained encoder and Transformer become the starting point for a supervised model rather than being relearned from the much smaller yeast genome alone.',
    marker: 'Transfer',
  },
  {
    title: 'Predict regulation and inspect the learned grammar',
    body: 'RNA, binding, and chromatin assays train a shared output model. Its coverage profiles support expression prediction, motif discovery, and variant-effect scoring.',
    marker: 'Interpret',
  },
] as const;
---

<section class="shk-story shk-overview" data-shorkie-scrolly data-stage="0" aria-label="Shorkie workflow from fungal genomes to regulatory predictions">
  <header class="shk-story-head">
    <h3 class="shk-story-title">How Shorkie transfers regulatory context from fungi to yeast</h3>
    <button class="shk-replay" type="button" data-shorkie-replay aria-label="Replay the current transition" title="Replay transition">↻</button>
  </header>
  <div class="shk-story-grid">
    <div class="shk-stage-figure">
      <div class="shk-canvas">
        <svg viewBox="0 0 760 460" role="img" aria-label="Editorial overview of Shorkie pretraining, transfer, and interpretation">
          <g class="shk-layer is-visible" data-stage-only="0">
            <text x="380" y="40" class="shk-note">ALTERNATIVE SOURCES OF EVOLUTIONARY CONTEXT</text>
            <circle cx="105" cy="228" r="44" fill="#2f8069" fill-opacity=".1" stroke="#2f8069" stroke-width="3"/>
            <path d="M91 217 q14-24 28 0 q-14 23-28 0 M105 230 v26" fill="none" stroke="#2f8069" stroke-width="3"/>
            <text x="105" y="292" class="shk-label">S. cerevisiae</text>
            <path d="M150 228 C205 228 216 86 285 86 M150 228 C205 228 216 182 285 182 M150 228 C205 228 216 278 285 278 M150 228 C205 228 216 374 285 374" fill="none" stroke="var(--color-rule)" stroke-width="2"/>
            <g opacity=".48">
              <circle cx="315" cy="86" r="12" fill="#3976a8"/>
              <text x="358" y="82" class="shk-label shk-left">R64</text><text x="358" y="104" class="shk-note shk-left">1 genome · ~12 Mb</text>
            </g>
            <g opacity=".48">
              {Array.from({ length: 8 }, (_, i) => <circle cx={310 + (i % 4) * 18} cy={168 + Math.floor(i / 4) * 28} r="6" fill="#b07d00" />)}
              <text x="410" y="178" class="shk-label shk-left">80 strains</text><text x="410" y="200" class="shk-note shk-left">~1 Gb</text>
            </g>
            <g>
              <ellipse cx="354" cy="278" rx="82" ry="48" fill="#2f8069" fill-opacity=".08" stroke="#2f8069" stroke-width="3"/>
              {Array.from({ length: 18 }, (_, i) => {
                const angle = i * Math.PI * 2 / 18;
                return <circle cx={354 + Math.cos(angle) * (42 + i % 3 * 10)} cy={278 + Math.sin(angle) * 29} r="5" fill="#2f8069" opacity={0.65 + i % 3 * 0.12} />;
              })}
              <text x="485" y="270" class="shk-label shk-left">165 Saccharomycetales</text><text x="485" y="294" class="shk-note shk-left">best transfer to held-out yeast</text>
            </g>
            <g opacity=".35">
              {Array.from({ length: 28 }, (_, i) => {
                const angle = i * Math.PI * 2 / 28;
                return <circle cx={354 + Math.cos(angle) * (48 + i % 4 * 12)} cy={374 + Math.sin(angle) * 38} r="4.5" fill="#6f62a8" />;
              })}
              <text x="485" y="366" class="shk-label shk-left">1,341 fungi</text><text x="485" y="390" class="shk-note shk-left">largest, but more heterogeneous</text>
            </g>
          </g>

          <g class="shk-layer" data-stage-only="1">
            <text x="380" y="40" class="shk-note">GENOME WINDOWS BECOME MASKED-LANGUAGE-MODEL EXAMPLES</text>
            <line x1="65" y1="125" x2="695" y2="125" stroke="#3976a8" stroke-width="24" stroke-linecap="round"/>
            <rect x="105" y="108" width="74" height="34" fill="#2f8069"/><rect x="265" y="108" width="90" height="34" fill="#2f8069"/><rect x="478" y="108" width="105" height="34" fill="#2f8069"/>
            <rect x="205" y="108" width="28" height="34" fill="#8a9491"/><rect x="402" y="108" width="34" height="34" fill="#8a9491"/>
            <text x="142" y="132" class="shk-note" style="fill:#fff">coding</text><text x="310" y="132" class="shk-note" style="fill:#fff">coding</text><text x="530" y="132" class="shk-note" style="fill:#fff">coding</text>
            <g data-beat="1">
              <rect x="80" y="190" width="330" height="42" rx="4" fill="#3976a8" fill-opacity=".08" stroke="#3976a8" stroke-width="2"/>
              <rect x="165" y="250" width="330" height="42" rx="4" fill="#3976a8" fill-opacity=".08" stroke="#3976a8" stroke-width="2"/>
              <rect x="250" y="310" width="330" height="42" rx="4" fill="#3976a8" fill-opacity=".08" stroke="#3976a8" stroke-width="2"/>
              <text x="245" y="216" class="shk-note">16,384 bp</text><text x="330" y="276" class="shk-note">stride 4,096 bp</text>
            </g>
            <g data-beat="2">
              <text x="380" y="395" class="shk-dna">A C <tspan style="fill:#b04755">?</tspan> G T A C <tspan style="fill:#b04755">?</tspan> T G A <tspan style="fill:#b04755">?</tspan> C T</text>
              <text x="380" y="430" class="shk-note">15% selected · 80% mask · 10% random · 10% unchanged</text>
            </g>
          </g>

          <g class="shk-layer" data-stage-only="2">
            <text x="380" y="38" class="shk-note">PRETRAINED SEQUENCE FEATURES BECOME THE SUPERVISED STARTING POINT</text>
            <text x="92" y="102" class="shk-dna">A C ? G T A C T</text>
            <path d="M155 115 C205 142 210 166 245 182" fill="none" stroke="#3976a8" stroke-width="3" marker-end="url(#shk-arrow)"/>
            <g data-beat="1">
              {Array.from({ length: 6 }, (_, i) => <rect x={225 + i * 34} y={145 + i * 28} width={130 - i * 12} height="23" rx="3" fill="#2f8069" fill-opacity={0.1 + i * 0.035} stroke="#2f8069" />)}
              <rect x="382" y="298" width="122" height="68" rx="5" fill="#6f62a8" fill-opacity=".12" stroke="#6f62a8" stroke-width="3"/>
              <text x="443" y="326" class="shk-label">Transformer × 8</text><text x="443" y="349" class="shk-note">128 × 384 · 4 heads</text>
              {Array.from({ length: 5 }, (_, i) => <rect x={523 + i * 34} y={285 - i * 28} width={70 + i * 12} height="23" rx="3" fill="#b26b32" fill-opacity={0.22 - i * 0.02} stroke="#b26b32" />)}
              <path d="M274 145 C340 76 568 76 630 145" fill="none" stroke="#b07d00" stroke-width="3"/>
            </g>
            <g data-beat="2">
              <path d="M520 392 H650" stroke="#2f8069" stroke-width="5" marker-end="url(#shk-arrow-green)"/>
              <text x="585" y="420" class="shk-label" style="fill:#2f8069">transfer learned weights</text>
            </g>
            <defs>
              <marker id="shk-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M0 0 L10 5 L0 10z" fill="#3976a8"/></marker>
              <marker id="shk-arrow-green" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M0 0 L10 5 L0 10z" fill="#2f8069"/></marker>
            </defs>
          </g>

          <g class="shk-layer" data-stage-only="3" data-print-final>
            <text x="380" y="38" class="shk-note">5,215 YEAST ASSAYS → REGULATORY COVERAGE → INTERPRETATION</text>
            <g data-beat="1">
              <path d="M55 95 H230" stroke="#3976a8" stroke-width="12"/><text x="55" y="78" class="shk-note shk-left">3,053 induction RNA-seq</text>
              <path d="M55 150 H230" stroke="#2f8069" stroke-width="12"/><text x="55" y="133" class="shk-note shk-left">1,014 strain RNA-seq</text>
              <path d="M55 205 H230" stroke="#6f62a8" stroke-width="12"/><text x="55" y="188" class="shk-note shk-left">1,128 ChIP-exo</text>
              <path d="M55 260 H230" stroke="#b26b32" stroke-width="12"/><text x="55" y="243" class="shk-note shk-left">20 histone tracks</text>
              <path d="M230 95 C290 95 280 180 330 180 M230 150 C290 150 280 180 330 180 M230 205 C290 205 280 180 330 180 M230 260 C290 260 280 180 330 180" fill="none" stroke="var(--color-rule)" stroke-width="2"/>
            </g>
            <g data-beat="2">
              <path d="M330 130 h105 l35 50-35 50H330z" fill="#2f8069" fill-opacity=".1" stroke="#2f8069" stroke-width="3"/>
              <text x="390" y="174" class="shk-label">fine-tuned</text><text x="390" y="198" class="shk-label">Shorkie</text>
              <path d="M470 180 H540" stroke="#2f8069" stroke-width="3" marker-end="url(#shk-arrow-green)"/>
            </g>
            <g data-beat="3">
              <polygon points="535,300 535,270 555,250 575,210 595,230 615,280 635,255 655,175 675,205 695,270 715,300" fill="#3976a8" opacity=".68"/>
              <line x1="535" y1="300" x2="715" y2="300" class="shk-rule"/>
              <rect x="548" y="324" width="58" height="18" fill="#182c67"/><line x1="606" y1="333" x2="638" y2="333" stroke="#182c67"/><rect x="638" y="324" width="65" height="18" fill="#182c67"/>
              <text x="625" y="370" class="shk-note">coverage over target-gene exons</text>
              <path d="M535 105 q14-45 28 0 q14-32 28 0 M620 105 q12-60 24 0 q12-38 24 0" fill="none" stroke="#b04755" stroke-width="5"/>
              <text x="603" y="72" class="shk-note">motifs and variant effects</text>
            </g>
          </g>
        </svg>
      </div>
      <div class="shk-markers" aria-hidden="true">{chapters.map((chapter, index) => <span class:list={['shk-marker', { 'is-active': index === 0 }]} data-shorkie-marker>{chapter.marker}</span>)}</div>
    </div>
    <ol class="shk-chapters">
      {chapters.map((chapter, index) => (
        <li class:list={['shk-chapter', { 'is-active': index === 0 }]} data-shorkie-stage tabindex="0">
          <span class="shk-chapter-index">{String(index + 1).padStart(2, '0')}</span>
          <h3>{chapter.title}</h3>
          <p>{chapter.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<script>
  import { mountShorkieScrolly } from '../scripts/shorkieScrolly';
  function boot() { document.querySelectorAll<HTMLElement>('.shk-overview').forEach(mountShorkieScrolly); }
  boot(); document.addEventListener('astro:page-load', boot);
</script>
