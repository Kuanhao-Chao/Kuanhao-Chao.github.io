---
/** Published OpenSpliceAI/SpliceAI residual dilated-CNN architecture. */
import '../styles/lvz.css';
import '../styles/osai.css';

type Context = { id: string; cl: number; units: number; groups: number; input: number; windows: string; dilations: string };
const contexts: Context[] = [
  { id: '10000', cl: 10000, units: 16, groups: 4, input: 15000, windows: '11 × 8, 21 × 4, 41 × 4', dilations: '1 × 4, 4 × 4, 10 × 4, 25 × 4' },
  { id: '2000', cl: 2000, units: 12, groups: 3, input: 7000, windows: '11 × 8, 21 × 4', dilations: '1 × 4, 4 × 4, 10 × 4' },
  { id: '400', cl: 400, units: 8, groups: 2, input: 5400, windows: '11 × 8', dilations: '1 × 4, 4 × 4' },
  { id: '80', cl: 80, units: 4, groups: 1, input: 5080, windows: '11 × 4', dilations: '1 × 4' },
];

const C = { input: '#4c78a8', model: '#2e6e5e', residual: '#54a24b', skip: '#b07d00', acceptor: '#7a6fbe', donor: '#158f83', neither: '#8a9491' };
const fmt = (n: number) => n.toLocaleString('en-US');

const groupSchedule = [
  { w: 11, ar: 1 },
  { w: 11, ar: 4 },
  { w: 21, ar: 10 },
  { w: 41, ar: 25 },
] as const;

function block(x: number, y: number, w: number, h: number, color: string, title: string, detail: string, focused: boolean, enabled = true) {
  const opacity = enabled ? (focused ? 1 : 0.48) : 0.14;
  return `<g opacity="${opacity}"><rect x="${x}" y="${y}" width="${w}" height="${h}" rx="5" fill="${color}" fill-opacity="${focused ? 0.16 : 0.05}" stroke="${color}" stroke-width="${focused ? 2.8 : 1.2}" ${enabled ? '' : 'stroke-dasharray="4 4"'}/><text x="${x + w / 2}" y="${y + h / 2 - 7}" class="lvz-nt on" fill="${color}">${title}</text><text x="${x + w / 2}" y="${y + h / 2 + 15}" class="lvz-small">${detail}</text></g>`;
}

function connector(x1: number, y1: number, x2: number, y2: number) {
  return `<path d="M${x1} ${y1} L${x2 - 8} ${y2}" stroke="var(--color-muted)" stroke-width="1.6" opacity="0.48"/><path d="M${x2 - 14} ${y2 - 5} l7 5-7 5" fill="none" stroke="var(--color-muted)" stroke-width="1.6" opacity="0.48"/>`;
}

function desktopDetail(ctx: Context, step: number) {
  if (step === 0) return `<text x="450" y="291" class="lvz-nt on" fill="${C.input}">stored X: 4 × 15,000 · selected model input: 4 × ${fmt(ctx.input)}</text><text x="450" y="318" class="lvz-small">5,000 central positions + ${fmt(ctx.cl / 2)} nt of context on each side</text>`;
  if (step === 1) return `<text x="450" y="291" class="lvz-nt on" fill="${C.model}">Conv1d stem · 4 input channels → 32 learned feature channels</text><text x="450" y="318" class="lvz-small">symmetric padding preserves the context-specific sequence length</text>`;
  if (step === 2) {
    const labels = ['BN', 'LeakyReLU', 'Conv1d', 'BN', 'LeakyReLU', 'Conv1d'];
    let s = `<text x="75" y="274" class="lvz-tl" fill="${C.residual}">One ResidualUnit</text><path d="M155 326 V286 H745 V326" fill="none" stroke="${C.input}" stroke-width="1.5"/><text x="450" y="280" class="lvz-small" fill="${C.input}">identity path</text>`;
    labels.forEach((label, i) => { const x = 160 + i * 96; s += `<rect x="${x}" y="302" width="78" height="42" rx="4" fill="${i === 1 || i === 4 ? C.skip : i === 2 || i === 5 ? C.residual : C.model}" fill-opacity="0.1" stroke="${i === 1 || i === 4 ? C.skip : i === 2 || i === 5 ? C.residual : C.model}"/><text x="${x + 39}" y="327" class="lvz-small">${label}</text>`; if (i < labels.length - 1) s += connector(x + 78, 323, x + 96, 323); });
    return s;
  }
  if (step === 3) return `<text x="450" y="286" class="lvz-nt on" fill="${C.residual}">${ctx.units} residual units in ${ctx.groups} active ${ctx.groups === 1 ? 'group' : 'groups'} · CL = 2 Σ AR(W−1) = ${fmt(ctx.cl)} nt</text><text x="450" y="314" class="lvz-small">W: ${ctx.windows} · AR: ${ctx.dilations}</text>`;
  if (step === 4) return `<text x="450" y="286" class="lvz-nt on" fill="${C.skip}">1×1 taps sum stem and residual-group features before Cropping1D</text><text x="450" y="314" class="lvz-small">trim ${fmt(ctx.cl / 2)} positions from each edge → 5,000 central positions</text>`;
  return `<text x="450" y="286" class="lvz-nt on" fill="${C.model}">1×1 Conv1d + softmax · N × 32 × 5,000 → N × 3 × 5,000</text><text x="450" y="314" class="lvz-small">probability at every central position: neither · acceptor · donor</text>`;
}

function desktopFrame(ctx: Context, step: number) {
  const inputFocus = step === 0;
  const stemFocus = step === 1;
  const residualFocus = step === 2 || step === 3;
  const skipFocus = step === 4;
  const outputFocus = step === 5;
  let s = `<text x="20" y="25" class="lvz-tl">Complete SpliceAI residual dilated 1-D CNN</text>`;
  s += block(15, 100, 110, 112, C.input, 'one-hot DNA', `4 × ${fmt(ctx.input)}`, inputFocus);
  s += connector(125, 156, 150, 156) + block(150, 112, 82, 88, C.model, 'Conv1d', 'stem · L=32', stemFocus);
  groupSchedule.forEach(({ w, ar }, i) => {
    const x = 255 + i * 105;
    const enabled = i < ctx.groups;
    s += connector(i === 0 ? 232 : x - 15, 156, x, 156);
    s += block(x, 96, 90, 120, C.residual, 'Residual ×4', `W=${w} · AR=${ar}`, residualFocus && enabled, enabled);
  });
  s += connector(660, 156, 690, 156) + block(690, 112, 82, 88, C.model, 'Crop', `−${fmt(ctx.cl / 2)} / edge`, skipFocus);
  s += connector(772, 156, 798, 156) + block(798, 100, 107, 112, C.model, '1×1 + softmax', '· / A / D', outputFocus);

  const taps = [191, 300, 405, 510, 615];
  taps.forEach((x, i) => {
    const enabled = i === 0 || i <= ctx.groups;
    const opacity = enabled ? (skipFocus ? 1 : 0.4) : 0.12;
    s += `<g opacity="${opacity}"><path d="M${x} ${i === 0 ? 112 : 96} V68" stroke="${C.skip}" stroke-width="${skipFocus ? 2.2 : 1.2}"/><rect x="${x - 30}" y="38" width="60" height="30" rx="3" fill="${C.skip}" fill-opacity="0.1" stroke="${C.skip}" ${enabled ? '' : 'stroke-dasharray="4 4"'}/><text x="${x}" y="58" class="lvz-small">skip 1×1</text></g>`;
  });
  s += `<path d="M191 38 H730 V108" fill="none" stroke="${C.skip}" stroke-width="${skipFocus ? 2.2 : 1.2}" opacity="${skipFocus ? 1 : 0.4}"/><circle cx="730" cy="94" r="11" fill="var(--color-bg)" stroke="${C.skip}" opacity="${skipFocus ? 1 : 0.55}"/><text x="730" y="98" class="lvz-small">Σ</text>`;
  s += `<rect x="120" y="252" width="660" height="96" rx="6" fill="var(--color-bg)" stroke="var(--color-rule)"/>${desktopDetail(ctx, step)}`;
  return `<svg viewBox="0 0 920 365" class="lvz-svg" role="img" aria-label="Complete OpenSpliceAI architecture at ${fmt(ctx.cl)} nucleotide context, highlighting step ${step + 1}" preserveAspectRatio="xMidYMid meet">${s}</svg>`;
}

function mobileBlock(y: number, title: string, detail: string, color: string, focused: boolean, enabled = true) {
  const opacity = enabled ? (focused ? 1 : 0.5) : 0.14;
  return `<g opacity="${opacity}"><rect x="18" y="${y}" width="238" height="52" rx="5" fill="${color}" fill-opacity="${focused ? 0.16 : 0.05}" stroke="${color}" stroke-width="${focused ? 2.5 : 1.2}" ${enabled ? '' : 'stroke-dasharray="4 4"'}/><text x="34" y="${y + 22}" class="lvz-tl" fill="${color}">${title}</text><text x="137" y="${y + 42}" class="lvz-small">${detail}</text></g>`;
}

function mobileFrame(ctx: Context, step: number) {
  let s = mobileBlock(8, 'one-hot DNA', `4 × ${fmt(ctx.input)}`, C.input, step === 0);
  s += `<path d="M137 60 V76" stroke="var(--color-muted)"/>` + mobileBlock(76, 'Conv1d stem', '4 → 32 channels', C.model, step === 1);
  s += `<g opacity="${step === 4 ? 1 : 0.42}"><path d="M256 102 H278" stroke="${C.skip}"/><rect x="278" y="86" width="64" height="32" rx="3" fill="${C.skip}" fill-opacity="0.1" stroke="${C.skip}"/><text x="310" y="106" class="lvz-small">skip 1×1</text></g>`;
  groupSchedule.forEach(({ w, ar }, i) => {
    const y = 144 + i * 62;
    const enabled = i < ctx.groups;
    s += `<path d="M137 ${y - 16} V${y}" stroke="var(--color-muted)" opacity="${enabled ? 0.5 : 0.15}"/>` + mobileBlock(y, `ResidualUnit × 4 · group ${i + 1}`, `W=${w} · AR=${ar}`, C.residual, (step === 2 || step === 3) && enabled, enabled);
    const tapOpacity = enabled ? (step === 4 ? 1 : 0.42) : 0.12;
    s += `<g opacity="${tapOpacity}"><path d="M256 ${y + 26} H278" stroke="${C.skip}"/><rect x="278" y="${y + 10}" width="64" height="32" rx="3" fill="${C.skip}" fill-opacity="0.1" stroke="${C.skip}"/><text x="310" y="${y + 30}" class="lvz-small">skip 1×1</text></g>`;
  });
  s += `<path d="M137 366 V386" stroke="var(--color-muted)"/>` + mobileBlock(386, 'Cropping1D', `trim ${fmt(ctx.cl / 2)} / edge`, C.model, step === 4);
  s += `<path d="M137 438 V458" stroke="var(--color-muted)"/>` + mobileBlock(458, '1×1 Conv1d + softmax', 'neither · acceptor · donor', C.model, step === 5);
  s += `<path d="M310 102 V412 H256" fill="none" stroke="${C.skip}" stroke-width="${step === 4 ? 2 : 1.2}" opacity="${step === 4 ? 1 : 0.35}"/><circle cx="275" cy="412" r="10" fill="var(--color-bg)" stroke="${C.skip}"/><text x="275" y="416" class="lvz-small">Σ</text>`;
  const details = [
    `stored 15,000 · selected input ${fmt(ctx.input)} · central output 5,000`,
    'stem preserves length while learning 32 sequence features',
    'BN → LeakyReLU → Conv1d, repeated twice, plus identity',
    `${ctx.units} units · W ${ctx.windows} · AR ${ctx.dilations}`,
    `sum active taps · crop ${fmt(ctx.cl / 2)} positions from both edges`,
    'output shape N × 3 × 5,000',
  ];
  s += `<rect x="12" y="532" width="336" height="76" rx="5" fill="var(--color-bg)" stroke="var(--color-rule)"/><text x="180" y="558" class="lvz-nt on">Step ${step + 1}</text><text x="180" y="585" class="lvz-small">${details[step]}</text>`;
  return `<svg viewBox="0 0 360 620" class="lvz-svg" role="img" aria-label="Complete OpenSpliceAI architecture at ${fmt(ctx.cl)} nucleotide context, highlighting step ${step + 1}" preserveAspectRatio="xMidYMid meet">${s}</svg>`;
}

const steps = [
  ['Select how much flanking sequence the model reads', 'The complete network stays visible while the selected context determines its input width and active residual groups.'],
  ['Project four DNA channels into learned features', 'The highlighted Conv1d stem converts one-hot DNA into 32 feature channels while preserving sequence length.'],
  ['Look inside one pre-activation residual unit', 'Each highlighted unit applies two BatchNorm–LeakyReLU–Conv1d sequences and adds the original input.'],
  ['Expand the receptive field with dilated convolution', 'The active groups show the fixed window and dilation schedule for the selected context size.'],
  ['Sum skip features and remove flanking context', 'Active 1×1 taps combine shallow and deep features before Cropping1D trims CL/2 positions from each edge.'],
  ['Predict three classes at every central position', 'The highlighted 1×1 head and softmax produce neither, acceptor, and donor probabilities for 5,000 positions.'],
] as const;
---

<section class="lvz osai osai-architecture" role="group" aria-label="Interactive: OpenSpliceAI residual dilated convolutional architecture" data-print-final-state="true">
  <div class="lvz-head"><p class="lvz-title">Read long-range sequence context</p><label class="osai-selector"><span>Flanking context</span><select data-osai-context>{contexts.map((ctx) => <option value={ctx.id}>{fmt(ctx.cl)} nt</option>)}</select></label></div>
  <p class="lvz-caption" data-wgi-caption aria-live="polite">{steps[0][1]}</p>
  <nav class="lvz-progress" aria-label="Model architecture steps">{steps.map(([title], i) => <button type="button" class="lvz-jump" data-wgi-jump aria-label={`Step ${i + 1}: ${title}`} title={title}>{i + 1}</button>)}</nav>
  {contexts.map((ctx, contextIndex) => (
    <div data-osai-context-group={ctx.id} hidden={contextIndex !== 0}>
      {steps.map(([title, caption], i) => (
        <div class="lvz-step" data-wgi-step data-print-final={i === steps.length - 1 ? 'true' : undefined} data-caption={caption} hidden={i !== 0}>
          <p class="lvz-steptitle"><span class="lvz-num">{i + 1}</span>{title}</p>
          <div class="lvz-fig lvz-visual--desktop" set:html={desktopFrame(ctx, i)} />
          <div class="lvz-fig lvz-visual--mobile" set:html={mobileFrame(ctx, i)} />
        </div>
      ))}
    </div>
  ))}
  <div class="lvz-controls">
    <button type="button" class="lvz-btn" data-wgi-prev aria-label="Previous step">← Prev</button><button type="button" class="lvz-btn" data-wgi-play aria-pressed="false" aria-label="Play animation"><span data-wgi-play-icon>▶</span> <span data-wgi-play-label>Play</span></button><button type="button" class="lvz-btn" data-wgi-next aria-label="Next step">Next →</button><button type="button" class="lvz-btn" data-wgi-reset aria-label="Restart from first step">↺ Restart</button><span class="lvz-pos" data-wgi-pos>1 / {steps.length}</span>
  </div>
  <div class="lvz-legend"><span><span class="lvz-sw" style={`background:${C.input}`}></span>sequence / context</span><span><span class="lvz-sw" style={`background:${C.residual}`}></span>residual features</span><span><span class="lvz-sw" style={`background:${C.skip}`}></span>skip features</span><span><span class="lvz-sw" style={`background:${C.acceptor}`}></span>acceptor</span><span><span class="lvz-sw" style={`background:${C.donor}`}></span>donor</span></div>
</section>

<script>
  import { mountStepper } from '../scripts/wgiStepper';
  function boot() {
    for (const root of document.querySelectorAll<HTMLElement>('.osai-architecture')) {
      if (root.dataset.osaiReady === 'true') continue;
      root.dataset.osaiReady = 'true';
      const groups = Array.from(root.querySelectorAll<HTMLElement>('[data-osai-context-group]'));
      const select = root.querySelector<HTMLSelectElement>('[data-osai-context]');
      let active = select?.value || groups[0]?.dataset.osaiContextGroup || '';
      let current = 0;
      const activeSteps = () => Array.from(groups.find((group) => group.dataset.osaiContextGroup === active)?.querySelectorAll<HTMLElement>('[data-wgi-step]') || []);
      const show = (i: number) => { current = i; groups.forEach((group) => { const on = group.dataset.osaiContextGroup === active; group.hidden = !on; Array.from(group.querySelectorAll<HTMLElement>('[data-wgi-step]')).forEach((step, k) => { const selected = on && i === k; step.hidden = !selected; step.setAttribute('aria-current', selected ? 'step' : 'false'); }); }); };
      const api = mountStepper(root, { total: activeSteps().length, onShow: show, caption: (i) => activeSteps()[i]?.dataset.caption || '', interval: 6500 });
      select?.addEventListener('change', () => { api?.stop(); active = select.value; api?.show(current); });
    }
  }
  boot();
  document.addEventListener('astro:page-load', boot);
</script>
