---
/** Published LiftOn method: resolve overlaps and recover additional gene copies. */
import '../styles/lvz.css';

interface Props { autoPlay?: boolean }
const { autoPlay = false } = Astro.props;

const W = 760, H = 330;
const C = { lift: '#4c78a8', mini: '#f58518', merge: '#54a24b', ref: '#2e6e5e', bad: '#d1495b' };
const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;');

function label(text: string, y: number, color = 'var(--color-ink)') {
  return `<text x="18" y="${y + 5}" class="lvz-tl" fill="${color}">${esc(text)}</text>`;
}
function axis(y: number) {
  return `<line x1="160" y1="${y}" x2="730" y2="${y}" stroke="var(--color-muted)" stroke-width="1.2" opacity="0.65"/>`;
}
function locus(x: number, y: number, w: number, color: string, opts: { opacity?: number; dash?: boolean; utr?: boolean } = {}) {
  const opacity = opts.opacity ?? 0.8;
  let s = `<rect x="${x}" y="${y - 13}" width="${w}" height="26" rx="3" fill="${color}" fill-opacity="${opacity * 0.22}" stroke="${color}" stroke-width="1.5"${opts.dash ? ' stroke-dasharray="5 3"' : ''}/>`;
  s += `<rect x="${x + 10}" y="${y - 9}" width="${Math.max(18, w * 0.24)}" height="18" rx="2" fill="${color}" fill-opacity="${opacity}"/>`;
  s += `<rect x="${x + w * 0.58}" y="${y - 9}" width="${Math.max(16, w * 0.25)}" height="18" rx="2" fill="${color}" fill-opacity="${opacity}"/>`;
  if (opts.utr) {
    s += `<rect x="${x + 2}" y="${y - 5}" width="8" height="10" fill="${color}" fill-opacity="${opacity * 0.65}"/>`;
    s += `<rect x="${x + w - 10}" y="${y - 5}" width="8" height="10" fill="${color}" fill-opacity="${opacity * 0.65}"/>`;
  }
  return s;
}

function reject(x: number, y: number, reason: string) {
  return `<path d="M${x} ${y - 9} l18 18 M${x + 18} ${y - 9} l-18 18" stroke="${C.bad}" stroke-width="2.7" stroke-linecap="round"/><text x="${x + 66}" y="${y + 5}" class="lvz-small" fill="${C.bad}">${esc(reason)}</text>`;
}

function frame(step: number) {
  let s = label('Accepted loci', 46, C.ref) + axis(46);
  s += locus(185, 46, 130, C.ref, { utr: true });
  s += locus(475, 46, 120, C.ref, { utr: true });
  s += `<text x="250" y="22" class="lvz-small">interval tree tracks occupied loci</text>`;

  if (step >= 1) {
    s += label('Liftoff copies', 120, C.lift) + axis(120);
    s += locus(345, 120, 115, C.lift, { utr: true });
    s += `<text x="405" y="98" class="lvz-small">DNA identity + overlap checks</text>`;
  }
  if (step >= 2) {
    s += label('miniprot candidates', 195, C.mini) + axis(195);
    s += locus(620, 195, 92, C.mini, { dash: true });
    s += locus(270, 195, 120, C.mini, { dash: true, opacity: step >= 3 ? 0.25 : 0.72 });
    s += locus(490, 195, 82, C.mini, { dash: true, opacity: step >= 3 ? 0.25 : 0.72 });
  }
  if (step >= 3) {
    s += reject(315, 231, '>10% overlap');
    s += reject(515, 254, 'single-CDS / length filter');
    s += `<rect x="610" y="174" width="110" height="42" rx="5" fill="${C.merge}" fill-opacity="0.05" stroke="${C.merge}" stroke-width="2"/>`;
  }
  if (step >= 4) {
    s += label('Final annotation', 290, C.merge) + axis(290);
    s += locus(185, 290, 130, C.ref, { utr: true });
    s += locus(345, 290, 115, C.lift, { utr: true });
    s += locus(475, 290, 120, C.ref, { utr: true });
    s += locus(620, 290, 92, C.mini);
    s += `<text x="666" y="267" class="lvz-small" fill="${C.mini}">protein-only copy · no UTRs</text>`;
  }
  return `<svg viewBox="0 0 ${W} ${H}" class="lvz-svg" role="img" aria-label="Additional gene-copy discovery and overlap filtering" preserveAspectRatio="xMidYMid meet">${s}</svg>`;
}

const steps = [
  {
    title: 'Track every accepted locus',
    caption: 'LiftOn stores mapped gene intervals in chromosome-specific interval trees. This makes overlap checks fast and prevents a new candidate from silently displacing an accepted annotation.',
  },
  {
    title: 'Let Liftoff search for DNA-supported copies first',
    caption: 'Liftoff iteratively maps additional copies, prioritizing DNA evidence because it can preserve the complete hierarchy and UTRs. A candidate must satisfy the requested DNA identity and may overlap another locus only where the reference already overlaps or within the 10% allowance.',
  },
  {
    title: 'Use miniprot to propose coding copies Liftoff missed',
    caption: 'LiftOn then examines remaining miniprot mappings. Because these candidates come from protein evidence, they can recover a coding copy where the DNA lift failed, but they require stricter filtering.',
  },
  {
    title: 'Reject overlaps, processed pseudogenes, and partial models',
    caption: 'A miniprot-only copy must overlap accepted loci by at most 10%. A single-CDS candidate is allowed only when the reference transcript also has one CDS, and its coding-length ratio to the reference gene’s longest isoform must fall between 0.9 and 1.5.',
  },
  {
    title: 'Add the accepted copy with an explicit hierarchy',
    caption: 'For an accepted protein-only copy, LiftOn recreates the reference gene as the parent of the new mRNA/CDS model. The copy is coding-only: miniprot does not provide UTR boundaries. Noncoding copies therefore depend on the DNA-based path.',
  },
];
---

<section
  class="lvz lvz-copies"
  role="group"
  aria-label="Interactive: resolving overlaps and finding additional gene copies"
  data-autoplay={autoPlay ? 'true' : undefined}
  data-print-final-state="true"
>
  <div class="lvz-head">
    <p class="lvz-title">Resolve overlaps and recover additional copies</p>
    <span class="lvz-tag">Interactive · illustrative</span>
  </div>
  <p class="lvz-caption" data-wgi-caption aria-live="polite">{steps[0].caption}</p>

  {steps.map((step, i) => (
    <div
      class="lvz-step"
      data-wgi-step
      data-print-final={i === steps.length - 1 ? 'true' : undefined}
      data-caption={step.caption}
      hidden={i !== 0}
    >
      <p class="lvz-steptitle"><span class="lvz-num">{i + 1}</span>{step.title}</p>
      <div class="lvz-fig" set:html={frame(i)} />
    </div>
  ))}

  <div class="lvz-controls">
    <button type="button" class="lvz-btn" data-wgi-prev aria-label="Previous step">← Prev</button>
    <button type="button" class="lvz-btn" data-wgi-play aria-pressed="false" aria-label="Play">▶ Play</button>
    <button type="button" class="lvz-btn" data-wgi-next aria-label="Next step">Next →</button>
    <button type="button" class="lvz-btn" data-wgi-reset aria-label="Reset to first step">↺ Reset</button>
    <span class="lvz-pos" data-wgi-pos>1 / {steps.length}</span>
  </div>

  <div class="lvz-legend">
    <span><span class="lvz-sw" style={`background:${C.lift}`}></span>Liftoff copy</span>
    <span><span class="lvz-sw" style={`background:${C.mini}`}></span>miniprot candidate</span>
    <span><span class="lvz-sw" style={`background:${C.merge}`}></span>accepted copy</span>
    <span><span class="lvz-sw" style={`background:${C.bad}`}></span>rejected candidate</span>
  </div>

  <noscript><style>{`.lvz-copies .lvz-step[hidden]{display:block!important}.lvz-copies .lvz-controls,.lvz-copies .lvz-caption{display:none!important}`}</style></noscript>
</section>

<script>
  import { mountStepper } from '../scripts/wgiStepper';
  function boot() {
    for (const root of document.querySelectorAll<HTMLElement>('.lvz-copies')) {
      const steps = Array.from(root.querySelectorAll<HTMLElement>('[data-wgi-step]'));
      const captions = steps.map((step) => step.dataset.caption || '');
      mountStepper(root, {
        total: steps.length,
        onShow: (i) => steps.forEach((step, k) => {
          const current = k === i;
          step.hidden = !current;
          step.setAttribute('aria-current', current ? 'step' : 'false');
        }),
        caption: (i) => captions[i],
        autoPlay: root.dataset.autoplay === 'true',
      });
    }
  }
  boot();
  document.addEventListener('astro:page-load', boot);
</script>
