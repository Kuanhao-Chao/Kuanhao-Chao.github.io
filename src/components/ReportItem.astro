---
import { monthDay } from '../lib/format';
import { topicSlugs } from '../lib/postTopics';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'reports'>;
  minutes: number;
}
const { entry, minutes } = Astro.props;
const d = entry.data;
const href = `/reports/${entry.id}/`;

const topics = topicSlugs(d.tags).join(' ');
const searchText = `${d.title} ${d.description} ${d.venue} ${d.institution} ${d.authors.join(' ')} ${d.tags.join(' ')}`.toLowerCase();
---
<article
  class="report"
  data-ts={d.date.getTime()}
  data-year={d.date.getFullYear()}
  data-topics={topics}
  data-search={searchText}
>
  <time class="report-date" datetime={d.date.toISOString()} aria-hidden="true">
    {monthDay(d.date)}
  </time>
  <div class="report-body">
    <h3 class="report-title"><a href={href}>{d.title}</a></h3>
    <p class="report-line">
      <span class="report-tag">{d.venue}</span>
      <span class="report-read">{minutes} min read</span>
    </p>
    <p class="report-desc muted">{d.description}</p>
  </div>
</article>

<style>
  .report {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: 0 1.5rem;
    padding-block: var(--space-6);
    border-bottom: 1px solid var(--color-rule);
  }
  .report-date {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: var(--fw-medium);
    color: var(--color-muted);
    padding-top: 0.15rem;
  }
  .report-line {
    margin-top: 0.4rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem;
    font-size: var(--fs-small);
  }
  .report-title {
    font-size: 1.15rem;
    font-weight: var(--fw-semibold);
    line-height: 1.35;
  }
  .report-title a {
    color: var(--color-ink);
  }
  .report-title a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
  .report-tag {
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: var(--fw-semibold);
    color: var(--color-accent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 35%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    padding: 0.12em 0.55em;
  }
  .report-read {
    font-size: var(--fs-meta);
    color: var(--color-muted);
  }
  .report-desc {
    margin-top: 0.4rem;
    font-size: var(--fs-small);
    max-width: var(--measure);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 560px) {
    .report {
      grid-template-columns: 1fr;
      gap: 0.3rem;
      padding-block: var(--space-4);
    }
    .report-date {
      padding-top: 0;
      font-size: 0.95rem;
    }
    .report-title {
      font-size: 1.02rem;
      line-height: 1.3;
    }
  }
</style>
