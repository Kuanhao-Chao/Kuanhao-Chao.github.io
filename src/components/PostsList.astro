---
import PostItem from './PostItem.astro';
import Icon from './Icon.astro';
import { readingTime } from '../lib/format';
import { POST_TOPICS } from '../lib/postTopics';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'posts'>[];
}
const { posts } = Astro.props;
const topics = [{ slug: 'all', label: 'All' }, ...POST_TOPICS];
---
<div class="post-tools" data-post-tools>
  <div class="post-filters" role="group" aria-label="Filter by topic">
    {
      topics.map((t) => (
        <button
          type="button"
          class="filter-pill"
          data-filter={t.slug}
          aria-pressed={t.slug === 'all' ? 'true' : 'false'}
        >
          {t.label}
        </button>
      ))
    }
  </div>

  <div class="post-controls">
    <label class="search">
      <Icon name="search" size={18} />
      <input type="search" placeholder="Search posts…" data-search-input aria-label="Search posts" />
    </label>
    <label class="sort">
      <span class="visually-hidden">Sort posts</span>
      <select data-sort>
        <option value="newest">Newest first</option>
        <option value="oldest">Oldest first</option>
        <option value="az">A–Z</option>
      </select>
      <Icon name="chevron-down" size={16} />
    </label>
  </div>
</div>

<ol class="post-list" data-post-list>
  {posts.map((entry) => <li><PostItem entry={entry} minutes={readingTime(entry.body ?? '')} /></li>)}
</ol>

<p class="post-empty" data-post-empty hidden>No posts match your search.</p>

<style>
  .post-tools {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: var(--space-4);
  }
  .post-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .filter-pill {
    font-size: var(--fs-small);
    font-weight: var(--fw-medium);
    padding: 0.4em 0.9em;
    border: 1px solid var(--color-rule);
    border-radius: 999px;
    background: transparent;
    color: var(--color-muted);
    cursor: pointer;
    transition: all var(--transition);
  }
  .filter-pill:hover {
    border-color: var(--color-ink);
    color: var(--color-ink);
  }
  .filter-pill[aria-pressed='true'] {
    background: var(--color-ink);
    border-color: var(--color-ink);
    color: var(--color-bg);
  }
  .post-controls {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .search {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45em 0.8em;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
    background: var(--color-surface);
    color: var(--color-muted);
  }
  .search:focus-within {
    border-color: var(--color-accent);
    color: var(--color-ink);
  }
  .search input {
    border: none;
    outline: none;
    background: transparent;
    font-size: var(--fs-small);
    width: min(15rem, 50vw);
  }
  .sort {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  .sort select {
    appearance: none;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
    background: var(--color-surface);
    padding: 0.5em 2.2em 0.5em 0.8em;
    font-size: var(--fs-small);
    cursor: pointer;
  }
  .sort :global(svg) {
    position: absolute;
    right: 0.6em;
    pointer-events: none;
    color: var(--color-muted);
  }
  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-rule);
  }
  .post-list li.is-hidden {
    display: none;
  }
  /* Year-group separators are created at runtime by the island, so they carry no
     scoped attribute — style them globally. The class is unique to this page. */
  :global(.post-year) {
    font-size: var(--fs-h3);
    color: var(--color-muted);
    font-weight: var(--fw-medium);
    padding-bottom: var(--space-3);
    margin-top: var(--space-10);
    border-bottom: 1px solid var(--color-rule);
  }
  :global(.post-year:first-child) {
    margin-top: var(--space-5);
  }
  .post-empty {
    padding: var(--space-8) 0;
    color: var(--color-muted);
  }

  /* Roomier controls on touch devices. */
  @media (pointer: coarse) {
    .filter-pill,
    .search,
    .sort select {
      padding-block: 0.6em;
    }
  }
</style>

<script>
  // Lightweight, dependency-free filter / sort / search island for the Posts page.
  // Adapted from PublicationsList: posts carry MULTIPLE topics, so the type filter
  // becomes a membership test, and we group by year on load (apply runs immediately).
  // Re-wires on every view transition: ClientRouter swaps in fresh DOM and bundled
  // module scripts run only once, so we (re)initialise on each astro:page-load.
  function init() {
    const root = document.querySelector<HTMLElement>('[data-post-tools]');
    const list = document.querySelector<HTMLOListElement>('[data-post-list]');
    const empty = document.querySelector<HTMLElement>('[data-post-empty]');
    if (!root || !list) return;
    const items = Array.from(list.querySelectorAll<HTMLLIElement>('li'));
    const pills = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-filter]'));
    const searchInput = root.querySelector<HTMLInputElement>('[data-search-input]');
    const sortSelect = root.querySelector<HTMLSelectElement>('[data-sort]');

    const meta = (li: HTMLLIElement) => {
      const el = li.querySelector<HTMLElement>('.post')!;
      return {
        ts: Number(el.dataset.ts ?? 0),
        year: Number(el.dataset.year ?? 0),
        topics: (el.dataset.topics ?? '').split(' ').filter(Boolean),
        title: el.querySelector('.post-title')?.textContent?.trim().toLowerCase() ?? '',
        search: el.dataset.search ?? '',
      };
    };
    const order = new Map(items.map((li, i) => [li, i])); // original (newest-first)

    let activeTopic = 'all';
    let query = '';

    const makeSep = (year: number) => {
      const li = document.createElement('li');
      li.className = 'post-year';
      li.dataset.sep = '';
      li.setAttribute('aria-hidden', 'true');
      li.textContent = String(year);
      return li;
    };

    const apply = () => {
      // Drop any separators from the previous render before re-laying out.
      list.querySelectorAll('[data-sep]').forEach((s) => s.remove());

      let visible = 0;
      for (const li of items) {
        const m = meta(li);
        const ok =
          (activeTopic === 'all' || m.topics.includes(activeTopic)) &&
          (query === '' || m.search.includes(query));
        li.classList.toggle('is-hidden', !ok);
        if (ok) visible++;
      }
      if (empty) empty.hidden = visible !== 0;

      const mode = sortSelect?.value ?? 'newest';
      const sorted = [...items].sort((a, b) => {
        const ma = meta(a);
        const mb = meta(b);
        if (mode === 'oldest') return ma.ts - mb.ts || order.get(a)! - order.get(b)!;
        if (mode === 'az') return ma.title.localeCompare(mb.title);
        return mb.ts - ma.ts || order.get(a)! - order.get(b)!; // newest
      });
      sorted.forEach((li) => list.appendChild(li));

      // Group visible items by year in the chronological views (skip A–Z).
      if (mode === 'newest' || mode === 'oldest') {
        let lastYear: number | null = null;
        for (const li of sorted) {
          if (li.classList.contains('is-hidden')) continue;
          const y = meta(li).year;
          if (y !== lastYear) {
            list.insertBefore(makeSep(y), li);
            lastYear = y;
          }
        }
      }
    };

    pills.forEach((pill) =>
      pill.addEventListener('click', () => {
        activeTopic = pill.dataset.filter ?? 'all';
        pills.forEach((p) => p.setAttribute('aria-pressed', String(p === pill)));
        apply();
      })
    );
    searchInput?.addEventListener('input', () => {
      query = searchInput.value.trim().toLowerCase();
      apply();
    });
    sortSelect?.addEventListener('change', apply);

    apply(); // group by year on load
  }
  document.addEventListener('astro:page-load', init);
</script>
