---
import '../styles/lvz.css';
import '../styles/shorkie.css';

const steps = [
  ['Encode sequence and species', 'For the selected 165-genome model, every 16,384 bp window has four DNA channels, one mask channel, and 165 one-hot species channels.'],
  ['Choose positions to reconstruct', 'The objective samples 15% of positions: 2,457 bases in each 16,384 bp training window.'],
  ['Corrupt the selected bases', 'Of those positions, 80% receive the mask token, 10% a random nucleotide, and 10% remain unchanged.'],
  ['Augment both DNA orientations', 'Each example is reverse-complemented with probability 0.5, so the model cannot depend on an arbitrary strand orientation.'],
  ['Reconstruct nucleotide probabilities', 'The language model predicts a probability distribution over A, C, G, and T at every selected position.'],
  ['Optimize and compare evolutionary scopes', 'Cross-entropy is computed only at selected positions; exon and repeat positions receive weight 0.1. Held-out perplexity identifies the 165-genome model as the best transfer source.'],
] as const;

const colors = ['#3976a8', '#b04755', '#b07d00', '#2f8069', '#6f62a8', '#b26b32'];

function box(x: number, y: number, w: number, h: number, title: string, detail: string, color: string, focus: boolean) {
  return `<g opacity="${focus ? 1 : 0.28}"><rect x="${x}" y="${y}" width="${w}" height="${h}" rx="5" fill="${color}" fill-opacity="0.1" stroke="${color}" stroke-width="${focus ? 2.8 : 1.2}"/><text x="${x + w / 2}" y="${y + h / 2 - 6}" class="shk-label" fill="${color}">${title}</text><text x="${x + w / 2}" y="${y + h / 2 + 16}" class="shk-detail">${detail}</text></g>`;
}

function desktop(step: number) {
  const data = [
    ['input channels', '16,384 × 170'], ['sample masks', '15% · 2,457 bases'], ['80 / 10 / 10', 'mask · random · unchanged'],
    ['orientation', 'forward or reverse complement'], ['A C G T', 'per-position softmax'], ['masked loss', 'weighted CE → perplexity'],
  ];
  let s = `<text x="20" y="27" class="lvz-tl">Masked-language-model pretraining</text>`;
  data.forEach(([title, detail], i) => {
    const x = 12 + i * 150;
    s += box(x, 88, 135, 100, title, detail, colors[i], i === step);
    if (i < 5) s += `<path d="M${x + 135} 138 H${x + 150}" class="shk-arrow"/><path d="M${x + 143} 132 l7 6-7 6" class="shk-arrow"/>`;
  });
  const sequence = step < 2 ? 'A C G T A C G T A C G T' : step === 2 ? 'A [M] G T A T G T A C G T' : 'A C G T A C G T A C G T';
  s += `<rect x="95" y="225" width="730" height="108" rx="5" class="shk-card"/><text x="460" y="255" class="shk-dna" text-anchor="middle">${sequence}</text>`;
  const detail = ['4 DNA + 1 mask + 165 species channels', 'selected sites define where loss is measured', '80% mask · 10% random base · 10% unchanged', 'reverse complement with probability 0.5', 'predict P(A), P(C), P(G), P(T)', 'exon/repeat weight 0.1 · other positions weight 1.0'][step];
  s += `<text x="460" y="290" class="shk-label">Step ${step + 1}</text><text x="460" y="315" class="shk-detail">${detail}</text>`;
  return `<svg viewBox="0 0 920 355" class="lvz-svg" role="img" aria-label="Shorkie masked language model pretraining, step ${step + 1}">${s}</svg>`;
}

function mobile(step: number) {
  const data = [
    ['input channels', '4 DNA + 1 mask + 165 species'], ['sample masks', '15% · 2,457 bases'], ['corrupt selected sites', '80% mask · 10% random · 10% unchanged'],
    ['strand augmentation', 'reverse complement with p = 0.5'], ['reconstruct DNA', 'P(A), P(C), P(G), P(T)'], ['masked weighted loss', 'cross-entropy → held-out perplexity'],
  ];
  let s = '';
  data.forEach(([title, detail], i) => { s += box(18, 14 + i * 70, 324, 54, title, detail, colors[i], i === step); if (i < 5) s += `<path d="M180 ${68 + i * 70} V${82 + i * 70}" class="shk-arrow"/>`; });
  return `<svg viewBox="0 0 360 435" class="lvz-svg" role="img" aria-label="Shorkie masked language model pretraining, step ${step + 1}">${s}</svg>`;
}
---

<section class="lvz shk shk-pretraining" role="group" aria-label="Interactive: Shorkie masked language model pretraining" data-print-final-state="true">
  <div class="lvz-head"><p class="lvz-title">Learn fungal sequence context</p><span class="lvz-tag">165-genome model shown</span></div>
  <p class="lvz-caption" data-wgi-caption aria-live="polite">{steps[0][1]}</p>
  <nav class="lvz-progress" aria-label="Pretraining steps">{steps.map(([title], i) => <button type="button" class="lvz-jump" data-wgi-jump aria-label={`Step ${i + 1}: ${title}`} title={title}>{i + 1}</button>)}</nav>
  {steps.map(([title, caption], i) => <div class="lvz-step" data-wgi-step data-print-final={i === 5 ? 'true' : undefined} data-caption={caption} hidden={i !== 0}><p class="lvz-steptitle"><span class="lvz-num">{i + 1}</span>{title}</p><div class="lvz-fig lvz-visual--desktop" set:html={desktop(i)} /><div class="lvz-fig lvz-visual--mobile" set:html={mobile(i)} /></div>)}
  <div class="lvz-controls"><button type="button" class="lvz-btn" data-wgi-prev>← Prev</button><button type="button" class="lvz-btn" data-wgi-play aria-pressed="false"><span data-wgi-play-icon>▶</span> <span data-wgi-play-label>Play</span></button><button type="button" class="lvz-btn" data-wgi-next>Next →</button><button type="button" class="lvz-btn" data-wgi-reset>↺ Restart</button><span class="lvz-pos" data-wgi-pos>1 / {steps.length}</span></div>
</section>

<script>
  import { mountStepper } from '../scripts/wgiStepper';
  function boot() { for (const root of document.querySelectorAll<HTMLElement>('.shk-pretraining')) { if (root.dataset.ready === 'true') continue; root.dataset.ready = 'true'; const all = Array.from(root.querySelectorAll<HTMLElement>('[data-wgi-step]')); mountStepper(root, { total: all.length, onShow: (i) => all.forEach((el, k) => el.hidden = k !== i), caption: (i) => all[i]?.dataset.caption || '', interval: 7000 }); } }
  boot(); document.addEventListener('astro:page-load', boot);
</script>
