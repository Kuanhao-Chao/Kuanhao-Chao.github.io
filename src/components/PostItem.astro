---
import { fullDate, monthDay } from '../lib/format';
import { topicSlugs } from '../lib/postTopics';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'posts'>;
  minutes: number;
  compact?: boolean;
}
const { entry, minutes, compact = false } = Astro.props;
const d = entry.data;
const href = `/posts/${entry.id}/`;
const categoryLabel = { summary: 'Research summary', opinion: 'Opinion' }[d.category];

// Data for the Posts-page filter/sort/search island (non-compact rows only).
const topics = topicSlugs(d.tags).join(' ');
const searchText = `${d.title} ${d.description} ${d.tags.join(' ')}`.toLowerCase();
---
{
  compact ? (
    <article class="post-item post-item--compact">
      <div class="post-meta">
        <time datetime={d.date.toISOString()}>{fullDate(d.date)}</time>
        <span class:list={['post-tag', `post-tag--${d.category}`]}>{categoryLabel}</span>
        <span class="post-read">{minutes} min read</span>
      </div>
      <h3 class="post-title"><a href={href}>{d.title}</a></h3>
      <p class="post-desc muted">{d.description}</p>
      <a class="post-more" href={href}>Read post<span aria-hidden="true">&nbsp;→</span></a>
    </article>
  ) : (
    <article
      class="post"
      data-ts={d.date.getTime()}
      data-year={d.date.getFullYear()}
      data-topics={topics}
      data-search={searchText}
    >
      <time class="post-date" datetime={d.date.toISOString()} aria-hidden="true">
        {monthDay(d.date)}
      </time>
      <div class="post-body">
        <h3 class="post-title"><a href={href}>{d.title}</a></h3>
        <p class="post-line">
          <span class:list={['post-tag', `post-tag--${d.category}`]}>{categoryLabel}</span>
          <span class="post-read">{minutes} min read</span>
        </p>
        <p class="post-desc muted">{d.description}</p>
      </div>
    </article>
  )
}

<style>
  /* ---- Listing row (mirrors the Publications item grid) ---- */
  .post {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: 0 1.5rem;
    padding-block: var(--space-6);
    border-bottom: 1px solid var(--color-rule);
  }
  .post-date {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: var(--fw-medium);
    color: var(--color-muted);
    padding-top: 0.15rem;
  }
  .post-line {
    margin-top: 0.4rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem;
    font-size: var(--fs-small);
  }

  /* ---- Shared between the row and the compact teaser ---- */
  .post-title {
    font-size: 1.15rem;
    font-weight: var(--fw-semibold);
    line-height: 1.35;
  }
  .post-title a {
    color: var(--color-ink);
  }
  .post-title a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
  .post-tag {
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: var(--fw-semibold);
    color: var(--color-muted);
    border: 1px solid var(--color-rule);
    border-radius: 999px;
    padding: 0.12em 0.55em;
  }
  .post-tag--summary {
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent) 35%, transparent);
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
  }
  .post-tag--opinion {
    color: var(--color-badge-warm-text);
    border-color: var(--color-badge-warm-border);
    background: var(--color-badge-warm-bg);
  }
  .post-read {
    font-size: var(--fs-meta);
    color: var(--color-muted);
  }
  .post-desc {
    margin-top: 0.4rem;
    font-size: var(--fs-small);
    max-width: var(--measure);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ---- Compact teaser (homepage "Writing" section) ---- */
  .post-item--compact {
    padding-block: var(--space-5);
    border-bottom: 1px solid var(--color-rule);
  }
  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.55rem 0.9rem;
    margin-bottom: 0.7rem;
  }
  .post-meta time {
    font-family: var(--font-display);
    color: var(--color-muted);
    font-size: 0.95rem;
  }
  .post-more {
    display: inline-block;
    margin-top: 0.9rem;
    font-size: var(--fs-small);
    font-weight: var(--fw-medium);
    color: var(--color-accent);
  }
  .post-more:hover {
    text-decoration: none;
  }

  @media (max-width: 560px) {
    .post {
      grid-template-columns: 1fr;
      gap: 0.3rem;
      padding-block: var(--space-4);
    }
    .post-date {
      padding-top: 0;
      font-size: 0.95rem;
    }
    .post-title {
      font-size: 1.02rem;
      line-height: 1.3;
    }
  }
</style>
