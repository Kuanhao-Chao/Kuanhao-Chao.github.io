---
import '../styles/shorkie.css';

const chapters = [
  {
    title: 'Compress sequence without discarding local detail',
    body: 'An initial convolution and seven residual downsampling stages turn 16,384 DNA positions into 128 positions with 384 channels. Multi-resolution skip paths retain local sequence features for decoding.',
    marker: 'Encode',
  },
  {
    title: 'Exchange information across the full window',
    body: 'Eight Transformer blocks, using four attention heads in the released configuration, operate at the compressed representation where distant positions can interact efficiently.',
    marker: 'Context',
  },
  {
    title: 'Use one trunk for two learning objectives',
    body: 'Pretraining restores A/C/G/T probabilities at every base. Fine-tuning keeps the learned trunk but predicts 5,215 regulatory tracks across 896 interior bins, each representing 16 bp.',
    marker: 'Decode',
  },
] as const;
---

<section class="shk-story shk-architecture" data-shorkie-scrolly data-stage="0" aria-label="Shorkie model architecture from DNA input to language-model and regulatory outputs">
  <header class="shk-story-head">
    <h3 class="shk-story-title">Inside the Shorkie model</h3>
    <button class="shk-replay" type="button" data-shorkie-replay aria-label="Replay the current transition" title="Replay transition">↻</button>
  </header>

  <div class="shk-story-grid">
    <div class="shk-stage-figure">
      <div class="shk-canvas">
        <svg viewBox="0 0 760 470" role="img" aria-label="Cumulative diagram of the Shorkie encoder, Transformer, and two decoder heads">
          <defs>
            <marker id="shk-arch-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto">
              <path d="M0 0 L10 5 L0 10z" fill="#3976a8" />
            </marker>
            <marker id="shk-arch-arrow-orange" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto">
              <path d="M0 0 L10 5 L0 10z" fill="#b26b32" />
            </marker>
          </defs>

          <g class="shk-layer is-visible" data-visible-from="0" data-print-final>
            <text x="380" y="31" class="shk-note">ONE PRETRAINED TRUNK, TWO DECODING OBJECTIVES</text>

            <g transform="translate(25 176)">
              <text x="72" y="-34" class="shk-note">DNA WINDOW</text>
              <rect x="0" y="-13" width="144" height="54" rx="4" fill="#3976a8" fill-opacity=".08" stroke="#3976a8" stroke-width="2" />
              <text x="72" y="10" class="shk-dna">A C T G A C</text>
              <text x="72" y="30" class="shk-note">16,384 positions</text>
            </g>

            <path d="M172 190 H208" fill="none" stroke="#3976a8" stroke-width="3" marker-end="url(#shk-arch-arrow)" />

            <g>
              <text x="282" y="116" class="shk-note">CONVOLUTIONAL ENCODER</text>
              <rect x="210" y="142" width="142" height="24" rx="3" fill="#2f8069" fill-opacity=".08" stroke="#2f8069" />
              <rect x="220" y="175" width="122" height="24" rx="3" fill="#2f8069" fill-opacity=".11" stroke="#2f8069" />
              <rect x="231" y="208" width="100" height="24" rx="3" fill="#2f8069" fill-opacity=".14" stroke="#2f8069" />
              <rect x="242" y="241" width="78" height="24" rx="3" fill="#2f8069" fill-opacity=".17" stroke="#2f8069" />
              <rect x="252" y="274" width="58" height="24" rx="3" fill="#2f8069" fill-opacity=".2" stroke="#2f8069" />
              <text x="281" y="326" class="shk-note">7 downsampling stages</text>
            </g>

            <g>
              <rect x="365" y="166" width="116" height="76" rx="5" fill="#2f8069" fill-opacity=".12" stroke="#2f8069" stroke-width="3" />
              <text x="423" y="198" class="shk-label">128 × 384</text>
              <text x="423" y="222" class="shk-note">features</text>
              <path d="M310 286 C340 347 477 347 506 286" fill="none" stroke="#b07d00" stroke-width="3" stroke-dasharray="5 5" />
              <text x="408" y="374" class="shk-note" style="fill:#9a7000">multi-resolution U-Net skips</text>
            </g>
          </g>

          <g class="shk-layer" data-visible-from="1" data-print-final>
            <path d="M482 204 H512" fill="none" stroke="#3976a8" stroke-width="3" marker-end="url(#shk-arch-arrow)" />
            <g>
              <rect x="516" y="142" width="112" height="124" rx="6" fill="#6f62a8" fill-opacity=".1" stroke="#6f62a8" stroke-width="3" />
              {Array.from({ length: 8 }, (_, i) => (
                <rect
                  x={532 + (i % 2) * 42}
                  y={157 + Math.floor(i / 2) * 23}
                  width="32"
                  height="16"
                  rx="2"
                  fill="#6f62a8"
                  fill-opacity={0.18 + i * 0.035}
                />
              ))}
              <text x="572" y="292" class="shk-label">Transformer × 8</text>
              <text x="572" y="315" class="shk-note">4 attention heads</text>
              <path d="M534 129 Q572 84 610 129 M540 118 Q572 96 604 118" fill="none" stroke="#6f62a8" stroke-width="2" />
              <circle cx="534" cy="129" r="4" fill="#6f62a8" />
              <circle cx="572" cy="103" r="4" fill="#6f62a8" />
              <circle cx="610" cy="129" r="4" fill="#6f62a8" />
            </g>
          </g>

          <g class="shk-layer" data-visible-from="2" data-print-final>
            <path d="M628 176 C660 176 649 98 676 98" fill="none" stroke="#b26b32" stroke-width="3" marker-end="url(#shk-arch-arrow-orange)" />
            <path d="M628 232 C660 232 649 354 676 354" fill="none" stroke="#2f8069" stroke-width="3" marker-end="url(#shk-arch-arrow)" />

            <g>
              <text x="676" y="55" class="shk-note">PRETRAIN</text>
              <rect x="676" y="72" width="66" height="54" rx="4" fill="#b26b32" fill-opacity=".11" stroke="#b26b32" stroke-width="2" />
              <text x="709" y="94" class="shk-label">7× up</text>
              <text x="709" y="114" class="shk-note">softmax</text>
              <text x="709" y="149" class="shk-note">16,384 × 4</text>
              <text x="709" y="169" class="shk-dna">A C G T</text>
            </g>

            <g>
              <text x="676" y="304" class="shk-note">FINE-TUNE</text>
              <rect x="676" y="326" width="66" height="54" rx="4" fill="#2f8069" fill-opacity=".11" stroke="#2f8069" stroke-width="2" />
              <text x="709" y="348" class="shk-label">3× up</text>
              <text x="709" y="368" class="shk-note">Softplus</text>
              <text x="709" y="404" class="shk-note">896 × 5,215</text>
              <path d="M679 440 l9-12 9 7 9-22 9 15 9-30 9 42" fill="none" stroke="#2f8069" stroke-width="3" />
              <text x="709" y="462" class="shk-note">16 bp bins</text>
            </g>
          </g>
        </svg>
      </div>

      <div class="shk-markers" aria-hidden="true">
        {chapters.map((chapter, index) => (
          <span class:list={['shk-marker', { 'is-active': index === 0 }]} data-shorkie-marker>{chapter.marker}</span>
        ))}
      </div>
    </div>

    <ol class="shk-chapters">
      {chapters.map((chapter, index) => (
        <li class:list={['shk-chapter', { 'is-active': index === 0 }]} data-shorkie-stage={index} tabindex="0">
          <span class="shk-chapter-index">0{index + 1}</span>
          <h3>{chapter.title}</h3>
          <p>{chapter.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<script>
  import { mountShorkieScrolly } from '../scripts/shorkieScrolly';

  function bootShorkieArchitecture() {
    document.querySelectorAll<HTMLElement>('.shk-architecture').forEach(mountShorkieScrolly);
  }

  bootShorkieArchitecture();
  document.addEventListener('astro:page-load', bootShorkieArchitecture);
</script>
