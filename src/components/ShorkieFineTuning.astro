---
import '../styles/lvz.css';
import '../styles/shorkie.css';

const steps = [
  ['Start from the fungal language model', 'Fine-tuning restores the pretrained encoder, Transformer bottleneck, and retained decoder layers, then replaces the language-model output head.'],
  ['Predict the well-supported interior', 'Three upsampling stages create 1,024 bins at 16 bp resolution. Cropping 64 bins from each edge leaves 896 bins, or 14,336 bp.'],
  ['Unify 5,215 experimental tracks', 'The output combines 3,053 induction RNA-seq, 1,014 strain RNA-seq, 1,128 ChIP-exo, and 20 histone-modification tracks.'],
  ['Fit profiles and total counts', 'A combined Poisson and multinomial objective learns both the amount of signal and its spatial distribution; eight folds provide held-out predictions.'],
  ['Train a matched control', 'Shorkie_Random_Init uses the same architecture and supervised data but starts from random weights, isolating the contribution of fungal pretraining.'],
  ['Ensemble strand and shift predictions', 'Inference averages forward and reverse-complement predictions at shifts 0 and 1 before coverage profiles are summarized over genes.'],
] as const;
const C = ['#6f62a8', '#3976a8', '#b26b32', '#2f8069', '#b04755', '#b07d00'];

function block(x: number, y: number, w: number, h: number, title: string, detail: string, color: string, focus: boolean) { return `<g opacity="${focus ? 1 : 0.28}"><rect x="${x}" y="${y}" width="${w}" height="${h}" rx="5" fill="${color}" fill-opacity="0.1" stroke="${color}" stroke-width="${focus ? 2.8 : 1.2}"/><text x="${x + w / 2}" y="${y + h / 2 - 6}" class="shk-label" fill="${color}">${title}</text><text x="${x + w / 2}" y="${y + h / 2 + 16}" class="shk-detail">${detail}</text></g>`; }

function desktop(step: number) {
  const data = [['pretrained trunk', 'encoder · Transformer · decoder'], ['16 bp output grid', '1,024 → crop → 896 bins'], ['5,215 tracks', 'RNA · binding · chromatin'], ['joint objective', 'Poisson + multinomial'], ['random-init twin', 'same supervised architecture'], ['prediction ensemble', 'strand × shifts {0,1}']];
  let s = `<text x="20" y="27" class="lvz-tl">Transfer fungal sequence learning to yeast regulation</text>`;
  data.forEach(([title, detail], i) => { const x = 12 + i * 150; s += block(x, 82, 135, 102, title, detail, C[i], i === step); if (i < 5) s += `<path d="M${x + 135} 133 H${x + 150}" class="shk-arrow"/><path d="M${x + 143} 127 l7 6-7 6" class="shk-arrow"/>`; });
  const bars = [70, 110, 46, 135, 90, 55, 120, 76, 35, 102, 64, 126];
  s += `<rect x="95" y="218" width="730" height="112" rx="5" class="shk-card"/><line x1="130" y1="300" x2="790" y2="300" class="shk-grid"/>`;
  bars.forEach((h, i) => { const color = i < 7 ? '#3976a8' : i < 10 ? '#b26b32' : '#2f8069'; s += `<rect x="${145 + i * 51}" y="${300 - h * 0.45}" width="27" height="${h * 0.45}" fill="${color}" opacity="${step === 2 || step === 5 ? 0.85 : 0.35}"/>`; });
  s += `<text x="460" y="244" class="shk-label">Step ${step + 1}</text><text x="460" y="322" class="shk-detail">positive predicted coverage across the 14,336 bp interior</text>`;
  return `<svg viewBox="0 0 920 350" class="lvz-svg" role="img" aria-label="Shorkie supervised fine-tuning, step ${step + 1}">${s}</svg>`;
}

function mobile(step: number) {
  const data = [['restore pretrained trunk', 'encoder · Transformer · retained decoder'], ['decode and crop', '1,024 bins → 896 bins · 16 bp'], ['predict 5,215 tracks', '3,053 + 1,014 + 1,128 + 20'], ['train eight folds', 'Poisson + multinomial loss'], ['random-init control', 'identical architecture and targets'], ['ensemble inference', 'forward/reverse × shifts {0,1}']];
  let s = ''; data.forEach(([title, detail], i) => { s += block(18, 14 + i * 70, 324, 54, title, detail, C[i], i === step); if (i < 5) s += `<path d="M180 ${68 + i * 70} V${82 + i * 70}" class="shk-arrow"/>`; }); return `<svg viewBox="0 0 360 435" class="lvz-svg" role="img" aria-label="Shorkie supervised fine-tuning, step ${step + 1}">${s}</svg>`;
}
---

<section class="lvz shk shk-finetuning" role="group" aria-label="Interactive: fine-tuning Shorkie on yeast regulatory assays" data-print-final-state="true">
  <div class="lvz-head"><p class="lvz-title">Fine-tune on yeast regulatory assays</p><span class="lvz-tag">5,215 tracks</span></div>
  <p class="lvz-caption" data-wgi-caption aria-live="polite">{steps[0][1]}</p>
  <nav class="lvz-progress" aria-label="Fine-tuning steps">{steps.map(([title], i) => <button type="button" class="lvz-jump" data-wgi-jump aria-label={`Step ${i + 1}: ${title}`} title={title}>{i + 1}</button>)}</nav>
  {steps.map(([title, caption], i) => <div class="lvz-step" data-wgi-step data-print-final={i === 5 ? 'true' : undefined} data-caption={caption} hidden={i !== 0}><p class="lvz-steptitle"><span class="lvz-num">{i + 1}</span>{title}</p><div class="lvz-fig lvz-visual--desktop" set:html={desktop(i)} /><div class="lvz-fig lvz-visual--mobile" set:html={mobile(i)} /></div>)}
  <div class="lvz-controls"><button type="button" class="lvz-btn" data-wgi-prev>← Prev</button><button type="button" class="lvz-btn" data-wgi-play aria-pressed="false"><span data-wgi-play-icon>▶</span> <span data-wgi-play-label>Play</span></button><button type="button" class="lvz-btn" data-wgi-next>Next →</button><button type="button" class="lvz-btn" data-wgi-reset>↺ Restart</button><span class="lvz-pos" data-wgi-pos>1 / {steps.length}</span></div>
</section>

<script>
  import { mountStepper } from '../scripts/wgiStepper';
  function boot() { for (const root of document.querySelectorAll<HTMLElement>('.shk-finetuning')) { if (root.dataset.ready === 'true') continue; root.dataset.ready = 'true'; const all = Array.from(root.querySelectorAll<HTMLElement>('[data-wgi-step]')); mountStepper(root, { total: all.length, onShow: (i) => all.forEach((el, k) => el.hidden = k !== i), caption: (i) => all[i]?.dataset.caption || '', interval: 7000 }); } }
  boot(); document.addEventListener('astro:page-load', boot);
</script>
