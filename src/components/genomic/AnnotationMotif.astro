---
/**
 * Genome annotation (LiftOn): annotated reference exons transfer onto a
 * shifted target genome track, then resolve into the target gene model.
 */
interface Props { class?: string }
const { class: className } = Astro.props;
const exons = [
  { refX: 24, targetX: 34, w: 22, dx: '45.45%', delay: '0s' },
  { refX: 67, targetX: 76, w: 18, dx: '50%', delay: '0.35s' },
  { refX: 108, targetX: 114, w: 24, dx: '25%', delay: '0.7s' },
];
---
<svg class:list={['motif', 'motif-an', className]} viewBox="0 0 160 100" fill="none" aria-hidden="true">
  <line class="an-axis an-axis--ref" x1="16" y1="30" x2="144" y2="30" />
  {exons.map((exon) => (
    <rect class="an-ref-feat" x={exon.refX} y="24" width={exon.w} height="12" rx="2" />
  ))}

  <line class="an-axis an-axis--target" x1="16" y1="74" x2="144" y2="74" />
  {exons.map((exon) => (
    <path
      class="an-guide an-guide--base"
      d={`M${exon.refX + exon.w / 2} 36 C ${exon.refX + exon.w / 2} 50 ${exon.targetX + exon.w / 2} 52 ${exon.targetX + exon.w / 2} 68`}
    />
  ))}
  {exons.map((exon) => (
    <path
      class="an-guide an-guide--flow"
      pathLength="1"
      d={`M${exon.refX + exon.w / 2} 36 C ${exon.refX + exon.w / 2} 50 ${exon.targetX + exon.w / 2} 52 ${exon.targetX + exon.w / 2} 68`}
      style={`--an-delay: ${exon.delay};`}
    />
  ))}

  {exons.map((exon) => (
    <rect
      class="an-target-ghost"
      x={exon.targetX}
      y="68"
      width={exon.w}
      height="12"
      rx="2"
    />
  ))}
  {exons.map((exon) => (
    <rect
      class="an-target-feat"
      x={exon.targetX}
      y="68"
      width={exon.w}
      height="12"
      rx="2"
      style={`--an-delay: ${exon.delay};`}
    />
  ))}
  {exons.map((exon) => (
    <g
      class="an-copy"
      style={`--an-dx: ${exon.dx}; --an-delay: ${exon.delay};`}
    >
      <rect x={exon.refX} y="24" width={exon.w} height="12" rx="2" />
    </g>
  ))}
</svg>

<style>
  .motif {
    width: 100%;
    height: 100%;
    display: block;
    --motif-ink: color-mix(in srgb, var(--color-ink) 55%, transparent);
    --an-duration: 5.2s;
    --an-dy: 366.67%;
  }
  .an-axis {
    stroke: var(--motif-ink);
    stroke-width: 1.35;
    stroke-linecap: round;
  }
  .an-axis--target {
    opacity: 0.6;
  }
  .an-ref-feat {
    fill: color-mix(in srgb, var(--color-ink) 12%, transparent);
    stroke: var(--motif-ink);
    stroke-width: 1.2;
  }
  .an-guide {
    fill: none;
    stroke: var(--color-accent);
    stroke-linecap: round;
  }
  .an-guide--base {
    stroke-width: 1;
    stroke-dasharray: 2.4 3.2;
    opacity: 0.28;
  }
  .an-guide--flow {
    stroke-width: 1.5;
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    opacity: 0;
  }
  .an-target-ghost {
    fill: color-mix(in srgb, var(--color-accent) 7%, transparent);
    stroke: color-mix(in srgb, var(--color-accent) 55%, transparent);
    stroke-width: 1.15;
    stroke-dasharray: 3 2.2;
  }
  .an-target-feat {
    fill: color-mix(in srgb, var(--color-accent) 16%, transparent);
    stroke: var(--color-accent);
    stroke-width: 1.35;
    opacity: 0;
  }
  .an-copy {
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
  }
  .an-copy rect {
    fill: color-mix(in srgb, var(--color-accent) 20%, transparent);
    stroke: var(--color-accent);
    stroke-width: 1.35;
  }
  @media (prefers-reduced-motion: no-preference) {
    .motif-an:hover .an-guide--flow,
    :global(.rcard:hover) .motif-an .an-guide--flow,
    :global(.research-motif:hover) .motif-an .an-guide--flow {
      animation: an-guide-flow var(--an-duration) ease-in-out infinite;
      animation-delay: var(--an-delay);
    }
    .motif-an:hover .an-target-feat,
    :global(.rcard:hover) .motif-an .an-target-feat,
    :global(.research-motif:hover) .motif-an .an-target-feat {
      animation: an-target-fill var(--an-duration) ease-in-out infinite;
      animation-delay: var(--an-delay);
    }
    .motif-an:hover .an-copy,
    :global(.rcard:hover) .motif-an .an-copy,
    :global(.research-motif:hover) .motif-an .an-copy {
      animation: an-copy-transfer var(--an-duration) ease-in-out infinite;
      animation-delay: var(--an-delay);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .an-guide--flow,
    .an-copy {
      display: none;
    }
    .an-target-feat {
      opacity: 1;
    }
  }
  @keyframes an-guide-flow {
    0%, 8% {
      opacity: 0;
      stroke-dashoffset: 1;
    }
    12% {
      opacity: 0.85;
    }
    42% {
      opacity: 0.85;
      stroke-dashoffset: 0;
    }
    58%, 100% {
      opacity: 0;
      stroke-dashoffset: 0;
    }
  }
  @keyframes an-copy-transfer {
    0%, 8% {
      opacity: 0;
      transform: translate(0, 0) scale(0.94);
    }
    12% {
      opacity: 1;
      transform: translate(0, 0) scale(1);
    }
    44% {
      opacity: 1;
      transform: translate(var(--an-dx), var(--an-dy)) scale(1);
    }
    54%, 100% {
      opacity: 0;
      transform: translate(var(--an-dx), var(--an-dy)) scale(0.94);
    }
  }
  @keyframes an-target-fill {
    0%, 42% {
      opacity: 0;
    }
    50%, 86% {
      opacity: 1;
    }
    96%, 100% {
      opacity: 0;
    }
  }
</style>
