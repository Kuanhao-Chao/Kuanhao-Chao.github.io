---
/**
 * RNA splicing (Splam / OpenSpliceAI): three exon blocks joined by two introns
 * with sequence scanning, splice-site prediction peaks, and junction pairing.
 */
interface Props { class?: string }
const { class: className } = Astro.props;

const baseClasses = ['a', 'c', 'g', 't'];
const seqTicks = Array.from({ length: 33 }, (_, i) => ({
  x: 18 + i * 3.875,
  h: [5.5, 7, 4.5, 6.5][i % 4],
  base: baseClasses[i % 4],
}));

const scorePeaks = [
  { kind: 'donor', d: 'M34 52 C39 52 41 43 44 38 C47 43 49 52 54 52' },
  { kind: 'acceptor', d: 'M56 52 C61 52 63 43 66 38 C69 43 71 52 76 52' },
  { kind: 'donor', d: 'M84 52 C89 52 91 43 94 38 C97 43 99 52 104 52' },
  { kind: 'acceptor', d: 'M106 52 C111 52 113 43 116 38 C119 43 121 52 126 52' },
];
---
<svg class:list={['motif', 'motif-sp', className]} viewBox="0 0 160 100" fill="none" aria-hidden="true">
  <g transform="translate(0 -15)">
    <g class="sp-seq">
      <line class="sp-seq-axis" x1="16" y1="86" x2="144" y2="86" />
      {seqTicks.map((tick) => (
        <line
          class:list={['sp-base', `sp-base--${tick.base}`]}
          x1={tick.x}
          y1={86 - tick.h / 2}
          x2={tick.x}
          y2={86 + tick.h / 2}
        />
      ))}
    </g>

    <rect class="sp-window" x="12" y="80" width="36" height="12" rx="2.5" />

    <g class="sp-scores">
      {scorePeaks.map((peak) => (
        <path
          class:list={['sp-score', `sp-score--${peak.kind}`]}
          pathLength="1"
          d={peak.d}
        />
      ))}
    </g>

    <g class="sp-left">
      <rect class="sp-exon" x="16" y="58" width="28" height="20" rx="2" />
    </g>

    <path class="sp-intron sp-intron--first" pathLength="1" d="M44 68 C51 68 59 68 66 68" />

    <g class="sp-mid">
      <rect class="sp-exon" x="66" y="58" width="28" height="20" rx="2" />
    </g>

    <path class="sp-intron sp-intron--second" pathLength="1" d="M94 68 C101 68 109 68 116 68" />

    <g class="sp-right">
      <rect class="sp-exon" x="116" y="58" width="28" height="20" rx="2" />
    </g>

    <path class="sp-junction" pathLength="1" d="M44 58 Q55 34 66 58" />
    <path class="sp-junction" pathLength="1" d="M94 58 Q105 34 116 58" />
  </g>
</svg>

<style>
  .motif {
    width: 100%;
    height: 100%;
    display: block;
    --motif-ink: color-mix(in srgb, var(--color-ink) 55%, transparent);
    --sp-duration: 5.2s;
    --sp-merge-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --sp-scan-ease: cubic-bezier(0.33, 1, 0.68, 1);
    --sp-score-ease: cubic-bezier(0.16, 1, 0.3, 1);
    --sp-pair-ease: cubic-bezier(0.3, 0, 0.2, 1);
    --sp-fade-ease: cubic-bezier(0.4, 0, 0.2, 1);
    --sp-donor: color-mix(in srgb, var(--color-accent) 72%, #3869b1);
    --sp-acceptor: #a84945;
  }
  .sp-seq,
  .sp-window,
  .sp-score {
    transform-box: view-box;
  }
  .sp-seq {
    opacity: 0.66;
  }
  .sp-seq-axis {
    stroke: color-mix(in srgb, var(--motif-ink) 70%, transparent);
    stroke-width: 1;
    stroke-linecap: round;
  }
  .sp-base {
    stroke-width: 1.15;
    stroke-linecap: round;
    opacity: 0.74;
  }
  .sp-base--a {
    stroke: color-mix(in srgb, var(--sp-donor) 78%, var(--motif-ink));
  }
  .sp-base--c {
    stroke: color-mix(in srgb, var(--sp-acceptor) 72%, var(--motif-ink));
  }
  .sp-base--g {
    stroke: color-mix(in srgb, var(--color-accent) 68%, var(--motif-ink));
  }
  .sp-base--t {
    stroke: color-mix(in srgb, #aa6f22 72%, var(--motif-ink));
  }
  .sp-window {
    fill: color-mix(in srgb, var(--color-accent) 12%, transparent);
    stroke: color-mix(in srgb, var(--color-accent) 70%, transparent);
    stroke-width: 1.1;
    opacity: 0;
    transform: translateX(0);
  }
  .sp-score {
    fill: none;
    stroke-width: 1.55;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    opacity: 0;
  }
  .sp-score--donor {
    stroke: var(--sp-donor);
  }
  .sp-score--acceptor {
    stroke: var(--sp-acceptor);
  }
  .sp-exon {
    fill: color-mix(in srgb, var(--color-accent) 16%, transparent);
    stroke: var(--color-accent);
    stroke-width: 1.4;
  }
  .sp-right,
  .sp-left,
  .sp-intron {
    transform-box: view-box;
  }
  .sp-left,
  .sp-right {
    transform: translateX(0);
  }
  .sp-intron {
    --sp-rest-opacity: 0.82;
    --sp-mid-opacity: 0.38;
    fill: none;
    stroke: var(--motif-ink);
    stroke-width: 1.45;
    stroke-linecap: round;
    opacity: var(--sp-rest-opacity);
  }
  .sp-junction {
    --sp-rest-opacity: 0.36;
    --sp-pulse-opacity: 0.92;
    fill: none;
    stroke: color-mix(in srgb, var(--color-accent) 75%, transparent);
    stroke-width: 1.35;
    stroke-linecap: round;
    stroke-linejoin: round;
    opacity: var(--sp-rest-opacity);
  }
  @media (prefers-reduced-motion: no-preference) {
    .sp-seq {
      will-change: opacity;
    }
    .sp-window {
      will-change: opacity, transform;
    }
    .sp-score {
      will-change: opacity, stroke-dashoffset;
    }
    .sp-left,
    .sp-right {
      will-change: transform;
    }
    .sp-intron,
    .sp-junction {
      will-change: opacity;
    }
    .motif-sp:hover .sp-left,
    :global(.rcard:hover) .motif-sp .sp-left,
    :global(.research-motif:hover) .motif-sp .sp-left {
      animation: sp-left-join var(--sp-duration) var(--sp-merge-ease) forwards;
    }
    .motif-sp:hover .sp-right,
    :global(.rcard:hover) .motif-sp .sp-right,
    :global(.research-motif:hover) .motif-sp .sp-right {
      animation: sp-right-join var(--sp-duration) var(--sp-merge-ease) forwards;
    }
    .motif-sp:hover .sp-seq,
    :global(.rcard:hover) .motif-sp .sp-seq,
    :global(.research-motif:hover) .motif-sp .sp-seq {
      animation: sp-seq-settle var(--sp-duration) var(--sp-fade-ease) forwards;
    }
    .motif-sp:hover .sp-window,
    :global(.rcard:hover) .motif-sp .sp-window,
    :global(.research-motif:hover) .motif-sp .sp-window {
      animation: sp-window-scan var(--sp-duration) var(--sp-scan-ease) forwards;
    }
    .motif-sp:hover .sp-score,
    :global(.rcard:hover) .motif-sp .sp-score,
    :global(.research-motif:hover) .motif-sp .sp-score {
      animation: sp-score-draw var(--sp-duration) var(--sp-score-ease) forwards;
    }
    .motif-sp:hover .sp-intron--first,
    :global(.rcard:hover) .motif-sp .sp-intron--first,
    :global(.research-motif:hover) .motif-sp .sp-intron--first {
      animation: sp-intron-excise var(--sp-duration) var(--sp-fade-ease) forwards;
    }
    .motif-sp:hover .sp-intron--second,
    :global(.rcard:hover) .motif-sp .sp-intron--second,
    :global(.research-motif:hover) .motif-sp .sp-intron--second {
      animation: sp-intron-excise var(--sp-duration) var(--sp-fade-ease) forwards;
    }
    .motif-sp:hover .sp-junction,
    :global(.rcard:hover) .motif-sp .sp-junction,
    :global(.research-motif:hover) .motif-sp .sp-junction {
      animation: sp-junction-pair var(--sp-duration) var(--sp-pair-ease) forwards;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .sp-left,
    .sp-right {
      transform: translateX(0);
    }
    .sp-intron {
      opacity: var(--sp-rest-opacity);
    }
    .sp-junction {
      opacity: var(--sp-rest-opacity);
    }
    .sp-window {
      opacity: 0.14;
      transform: translateX(46px);
    }
    .sp-score {
      opacity: 0.5;
      stroke-dashoffset: 0;
    }
  }
  @keyframes sp-left-join {
    0%, 38% {
      transform: translateX(0);
    }
    46% {
      transform: translateX(10px);
    }
    50%, 100% {
      transform: translateX(22px);
    }
  }
  @keyframes sp-right-join {
    0%, 38% {
      transform: translateX(0);
    }
    46% {
      transform: translateX(-10px);
    }
    50%, 100% {
      transform: translateX(-22px);
    }
  }
  @keyframes sp-seq-settle {
    0%, 46% {
      opacity: 0.66;
    }
    50%, 100% {
      opacity: 0.32;
    }
  }
  @keyframes sp-window-scan {
    0%, 12% {
      opacity: 0;
      transform: translateX(0);
    }
    16% {
      opacity: 0.78;
      transform: translateX(0);
    }
    28% {
      opacity: 0.78;
      transform: translateX(96px);
    }
    38% {
      opacity: 0;
      transform: translateX(96px);
    }
    50%, 100% {
      opacity: 0.1;
      transform: translateX(96px);
    }
  }
  @keyframes sp-score-draw {
    0%, 22% {
      opacity: 0;
      stroke-dashoffset: 1;
    }
    28% {
      opacity: 0.82;
      stroke-dashoffset: 0.55;
    }
    38% {
      opacity: 0.9;
      stroke-dashoffset: 0;
    }
    50%, 100% {
      opacity: 0.2;
      stroke-dashoffset: 0;
    }
  }
  @keyframes sp-intron-excise {
    0%, 38% {
      opacity: var(--sp-rest-opacity);
    }
    46% {
      opacity: var(--sp-mid-opacity);
    }
    50%, 100% {
      opacity: 0;
    }
  }
  @keyframes sp-junction-pair {
    0%, 34% {
      opacity: var(--sp-rest-opacity);
    }
    42%, 46% {
      opacity: var(--sp-pulse-opacity);
    }
    50%, 100% {
      opacity: 0;
    }
  }
</style>
