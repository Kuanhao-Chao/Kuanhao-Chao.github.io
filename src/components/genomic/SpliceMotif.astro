---
/**
 * RNA splicing (Splam / OpenSpliceAI): three exon blocks joined by two introns
 * that are removed together on hover as the exons splice together.
 */
interface Props { class?: string }
const { class: className } = Astro.props;
---
<svg class:list={['motif', 'motif-sp', className]} viewBox="0 0 160 100" fill="none" aria-hidden="true">
  <g class="sp-left">
    <rect class="sp-exon" x="16" y="58" width="28" height="20" rx="2" />
  </g>

  <path class="sp-intron sp-intron--first" pathLength="1" d="M44 68 C51 68 59 68 66 68" />

  <g class="sp-mid">
    <rect class="sp-exon" x="66" y="58" width="28" height="20" rx="2" />
  </g>

  <path class="sp-intron sp-intron--second" pathLength="1" d="M94 68 C101 68 109 68 116 68" />

  <g class="sp-right">
    <rect class="sp-exon" x="116" y="58" width="28" height="20" rx="2" />
  </g>
</svg>

<style>
  .motif {
    width: 100%;
    height: 100%;
    display: block;
    --motif-ink: color-mix(in srgb, var(--color-ink) 55%, transparent);
    --sp-duration: 5.2s;
  }
  .sp-exon {
    fill: color-mix(in srgb, var(--color-accent) 16%, transparent);
    stroke: var(--color-accent);
    stroke-width: 1.4;
  }
  .sp-right,
  .sp-left,
  .sp-intron {
    transform-box: view-box;
  }
  .sp-left,
  .sp-right {
    transform: translateX(0);
  }
  .sp-intron {
    fill: none;
    stroke: var(--motif-ink);
    stroke-width: 1.45;
    stroke-linecap: round;
    opacity: 0.82;
  }
  @media (prefers-reduced-motion: no-preference) {
    .motif-sp:hover .sp-left,
    :global(.rcard:hover) .motif-sp .sp-left,
    :global(.research-motif:hover) .motif-sp .sp-left {
      animation: sp-left-join var(--sp-duration) ease-in-out forwards;
    }
    .motif-sp:hover .sp-right,
    :global(.rcard:hover) .motif-sp .sp-right,
    :global(.research-motif:hover) .motif-sp .sp-right {
      animation: sp-right-join var(--sp-duration) ease-in-out forwards;
    }
    .motif-sp:hover .sp-intron--first,
    :global(.rcard:hover) .motif-sp .sp-intron--first,
    :global(.research-motif:hover) .motif-sp .sp-intron--first {
      animation: sp-intron-excise var(--sp-duration) ease-in-out forwards;
    }
    .motif-sp:hover .sp-intron--second,
    :global(.rcard:hover) .motif-sp .sp-intron--second,
    :global(.research-motif:hover) .motif-sp .sp-intron--second {
      animation: sp-intron-excise var(--sp-duration) ease-in-out forwards;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .sp-left,
    .sp-right {
      transform: translateX(0);
    }
    .sp-intron {
      opacity: 0.82;
    }
  }
  @keyframes sp-left-join {
    0%, 38% {
      transform: translateX(0);
    }
    48%, 100% {
      transform: translateX(22px);
    }
  }
  @keyframes sp-right-join {
    0%, 38% {
      transform: translateX(0);
    }
    48%, 100% {
      transform: translateX(-22px);
    }
  }
  @keyframes sp-intron-excise {
    0%, 10% {
      opacity: 0.82;
    }
    18%, 100% {
      opacity: 0;
    }
  }
</style>
