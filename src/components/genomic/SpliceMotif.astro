---
/**
 * RNA splicing (Splam / OpenSpliceAI): a pre-mRNA transcript model whose
 * introns are removed as neighboring exons glide into a mature transcript.
 */
interface Props { class?: string }
const { class: className } = Astro.props;

const exons = [
  { className: 'sp-left', x: 20, width: 30 },
  { className: 'sp-mid', x: 65, width: 30 },
  { className: 'sp-right', x: 110, width: 30 },
];
---
<svg class:list={['motif', 'motif-sp', className]} viewBox="0 0 160 100" fill="none" aria-hidden="true">
  <g class="sp-transcript">
    <line class="sp-rail" x1="18" y1="58" x2="142" y2="58" />
    <path class="sp-intron sp-intron--first" pathLength="1" d="M50 58 C55 58 60 58 65 58" />
    <path class="sp-intron sp-intron--second" pathLength="1" d="M95 58 C100 58 105 58 110 58" />

    <path class="sp-junction sp-junction--first" pathLength="1" d="M50 46 C54 30 61 30 65 46" />
    <path class="sp-junction sp-junction--second" pathLength="1" d="M95 46 C99 30 106 30 110 46" />

    {exons.map((exon) => (
      <g class:list={['sp-exon-wrap', exon.className]}>
        <rect class="sp-exon" x={exon.x} y="46" width={exon.width} height="24" rx="3" />
      </g>
    ))}
  </g>
</svg>

<style>
  .motif {
    width: 100%;
    height: 100%;
    display: block;
    --motif-ink: color-mix(in srgb, var(--color-ink) 55%, transparent);
    --sp-duration: 3.2s;
    --sp-ease: cubic-bezier(0.42, 0, 0.2, 1);
    --sp-fade-ease: cubic-bezier(0.4, 0, 0.2, 1);
  }
  .sp-transcript {
    transform-box: view-box;
    transform-origin: center;
  }
  .sp-rail,
  .sp-intron,
  .sp-junction {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .sp-rail {
    stroke: var(--motif-ink);
    stroke-width: 1.15;
    opacity: 0.26;
  }
  .sp-intron {
    stroke: color-mix(in srgb, var(--motif-ink) 86%, transparent);
    stroke-width: 1.5;
    stroke-dasharray: 1;
    stroke-dashoffset: 0;
    opacity: 0.82;
  }
  .sp-junction {
    stroke: color-mix(in srgb, var(--color-accent) 78%, transparent);
    stroke-width: 1.45;
    stroke-dasharray: 1;
    stroke-dashoffset: 0;
    opacity: 0.38;
  }
  .sp-exon-wrap {
    transform-box: view-box;
    transform: translateX(0);
  }
  .sp-exon {
    fill: color-mix(in srgb, var(--color-accent) 16%, var(--color-bg));
    stroke: var(--color-accent);
    stroke-width: 1.35;
  }

  @media (prefers-reduced-motion: no-preference) {
    .sp-exon-wrap {
      will-change: transform;
    }
    .sp-intron,
    .sp-junction {
      will-change: opacity, stroke-dashoffset;
    }
    .motif-sp:hover .sp-left,
    :global(.rcard:hover) .motif-sp .sp-left,
    :global(.research-motif:hover) .motif-sp .sp-left {
      animation: sp-left-splice var(--sp-duration) var(--sp-ease) forwards;
    }
    .motif-sp:hover .sp-right,
    :global(.rcard:hover) .motif-sp .sp-right,
    :global(.research-motif:hover) .motif-sp .sp-right {
      animation: sp-right-splice var(--sp-duration) var(--sp-ease) forwards;
    }
    .motif-sp:hover .sp-intron,
    :global(.rcard:hover) .motif-sp .sp-intron,
    :global(.research-motif:hover) .motif-sp .sp-intron {
      animation: sp-intron-remove var(--sp-duration) var(--sp-fade-ease) forwards;
    }
    .motif-sp:hover .sp-junction,
    :global(.rcard:hover) .motif-sp .sp-junction,
    :global(.research-motif:hover) .motif-sp .sp-junction {
      animation: sp-junction-fade var(--sp-duration) var(--sp-fade-ease) forwards;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sp-junction {
      opacity: 0.38;
      stroke-dashoffset: 0;
    }
  }

  @keyframes sp-left-splice {
    0% {
      transform: translateX(0);
    }
    86%, 100% {
      transform: translateX(15px);
    }
  }
  @keyframes sp-right-splice {
    0% {
      transform: translateX(0);
    }
    86%, 100% {
      transform: translateX(-15px);
    }
  }
  @keyframes sp-intron-remove {
    0%, 18% {
      opacity: 0.82;
      stroke-dashoffset: 0;
    }
    82%, 100% {
      opacity: 0;
      stroke-dashoffset: 1;
    }
  }
  @keyframes sp-junction-fade {
    0% {
      opacity: 0.38;
      stroke-dashoffset: 0;
    }
    6%, 100% {
      opacity: 0;
      stroke-dashoffset: 0;
    }
  }
</style>
