---
/**
 * Genome assembly (Han1): scattered sequencing reads that resolve into a single
 * contiguous contig, which "builds" left-to-right on hover.
 */
interface Props { class?: string }
const { class: className } = Astro.props;
const reads = [
  { x: 22, y: 22, w: 42 },
  { x: 76, y: 22, w: 34 },
  { x: 40, y: 38, w: 38 },
  { x: 92, y: 38, w: 44 },
  { x: 28, y: 54, w: 50 },
  { x: 86, y: 54, w: 42 },
];
---
<svg class:list={['motif', 'motif-as', className]} viewBox="0 0 160 100" fill="none" aria-hidden="true">
  {reads.map((r) => <rect class="as-read" x={r.x} y={r.y} width={r.w} height="8" rx="3" />)}
  <rect class="as-contig" x="20" y="74" width="120" height="12" rx="3" />
</svg>

<style>
  .motif {
    width: 100%;
    height: 100%;
    display: block;
    --motif-ink: color-mix(in srgb, var(--color-ink) 55%, transparent);
  }
  .as-read {
    fill: color-mix(in srgb, var(--color-ink) 14%, transparent);
    stroke: var(--motif-ink);
    stroke-width: 1;
  }
  .as-contig {
    fill: color-mix(in srgb, var(--color-accent) 18%, transparent);
    stroke: var(--color-accent);
    stroke-width: 1.4;
    transform-box: view-box;
    transform-origin: 20px 80px;
  }
  @media (prefers-reduced-motion: no-preference) {
    .motif-as:hover .as-contig { animation: as-build 3.2s ease-in-out infinite; }
    .motif-as:hover .as-read { animation: as-pulse 3.2s ease-in-out infinite; }
    .motif-as:hover .as-read:nth-of-type(2) { animation-delay: 0.15s; }
    .motif-as:hover .as-read:nth-of-type(3) { animation-delay: 0.3s; }
    .motif-as:hover .as-read:nth-of-type(4) { animation-delay: 0.45s; }
    .motif-as:hover .as-read:nth-of-type(5) { animation-delay: 0.6s; }
    .motif-as:hover .as-read:nth-of-type(6) { animation-delay: 0.75s; }
  }
  @keyframes as-build {
    0% { transform: scaleX(0); }
    45%, 100% { transform: scaleX(1); }
  }
  @keyframes as-pulse {
    0%, 100% { opacity: 0.55; }
    50% { opacity: 1; }
  }
</style>
