---
/**
 * Gene expression / Shorkie: a compact genome-browser style locus.
 * A subtle scanner reads the regulatory region and the predicted RNA-seq
 * coverage track rises over the target gene.
 */
interface Props { class?: string }
const { class: className } = Astro.props;

const regulatoryMarks = [
  { x: 25, h: 10, delay: '0s' },
  { x: 36, h: 18, delay: '0.12s' },
  { x: 48, h: 13, delay: '0.24s' },
];
const exons = [
  { x: 75, w: 14 },
  { x: 99, w: 18 },
  { x: 129, w: 13 },
];
---
<svg class:list={['motif', 'motif-gx', className]} viewBox="0 0 160 100" fill="none" aria-hidden="true">
  <rect class="gx-scan" x="22" y="21" width="34" height="58" rx="4" />

  <g class="gx-coverage">
    <line class="gx-axis gx-axis--coverage" x1="15" y1="56" x2="146" y2="56" />
    <path
      class="gx-area"
      d="M15 56 C26 56 31 54 37 53 C45 52 48 41 56 40 C66 39 70 52 78 51 C87 50 91 43 98 43 C107 43 108 26 119 25 C130 24 134 40 140 41 C144 42 146 39 146 39 L146 56 L15 56 Z"
    />
    <path
      class="gx-curve"
      pathLength="1"
      d="M15 56 C26 56 31 54 37 53 C45 52 48 41 56 40 C66 39 70 52 78 51 C87 50 91 43 98 43 C107 43 108 26 119 25 C130 24 134 40 140 41 C144 42 146 39 146 39"
    />
  </g>

  <g class="gx-locus">
    <line class="gx-axis" x1="15" y1="72" x2="146" y2="72" />
    {regulatoryMarks.map((mark) => (
      <rect
        class="gx-reg-mark"
        x={mark.x}
        y={72 - mark.h}
        width="5"
        height={mark.h}
        rx="2.5"
        style={`--gx-delay: ${mark.delay};`}
      />
    ))}
    {exons.map((exon) => (
      <rect class="gx-exon" x={exon.x} y="66" width={exon.w} height="12" rx="2" />
    ))}
    <path class="gx-gene-arrow" d="M75 72 H145 M139 67 L146 72 L139 77" />
  </g>
</svg>

<style>
  .motif {
    width: 100%;
    height: 100%;
    display: block;
    --motif-ink: color-mix(in srgb, var(--color-ink) 55%, transparent);
    --gx-duration: 4.6s;
  }
  .gx-axis,
  .gx-curve,
  .gx-gene-arrow {
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .gx-axis {
    stroke: var(--motif-ink);
    stroke-width: 1.2;
    opacity: 0.34;
  }
  .gx-axis--coverage {
    opacity: 0.25;
  }
  .gx-scan {
    fill: color-mix(in srgb, var(--color-accent) 8%, transparent);
    stroke: color-mix(in srgb, var(--color-accent) 42%, transparent);
    stroke-width: 1;
    opacity: 0.32;
    transform-box: view-box;
  }
  .gx-area {
    fill: color-mix(in srgb, var(--color-accent) 15%, transparent);
    opacity: 0.78;
    transform-box: view-box;
    transform-origin: bottom;
  }
  .gx-curve {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 2;
  }
  .gx-reg-mark {
    fill: color-mix(in srgb, var(--color-accent) 22%, var(--color-bg));
    stroke: var(--color-accent);
    stroke-width: 1.1;
    transform-box: fill-box;
    transform-origin: bottom;
  }
  .gx-exon {
    fill: color-mix(in srgb, var(--color-accent) 16%, var(--color-bg));
    stroke: var(--color-accent);
    stroke-width: 1.15;
  }
  .gx-gene-arrow {
    fill: none;
    stroke: color-mix(in srgb, var(--color-accent) 70%, transparent);
    stroke-width: 1.3;
  }

  @media (prefers-reduced-motion: no-preference) {
    .motif-gx:hover .gx-scan,
    :global(.rcard:hover) .motif-gx .gx-scan,
    :global(.research-motif:hover) .motif-gx .gx-scan {
      animation: gx-scan-locus var(--gx-duration) ease-in-out infinite;
    }
    .motif-gx:hover .gx-reg-mark,
    :global(.rcard:hover) .motif-gx .gx-reg-mark,
    :global(.research-motif:hover) .motif-gx .gx-reg-mark {
      animation: gx-mark-pulse var(--gx-duration) ease-in-out infinite;
      animation-delay: var(--gx-delay);
    }
    .motif-gx:hover .gx-area,
    :global(.rcard:hover) .motif-gx .gx-area,
    :global(.research-motif:hover) .motif-gx .gx-area {
      animation: gx-coverage-rise var(--gx-duration) ease-in-out infinite;
    }
    .motif-gx:hover .gx-curve,
    :global(.rcard:hover) .motif-gx .gx-curve,
    :global(.research-motif:hover) .motif-gx .gx-curve {
      animation: gx-coverage-draw var(--gx-duration) ease-in-out infinite;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .gx-scan {
      opacity: 0.34;
      transform: translateX(66px);
    }
    .gx-area,
    .gx-curve,
    .gx-reg-mark {
      opacity: 0.86;
    }
  }
  @keyframes gx-scan-locus {
    0%, 10% {
      opacity: 0;
      transform: translateX(0);
    }
    22%, 62% {
      opacity: 0.72;
    }
    72%, 100% {
      opacity: 0;
      transform: translateX(68px);
    }
  }
  @keyframes gx-mark-pulse {
    0%, 24%, 100% {
      transform: scaleY(1);
      opacity: 0.9;
    }
    14% {
      transform: scaleY(1.22);
      opacity: 1;
    }
  }
  @keyframes gx-coverage-rise {
    0%, 28% {
      opacity: 0.24;
      transform: scaleY(0.18);
    }
    58%, 100% {
      opacity: 0.78;
      transform: scaleY(1);
    }
  }
  @keyframes gx-coverage-draw {
    0%, 28% {
      stroke-dashoffset: 1;
      opacity: 0.28;
    }
    58%, 100% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
  }
</style>
