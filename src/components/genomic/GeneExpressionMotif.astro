---
/**
 * Gene expression / Shorkie: a compact genome-browser style locus with an
 * explicit TATA box motif upstream of the target gene and noisy RNA-seq signal.
 */
interface Props { class?: string }
const { class: className } = Astro.props;

const tataBases = ['T', 'A', 'T', 'A', 'A', 'A'];
const exons = [
  { x: 72, w: 16 },
  { x: 100, w: 23 },
  { x: 132, w: 15 },
];
const coverageBaseline = 45;
const coverageCurve =
  `M70 ${coverageBaseline} ` +
  'C77.1 45 80.3 43.7 84.1 43.1 ' +
  'C89.2 42.4 91.2 35.3 96.3 34.6 ' +
  'C102.7 34 105.3 42.4 110.4 41.8 ' +
  'C116.2 41.1 118.7 36.6 123.2 36.6 ' +
  'C129 36.6 129.6 25.5 136.7 24.9 ' +
  'C143.7 24.2 146.3 34.6 150.2 35.3 ' +
  'C152.7 35.9 154 34 154 34';
const coverageArea = `${coverageCurve} L154 ${coverageBaseline} L70 ${coverageBaseline} Z`;
---
<svg class:list={['motif', 'motif-gx', className]} viewBox="0 0 160 100" fill="none" aria-hidden="true">
  <g class="gx-coverage">
    <line class="gx-axis gx-axis--coverage" x1="9" y1="45" x2="154" y2="45" />
    <g class="gx-coverage-signal">
      <path class="gx-area" d={coverageArea} />
      <path class="gx-curve" pathLength="1" d={coverageCurve} />
    </g>
  </g>

  <g class="gx-locus">
    <line class="gx-axis" x1="9" y1="73" x2="154" y2="73" />
    <path class="gx-gene-arrow" d="M70 73 H154 M148 68 L156 73 L148 78" />
    <g class="gx-tata" aria-hidden="true">
      <rect class="gx-tata-box" x="11" y="62" width="54" height="21" rx="4.5" />
      {tataBases.map((base, index) => (
        <text class="gx-tata-base" x={17 + index * 7.2} y="76.1">{base}</text>
      ))}
    </g>
    {exons.map((exon) => (
      <rect class="gx-exon" x={exon.x} y="66" width={exon.w} height="14" rx="2.2" />
    ))}
  </g>
</svg>

<style>
  .motif {
    width: 100%;
    height: 100%;
    display: block;
    --motif-ink: color-mix(in srgb, var(--color-ink) 55%, transparent);
    --gx-duration: 3.6s;
  }
  .gx-axis,
  .gx-curve,
  .gx-gene-arrow {
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .gx-axis {
    stroke: var(--motif-ink);
    stroke-width: 1.2;
    opacity: 0.34;
  }
  .gx-axis--coverage {
    opacity: 0.25;
  }
  .gx-coverage-signal {
    opacity: 0;
    transform: scaleY(0.05);
    transform-box: fill-box;
    transform-origin: center bottom;
  }
  .gx-area {
    fill: color-mix(in srgb, var(--color-accent) 22%, transparent);
    opacity: 0.84;
  }
  .gx-curve {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 2.1;
  }
  .gx-tata {
    transform-box: fill-box;
    transform-origin: center;
  }
  .gx-tata-box {
    fill: color-mix(in srgb, var(--color-accent) 11%, var(--color-bg));
    stroke: color-mix(in srgb, var(--color-accent) 58%, transparent);
    stroke-width: 1.15;
  }
  .gx-tata-base {
    fill: var(--color-accent);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace;
    font-size: 9.4px;
    font-weight: 750;
    letter-spacing: 0;
    opacity: 0.92;
    paint-order: stroke;
    pointer-events: none;
    stroke: color-mix(in srgb, var(--color-bg) 72%, transparent);
    stroke-width: 0.45;
  }
  .gx-exon {
    fill: color-mix(in srgb, var(--color-accent) 16%, var(--color-bg));
    stroke: var(--color-accent);
    stroke-width: 1.15;
  }
  .gx-gene-arrow {
    fill: none;
    stroke: color-mix(in srgb, var(--color-accent) 70%, transparent);
    stroke-width: 1.3;
    opacity: 0.82;
  }

  @media (prefers-reduced-motion: no-preference) {
    .motif-gx:hover .gx-tata,
    :global(.rcard:hover) .motif-gx .gx-tata,
    :global(.research-motif:hover) .motif-gx .gx-tata {
      animation: gx-tata-pulse var(--gx-duration) ease-in-out infinite;
    }
    .motif-gx:hover .gx-tata-box,
    :global(.rcard:hover) .motif-gx .gx-tata-box,
    :global(.research-motif:hover) .motif-gx .gx-tata-box {
      animation: gx-tata-box-pulse var(--gx-duration) ease-in-out infinite;
    }
    .motif-gx:hover .gx-tata-base,
    :global(.rcard:hover) .motif-gx .gx-tata-base,
    :global(.research-motif:hover) .motif-gx .gx-tata-base {
      animation: gx-tata-base-pulse var(--gx-duration) ease-in-out infinite;
    }
    .motif-gx:hover .gx-coverage-signal,
    :global(.rcard:hover) .motif-gx .gx-coverage-signal,
    :global(.research-motif:hover) .motif-gx .gx-coverage-signal {
      animation: gx-coverage-pop var(--gx-duration) ease-in-out infinite;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .gx-tata-box {
      fill: color-mix(in srgb, var(--color-accent) 14%, var(--color-bg));
    }
    .gx-coverage-signal {
      opacity: 0.92;
      transform: scaleY(1);
    }
  }
  @keyframes gx-tata-pulse {
    0%, 100% {
      transform: scale(1);
    }
    48% {
      transform: scale(1.035);
    }
  }
  @keyframes gx-tata-box-pulse {
    0%, 100% {
      fill: color-mix(in srgb, var(--color-accent) 11%, var(--color-bg));
      stroke: color-mix(in srgb, var(--color-accent) 58%, transparent);
    }
    48% {
      fill: color-mix(in srgb, var(--color-accent) 24%, var(--color-bg));
      stroke: color-mix(in srgb, var(--color-accent) 100%, transparent);
    }
  }
  @keyframes gx-tata-base-pulse {
    0%, 100% {
      opacity: 0.92;
    }
    48% {
      opacity: 1;
    }
  }
  @keyframes gx-coverage-pop {
    0%, 16% {
      opacity: 0;
      transform: scaleY(0.05);
    }
    34%, 76% {
      opacity: 0.92;
      transform: scaleY(1);
    }
    100% {
      opacity: 0;
      transform: scaleY(0.05);
    }
  }
</style>
