---
/**
 * Gene expression / Shorkie: a minimal sequence-to-function motif.
 * DNA regulatory marks flow through a compact model and become one expression trace.
 */
interface Props { class?: string }
const { class: className } = Astro.props;
const regulatoryMarks = [
  { x: 30, y: 37, h: 26, delay: '0s' },
  { x: 43, y: 34, h: 32, delay: '0.12s' },
  { x: 56, y: 39, h: 22, delay: '0.24s' },
];
---
<svg class:list={['motif', 'motif-gx', className]} viewBox="0 0 160 100" fill="none" aria-hidden="true">
  <g class="gx-dna">
    <path class="gx-strand" d="M14 44 C24 39 34 49 44 44 S64 39 74 44" />
    <path class="gx-strand" d="M14 56 C24 61 34 51 44 56 S64 61 74 56" />
    <path class="gx-rungs" d="M20 46 L20 54 M32 43 L32 57 M44 45 L44 55 M56 43 L56 57 M68 46 L68 54" />
    {regulatoryMarks.map((mark) => (
      <rect
        class="gx-reg-mark"
        x={mark.x}
        y={mark.y}
        width="6"
        height={mark.h}
        rx="3"
        style={`--gx-delay: ${mark.delay};`}
      />
    ))}
  </g>

  <path class="gx-flow gx-flow--input" pathLength="1" d="M74 50 C79 50 82 50 86 50" />

  <g class="gx-model">
    <rect class="gx-model-box" x="84" y="35" width="30" height="30" rx="7" />
    <circle class="gx-node" cx="93" cy="45" r="2" />
    <circle class="gx-node" cx="105" cy="50" r="2" />
    <circle class="gx-node" cx="93" cy="55" r="2" />
    <path class="gx-link" d="M95 45 L103 50 L95 55" />
  </g>

  <path class="gx-flow gx-flow--output" pathLength="1" d="M114 50 C120 50 119 72 125 72" />

  <g class="gx-expression">
    <line class="gx-axis" x1="120" y1="76" x2="149" y2="76" />
    <path class="gx-area" d="M120 76 C124 74 126 64 131 63 C136 62 139 48 144 47 C147 47 149 53 150 56 L150 76 Z" />
    <path
      class="gx-curve"
      pathLength="1"
      d="M120 76 C124 74 126 64 131 63 C136 62 139 48 144 47 C147 47 149 53 150 56"
    />
  </g>
</svg>

<style>
  .motif {
    width: 100%;
    height: 100%;
    display: block;
    --motif-ink: color-mix(in srgb, var(--color-ink) 55%, transparent);
    --gx-duration: 4.4s;
  }
  .gx-strand,
  .gx-rungs,
  .gx-axis,
  .gx-link {
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .gx-strand {
    fill: none;
    stroke: var(--motif-ink);
    stroke-width: 1.55;
    opacity: 0.58;
  }
  .gx-rungs {
    fill: none;
    stroke: var(--motif-ink);
    stroke-width: 1.25;
    opacity: 0.38;
  }
  .gx-reg-mark {
    fill: color-mix(in srgb, var(--color-accent) 16%, var(--color-bg));
    stroke: var(--color-accent);
    stroke-width: 1.25;
    transform-box: fill-box;
    transform-origin: center;
  }
  .gx-flow {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 1.45;
    stroke-linecap: round;
    stroke-dasharray: 1;
    stroke-dashoffset: 0;
    opacity: 0.5;
  }
  .gx-model {
    transform-box: view-box;
    transform-origin: center;
  }
  .gx-model-box {
    fill: color-mix(in srgb, var(--color-accent) 10%, var(--color-bg));
    stroke: var(--color-accent);
    stroke-width: 1.45;
  }
  .gx-node {
    fill: color-mix(in srgb, var(--color-bg) 74%, white);
    stroke: var(--color-accent);
    stroke-width: 1.05;
  }
  .gx-link {
    fill: none;
    stroke: color-mix(in srgb, var(--color-accent) 70%, transparent);
    stroke-width: 1.2;
  }
  .gx-expression {
    transform-box: view-box;
    transform-origin: center;
  }
  .gx-axis {
    stroke: var(--motif-ink);
    stroke-width: 1.15;
    opacity: 0.32;
  }
  .gx-area {
    fill: color-mix(in srgb, var(--color-accent) 13%, transparent);
    opacity: 0.7;
  }
  .gx-curve {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 1.9;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media (prefers-reduced-motion: no-preference) {
    .motif-gx:hover .gx-reg-mark,
    :global(.rcard:hover) .motif-gx .gx-reg-mark,
    :global(.research-motif:hover) .motif-gx .gx-reg-mark {
      animation: gx-mark-read var(--gx-duration) ease-in-out infinite;
      animation-delay: var(--gx-delay);
    }
    .motif-gx:hover .gx-flow,
    :global(.rcard:hover) .motif-gx .gx-flow,
    :global(.research-motif:hover) .motif-gx .gx-flow {
      animation: gx-send var(--gx-duration) ease-in-out infinite;
    }
    .motif-gx:hover .gx-model,
    :global(.rcard:hover) .motif-gx .gx-model,
    :global(.research-motif:hover) .motif-gx .gx-model {
      animation: gx-model-pulse var(--gx-duration) ease-in-out infinite;
    }
    .motif-gx:hover .gx-expression,
    :global(.rcard:hover) .motif-gx .gx-expression,
    :global(.research-motif:hover) .motif-gx .gx-expression {
      animation: gx-expression-lift var(--gx-duration) ease-in-out infinite;
    }
    .motif-gx:hover .gx-curve,
    :global(.rcard:hover) .motif-gx .gx-curve,
    :global(.research-motif:hover) .motif-gx .gx-curve {
      animation: gx-curve-draw var(--gx-duration) ease-in-out infinite;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .gx-flow,
    .gx-reg-mark,
    .gx-area,
    .gx-curve {
      opacity: 0.82;
    }
  }
  @keyframes gx-mark-read {
    0%, 30%, 100% {
      opacity: 0.88;
      transform: scaleY(1);
    }
    14% {
      opacity: 1;
      transform: scaleY(1.14);
    }
  }
  @keyframes gx-send {
    0%, 10% {
      opacity: 0;
      stroke-dashoffset: 1;
    }
    28%, 76% {
      opacity: 0.88;
      stroke-dashoffset: 0;
    }
    100% {
      opacity: 0.5;
      stroke-dashoffset: 0;
    }
  }
  @keyframes gx-model-pulse {
    0%, 100% {
      transform: scale(1);
    }
    40% {
      transform: scale(1.04);
    }
  }
  @keyframes gx-expression-lift {
    0%, 30%, 100% {
      transform: translateY(0);
    }
    54%, 72% {
      transform: translateY(-2px);
    }
  }
  @keyframes gx-curve-draw {
    0%, 24% {
      stroke-dashoffset: 1;
    }
    52%, 100% {
      stroke-dashoffset: 0;
    }
  }
</style>
