---
/**
 * Gene expression / Shorkie: a compact genome-browser style locus with an
 * explicit TATA box motif upstream of the target gene and noisy RNA-seq signal.
 */
interface Props { class?: string }
const { class: className } = Astro.props;

const tataBases = ['T', 'A', 'T', 'A', 'A', 'A'];
const exons = [
  { className: 'gx-exon--first', x: 63, w: 14 },
  { className: 'gx-exon--middle', x: 90, w: 22 },
  { className: 'gx-exon--third', x: 121, w: 12 },
];
const coverageBaseline = 41.5;
const coverageCurve =
  `M60 ${coverageBaseline} ` +
  'C61.5 40.8 62.2 35.4 64.2 30.6 ' +
  'C66.5 25.2 70.8 23.7 73.6 25.4 ' +
  'C76.2 27 77.4 34.1 79.8 38.1 ' +
  'C82.8 39.3 86.1 38.8 88.8 35.9 ' +
  'C91.6 27.2 94.4 19.4 99.1 18 ' +
  'C104.1 16.5 109.1 18.8 111.8 24.3 ' +
  'C114.5 30.4 116.6 36.9 119.4 38.5 ' +
  'C121.3 37.7 123.4 32.4 126.3 30.6 ' +
  'C129.7 28.7 132.6 31.6 134.6 35.7 ' +
  `C136.2 38.7 137.9 40.8 140 ${coverageBaseline}`;
const coverageArea = `${coverageCurve} L140 ${coverageBaseline} L60 ${coverageBaseline} Z`;
---
<svg class:list={['motif', 'motif-gx', className]} viewBox="0 0 160 100" fill="none" aria-hidden="true">
  <g class="gx-coverage">
    <line class="gx-axis gx-axis--coverage" x1="54" y1={coverageBaseline} x2="142" y2={coverageBaseline} />
    <g class="gx-coverage-signal">
      <path class="gx-area" d={coverageArea} />
      <path class="gx-curve" pathLength="1" d={coverageCurve} />
    </g>
  </g>

  <g class="gx-locus">
    <line class="gx-axis" x1="18" y1="70" x2="145" y2="70" />
    <path class="gx-gene-arrow" d="M60 70 H143 M137 65 L145 70 L137 75" />
    <g class="gx-tata" aria-hidden="true">
      {tataBases.map((base, index) => (
        <text class="gx-tata-base" x={27.5 + index * 5.5} y="70">{base}</text>
      ))}
    </g>
    {exons.map((exon) => (
      <rect class:list={['gx-exon', exon.className]} x={exon.x} y="64" width={exon.w} height="12" rx="2" />
    ))}
  </g>
</svg>

<style>
  .motif {
    width: 100%;
    height: 100%;
    display: block;
    --motif-ink: color-mix(in srgb, var(--color-ink) 55%, transparent);
    --gx-duration: 3.6s;
  }
  .gx-axis,
  .gx-curve,
  .gx-gene-arrow {
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .gx-axis {
    stroke: var(--motif-ink);
    stroke-width: 1.2;
    opacity: 0.34;
  }
  .gx-axis--coverage {
    opacity: 0.25;
  }
  .gx-coverage-signal {
    opacity: 0;
    transform: scaleY(0.05);
    transform-box: fill-box;
    transform-origin: center bottom;
  }
  .gx-area {
    fill: color-mix(in srgb, var(--color-accent) 22%, transparent);
    opacity: 0.84;
  }
  .gx-curve {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 2.1;
  }
  .gx-tata {
    transform-box: fill-box;
    transform-origin: center;
  }
  .gx-tata-base {
    fill: var(--color-accent);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace;
    font-size: 7.5px;
    font-weight: 750;
    letter-spacing: 0;
    opacity: 0.92;
    paint-order: stroke;
    pointer-events: none;
    stroke: color-mix(in srgb, var(--color-bg) 72%, transparent);
    stroke-width: 0.45;
    text-anchor: middle;
    dominant-baseline: middle;
  }
  .gx-exon {
    fill: color-mix(in srgb, var(--color-accent) 16%, var(--color-bg));
    stroke: var(--color-accent);
    stroke-width: 1.15;
  }
  .gx-exon--middle {
    fill: color-mix(in srgb, var(--color-accent) 22%, var(--color-bg));
  }
  .gx-gene-arrow {
    fill: none;
    stroke: color-mix(in srgb, var(--color-accent) 70%, transparent);
    stroke-width: 1.3;
    opacity: 0.82;
  }

  @media (prefers-reduced-motion: no-preference) {
    .motif-gx:hover .gx-tata,
    :global(.rcard:hover) .motif-gx .gx-tata,
    :global(.research-motif:hover) .motif-gx .gx-tata {
      animation: gx-tata-pulse var(--gx-duration) ease-in-out infinite;
    }
    .motif-gx:hover .gx-tata-base,
    :global(.rcard:hover) .motif-gx .gx-tata-base,
    :global(.research-motif:hover) .motif-gx .gx-tata-base {
      animation: gx-tata-base-pulse var(--gx-duration) ease-in-out infinite;
    }
    .motif-gx:hover .gx-coverage-signal,
    :global(.rcard:hover) .motif-gx .gx-coverage-signal,
    :global(.research-motif:hover) .motif-gx .gx-coverage-signal {
      animation: gx-coverage-pop var(--gx-duration) ease-in-out infinite;
    }
    .motif-gx:hover .gx-exon,
    :global(.rcard:hover) .motif-gx .gx-exon,
    :global(.research-motif:hover) .motif-gx .gx-exon {
      animation: gx-exon-pulse var(--gx-duration) ease-in-out infinite;
    }
    .motif-gx:hover .gx-exon--middle,
    :global(.rcard:hover) .motif-gx .gx-exon--middle,
    :global(.research-motif:hover) .motif-gx .gx-exon--middle {
      animation-name: gx-exon-middle-pulse;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .gx-coverage-signal {
      opacity: 0.92;
      transform: scaleY(1);
    }
  }
  @keyframes gx-tata-pulse {
    0%, 100% {
      transform: scale(1);
    }
    48% {
      transform: scale(1.035);
    }
  }
  @keyframes gx-tata-base-pulse {
    0%, 100% {
      opacity: 0.92;
    }
    48% {
      opacity: 1;
    }
  }
  @keyframes gx-coverage-pop {
    0%, 16% {
      opacity: 0;
      transform: scaleY(0.05);
    }
    34%, 76% {
      opacity: 0.92;
      transform: scaleY(1);
    }
    100% {
      opacity: 0;
      transform: scaleY(0.05);
    }
  }
  @keyframes gx-exon-pulse {
    0%, 100% {
      fill: color-mix(in srgb, var(--color-accent) 16%, var(--color-bg));
    }
    48% {
      fill: color-mix(in srgb, var(--color-accent) 22%, var(--color-bg));
    }
  }
  @keyframes gx-exon-middle-pulse {
    0%, 100% {
      fill: color-mix(in srgb, var(--color-accent) 22%, var(--color-bg));
    }
    48% {
      fill: color-mix(in srgb, var(--color-accent) 32%, var(--color-bg));
    }
  }
</style>
