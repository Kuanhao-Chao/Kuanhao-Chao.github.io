---
/**
 * Gene expression / Shorkie: a compact genome-browser style locus with an
 * explicit TATA box motif upstream of the target gene.
 */
interface Props { class?: string }
const { class: className } = Astro.props;

const tataBases = ['T', 'A', 'T', 'A', 'A', 'A'];
const exons = [
  { x: 75, w: 14 },
  { x: 99, w: 18 },
  { x: 125, w: 11 },
];
const fmt = (value: number) => Number(value.toFixed(1));
const coverageBaseline = 56;
const coverageHeights = [13, 21, 15];
const coverageSegments = exons.map((exon, index) => {
  const height = coverageHeights[index] ?? 14;
  const x0 = exon.x;
  const x1 = exon.x + exon.w;
  const xMid = exon.x + exon.w / 2;
  const xLeft = exon.x + exon.w * 0.28;
  const xRight = exon.x + exon.w * 0.72;
  const yPeak = coverageBaseline - height;
  const yShoulder = coverageBaseline - height * 0.62;
  const curve = `M${fmt(x0)} ${coverageBaseline} C${fmt(xLeft)} ${fmt(yShoulder)} ${fmt(xLeft)} ${fmt(yPeak)} ${fmt(xMid)} ${fmt(yPeak)} C${fmt(xRight)} ${fmt(yPeak)} ${fmt(xRight)} ${fmt(yShoulder)} ${fmt(x1)} ${coverageBaseline}`;

  return {
    area: `${curve} L${fmt(x1)} ${coverageBaseline} L${fmt(x0)} ${coverageBaseline} Z`,
    curve,
    delay: `${0.14 + index * 0.12}s`,
  };
});
---
<svg class:list={['motif', 'motif-gx', className]} viewBox="0 0 160 100" fill="none" aria-hidden="true">
  <g class="gx-coverage">
    <line class="gx-axis gx-axis--coverage" x1="15" y1="56" x2="146" y2="56" />
    {coverageSegments.map((segment) => (
      <g class="gx-coverage-segment" style={`--gx-delay: ${segment.delay};`}>
        <path class="gx-area" d={segment.area} />
        <path class="gx-curve" pathLength="1" d={segment.curve} />
      </g>
    ))}
  </g>

  <g class="gx-locus">
    <line class="gx-axis" x1="15" y1="72" x2="146" y2="72" />
    <path class="gx-gene-arrow" d="M73 72 H148 M142 67 L149 72 L142 77" />
    <g class="gx-tata" aria-hidden="true">
      <rect class="gx-tata-box" x="19" y="59" width="49" height="18" rx="4" />
      {tataBases.map((base, index) => (
        <text class="gx-tata-base" x={24 + index * 6.6} y="71.5">{base}</text>
      ))}
    </g>
    {exons.map((exon) => (
      <rect class="gx-exon" x={exon.x} y="66" width={exon.w} height="12" rx="2" />
    ))}
  </g>
</svg>

<style>
  .motif {
    width: 100%;
    height: 100%;
    display: block;
    --motif-ink: color-mix(in srgb, var(--color-ink) 55%, transparent);
    --gx-duration: 3.6s;
  }
  .gx-axis,
  .gx-curve,
  .gx-gene-arrow {
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .gx-axis {
    stroke: var(--motif-ink);
    stroke-width: 1.2;
    opacity: 0.34;
  }
  .gx-axis--coverage {
    opacity: 0.25;
  }
  .gx-coverage-segment {
    opacity: 0;
    transform: scaleY(0.05);
    transform-box: fill-box;
    transform-origin: center bottom;
  }
  .gx-area {
    fill: color-mix(in srgb, var(--color-accent) 22%, transparent);
    opacity: 0.84;
  }
  .gx-curve {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 2.1;
  }
  .gx-tata {
    transform-box: fill-box;
    transform-origin: center;
  }
  .gx-tata-box {
    fill: color-mix(in srgb, var(--color-accent) 11%, var(--color-bg));
    stroke: color-mix(in srgb, var(--color-accent) 58%, transparent);
    stroke-width: 1.15;
  }
  .gx-tata-base {
    fill: var(--color-accent);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace;
    font-size: 9.4px;
    font-weight: 750;
    letter-spacing: 0;
    opacity: 0.92;
    paint-order: stroke;
    pointer-events: none;
    stroke: color-mix(in srgb, var(--color-bg) 72%, transparent);
    stroke-width: 0.45;
  }
  .gx-exon {
    fill: color-mix(in srgb, var(--color-accent) 16%, var(--color-bg));
    stroke: var(--color-accent);
    stroke-width: 1.15;
  }
  .gx-gene-arrow {
    fill: none;
    stroke: color-mix(in srgb, var(--color-accent) 70%, transparent);
    stroke-width: 1.3;
    opacity: 0.82;
  }

  @media (prefers-reduced-motion: no-preference) {
    .motif-gx:hover .gx-tata,
    :global(.rcard:hover) .motif-gx .gx-tata,
    :global(.research-motif:hover) .motif-gx .gx-tata {
      animation: gx-tata-pulse var(--gx-duration) ease-in-out infinite;
    }
    .motif-gx:hover .gx-tata-box,
    :global(.rcard:hover) .motif-gx .gx-tata-box,
    :global(.research-motif:hover) .motif-gx .gx-tata-box {
      animation: gx-tata-box-pulse var(--gx-duration) ease-in-out infinite;
    }
    .motif-gx:hover .gx-tata-base,
    :global(.rcard:hover) .motif-gx .gx-tata-base,
    :global(.research-motif:hover) .motif-gx .gx-tata-base {
      animation: gx-tata-base-pulse var(--gx-duration) ease-in-out infinite;
    }
    .motif-gx:hover .gx-coverage-segment,
    :global(.rcard:hover) .motif-gx .gx-coverage-segment,
    :global(.research-motif:hover) .motif-gx .gx-coverage-segment {
      animation: gx-coverage-pop var(--gx-duration) ease-in-out infinite;
      animation-delay: var(--gx-delay);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .gx-tata-box {
      fill: color-mix(in srgb, var(--color-accent) 14%, var(--color-bg));
    }
    .gx-coverage-segment {
      opacity: 0.92;
      transform: scaleY(1);
    }
  }
  @keyframes gx-tata-pulse {
    0%, 100% {
      transform: scale(1);
    }
    48% {
      transform: scale(1.035);
    }
  }
  @keyframes gx-tata-box-pulse {
    0%, 100% {
      fill: color-mix(in srgb, var(--color-accent) 11%, var(--color-bg));
      stroke: color-mix(in srgb, var(--color-accent) 58%, transparent);
    }
    48% {
      fill: color-mix(in srgb, var(--color-accent) 24%, var(--color-bg));
      stroke: color-mix(in srgb, var(--color-accent) 100%, transparent);
    }
  }
  @keyframes gx-tata-base-pulse {
    0%, 100% {
      opacity: 0.92;
    }
    48% {
      opacity: 1;
    }
  }
  @keyframes gx-coverage-pop {
    0%, 16% {
      opacity: 0;
      transform: scaleY(0.05);
    }
    34%, 76% {
      opacity: 0.92;
      transform: scaleY(1);
    }
    100% {
      opacity: 0;
      transform: scaleY(0.05);
    }
  }
</style>
