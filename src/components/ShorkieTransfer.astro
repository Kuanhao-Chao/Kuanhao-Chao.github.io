---
import '../styles/lvz.css';
import '../styles/shorkie.css';

const steps = [
  ['Compress DNA across seven resolutions', 'An 11 nt convolution and seven residual downsampling stages turn 16,384 positions into 128 contextual positions with 384 channels.'],
  ['Let distant sequence positions communicate', 'Eight Transformer blocks operate at the bottleneck; the released configuration uses four attention heads, while U-Net skips preserve local detail.'],
  ['Pretrain by rebuilding the hidden bases', 'Seven upsampling stages restore single-base resolution and a softmax predicts A/C/G/T at all 16,384 positions.'],
  ['Replace reconstruction with regulatory prediction', 'Fine-tuning keeps the pretrained trunk, uses three upsampling stages, crops edge bins, and predicts 5,215 RNA, binding, and chromatin tracks at 16 bp resolution.'],
  ['Ensemble predictions into a coverage profile', 'Eight folds average forward/reverse-complement predictions at shifts 0 and 1, producing coverage that can be summarized over genes.'],
] as const;

const C = { dna: '#3976a8', encoder: '#2f8069', transformer: '#6f62a8', skip: '#b07d00', output: '#b26b32', variant: '#b04755' };

function encoderScene(mobile=false) {
  const w=mobile?360:920; const cx=w/2; let out=`<text x="${cx}" y="28" class="shk-kicker">16,384 bp sequence → progressively wider contextual features</text>`;
  if (mobile) {
    out+=`<text x="180" y="70" class="shk-dna" text-anchor="middle">A C T G A C C T G T A T G C A</text>`;
    const widths=[310,270,230,190,155,125,96,72]; widths.forEach((ww,i)=>{const y=95+i*37;out+=`<rect x="${180-ww/2}" y="${y}" width="${ww}" height="22" rx="3" fill="${C.encoder}" fill-opacity="${.08+i*.025}" stroke="${C.encoder}"/><text x="180" y="${y+15}" class="shk-mini">${i===0?'Conv1D · 96 channels':i===7?'128 positions · 384 channels':`${16384/2**i} positions`}</text>`;});
    out+=`<path d="M180 78 V92" class="shk-arrow"/><text x="180" y="405" class="shk-label" fill="${C.encoder}">7 residual downsampling stages</text>`;
  } else {
    out+=`<rect x="50" y="90" width="150" height="78" rx="6" fill="${C.dna}" fill-opacity=".1" stroke="${C.dna}" stroke-width="2"/><text x="125" y="120" class="shk-dna" text-anchor="middle">ACTGACCTGTATGCA</text><text x="125" y="148" class="shk-detail">16,384 × 170 LM input</text>`;
    const widths=[125,112,100,88,76,64,52]; widths.forEach((ww,i)=>{const x=245+i*82,y=80+i*35;out+=`<rect x="${x}" y="${y}" width="${ww}" height="34" rx="3" fill="${C.encoder}" fill-opacity="${.1+i*.03}" stroke="${C.encoder}" stroke-width="2"/><text x="${x+ww/2}" y="${y+22}" class="shk-mini">${16384/2**(i+1)}</text>${i<6?`<path d="M${x+ww} ${y+17} L${x+82} ${y+52}" class="shk-arrow"/>`:''}`;});
    out+=`<path d="M200 129 H238" class="shk-arrow"/><path d="M230 123 l8 6-8 6" class="shk-arrow"/><rect x="780" y="290" width="100" height="66" rx="5" fill="${C.encoder}" fill-opacity=".2" stroke="${C.encoder}" stroke-width="3"/><text x="830" y="316" class="shk-label">128 × 384</text><text x="830" y="339" class="shk-detail">bottleneck</text><text x="465" y="390" class="shk-label" fill="${C.encoder}">seven stages halve sequence length while increasing feature width</text>`;
  }
  return `<svg viewBox="0 0 ${w} ${mobile?430:420}" class="lvz-svg" role="img" aria-label="Shorkie convolutional encoder compressing sequence through seven resolutions">${out}</svg>`;
}

function transformerScene(mobile=false) {
  const w=mobile?360:920,cx=w/2; let out=`<text x="${cx}" y="28" class="shk-kicker">long-range context at the 128-position bottleneck</text>`;
  const boxW=mobile?62:92,gap=mobile?17:13,x0=mobile?22:70,y=mobile?220:195;
  for(let i=0;i<8;i+=1){const row=mobile?Math.floor(i/4):0,col=mobile?i%4:i,x=x0+col*(boxW+gap),yy=y+row*(mobile?58:0);out+=`<rect x="${x}" y="${yy}" width="${boxW}" height="${mobile?44:58}" rx="5" fill="${C.transformer}" fill-opacity="${.09+i*.015}" stroke="${C.transformer}" stroke-width="${i===3||i===4?2.5:1.2}"/><text x="${x+boxW/2}" y="${yy+(mobile?27:34)}" class="shk-label">${i+1}</text>`;}
  if(mobile){
    out=out.replace('long-range context at the 128-position bottleneck','eight Transformer blocks · four attention heads')+`<g transform="translate(20 62)"><rect width="320" height="105" rx="8" fill="${C.transformer}" fill-opacity=".08" stroke="${C.transformer}" stroke-width="2"/><circle cx="45" cy="65" r="8" fill="${C.dna}"/><circle cx="120" cy="42" r="8" fill="${C.dna}"/><circle cx="205" cy="68" r="8" fill="${C.dna}"/><circle cx="275" cy="35" r="8" fill="${C.dna}"/><path d="M45 65 Q120 2 205 68 M120 42 Q205 105 275 35 M45 65 Q170 125 275 35" fill="none" stroke="${C.transformer}" stroke-width="2" opacity=".75"/><text x="160" y="95" class="shk-detail">distant positions exchange context</text></g>`;
    out+=`<text x="180" y="345" class="shk-detail">Transformer blocks 1–8</text><path d="M55 375 C100 345,260 345,305 375" fill="none" stroke="${C.skip}" stroke-width="3"/><text x="180" y="405" class="shk-label" fill="${C.skip}">skip features bypass the bottleneck</text>`;
  }else{
    const pts=[130,270,410,550,690,830];pts.forEach((x,i)=>{out+=`<circle cx="${x}" cy="95" r="10" fill="${C.dna}"/><text x="${x}" y="72" class="shk-mini">position ${i*24+1}</text>`;});
    [[0,3],[1,5],[2,4],[0,5]].forEach(([a,b],i)=>{out+=`<path d="M${pts[a]} 95 Q${(pts[a]+pts[b])/2} ${35+i*14},${pts[b]} 95" fill="none" stroke="${C.transformer}" stroke-width="2" opacity="${.45+i*.12}"/>`;});
    out+=`<text x="460" y="135" class="shk-label" fill="${C.transformer}">four attention heads connect distant sequence positions</text><text x="460" y="300" class="shk-detail">Transformer blocks 1–8</text><path d="M95 345 C250 305,670 305,825 345" fill="none" stroke="${C.skip}" stroke-width="4"/><text x="460" y="375" class="shk-label" fill="${C.skip}">multi-resolution U-Net skips preserve local sequence detail</text>`;
  }
  return `<svg viewBox="0 0 ${w} ${mobile?420:410}" class="lvz-svg" role="img" aria-label="Eight Shorkie Transformer blocks with four-head attention and U-Net skips">${out}</svg>`;
}

function lmScene(mobile=false) {
  const w=mobile?360:920,cx=w/2;let out=`<text x="${cx}" y="28" class="shk-kicker">pretraining head restores one-base resolution</text>`;
  if(mobile){
    const widths=[72,96,125,155,190,230,270,310];widths.forEach((ww,i)=>{const y=55+i*32;out+=`<rect x="${180-ww/2}" y="${y}" width="${ww}" height="19" rx="3" fill="${C.output}" fill-opacity="${.2-i*.015}" stroke="${C.output}"/><text x="180" y="${y+13}" class="shk-mini">${i===0?'128 positions':i===7?'16,384 positions':`${128*2**i} positions`}</text>`;});
    out+=`<g transform="translate(40 335)"><text x="140" y="0" class="shk-label">A/C/G/T softmax at every base</text>${['A','C','G','T'].map((l,i)=>`<rect x="${45+i*50}" y="18" width="34" height="${[25,46,68,31][i]}" fill="${['#3976a8','#b04755','#2f8069','#b07d00'][i]}"/><text x="${62+i*50}" y="102" class="shk-label">${l}</text>`).join('')}</g>`;
  }else{
    const widths=[95,115,140,170,205,245,290];widths.forEach((ww,i)=>{const x=55+i*94,y=315-i*34;out+=`<rect x="${x}" y="${y}" width="${ww}" height="28" rx="3" fill="${C.output}" fill-opacity="${.18-i*.014}" stroke="${C.output}" stroke-width="2"/><text x="${x+ww/2}" y="${y+19}" class="shk-mini">${128*2**i} positions</text>`;});
    out+=`<path d="M740 110 H810" class="shk-arrow"/><path d="M802 104 l8 6-8 6" class="shk-arrow"/><g transform="translate(790 135)"><text x="55" y="0" class="shk-label">per-base softmax</text>${['A','C','G','T'].map((l,i)=>`<rect x="${i*28}" y="${75-[18,32,65,24][i]}" width="19" height="${[18,32,65,24][i]}" fill="${['#3976a8','#b04755','#2f8069','#b07d00'][i]}"/><text x="${i*28+9}" y="92" class="shk-mini">${l}</text>`).join('')}</g><text x="460" y="390" class="shk-label" fill="${C.output}">seven decoder stages: 128 → 16,384 positions</text>`;
  }
  return `<svg viewBox="0 0 ${w} ${mobile?450:420}" class="lvz-svg" role="img" aria-label="Shorkie language model decoder restoring base resolution and predicting nucleotides">${out}</svg>`;
}

function fineScene(mobile=false) {
  const w=mobile?360:920,cx=w/2;let out=`<text x="${cx}" y="28" class="shk-kicker">the pretrained trunk now predicts measured yeast regulation</text>`;
  const tracks=[['induction RNA-seq','3,053',C.dna],['strain RNA-seq','1,014',C.encoder],['ChIP-exo','1,128',C.transformer],['histone marks','20',C.output]];
  if(mobile){
    tracks.forEach(([name,n,color],i)=>{const y=58+i*48;out+=`<path d="M22 ${y+14} H120" stroke="${color}" stroke-width="${8+i*2}" opacity=".75"/><text x="130" y="${y+5}" class="shk-label shk-left" fill="${color}">${name}</text><text x="130" y="${y+23}" class="shk-detail shk-left">${n} tracks</text>`;});
    out+=`<path d="M180 245 V275" class="shk-arrow"/><rect x="65" y="278" width="230" height="58" rx="6" fill="${C.output}" fill-opacity=".1" stroke="${C.output}" stroke-width="2"/><text x="180" y="302" class="shk-label">3 decoder stages · Softplus</text><text x="180" y="322" class="shk-detail">1,024 bins → crop edges → 896 bins</text><g transform="translate(30 365)">${Array.from({length:14},(_,i)=>`<rect x="${i*21}" y="${36-[12,20,28,18,33,24,10,26,35,20,14,29,23,16][i]}" width="14" height="${[12,20,28,18,33,24,10,26,35,20,14,29,23,16][i]}" fill="${C.dna}" opacity=".8"/>`).join('')}<text x="147" y="58" class="shk-detail">16 bp regulatory coverage bins</text></g>`;
  }else{
    tracks.forEach(([name,n,color],i)=>{const y=75+i*72;out+=`<path d="M45 ${y+20} C170 ${y+20},205 205,330 205" fill="none" stroke="${color}" stroke-width="${10+i*2}" opacity=".72"/><text x="55" y="${y+8}" class="shk-label shk-left" fill="${color}">${name}</text><text x="55" y="${y+34}" class="shk-detail shk-left">${n} tracks</text>`;});
    out+=`<rect x="330" y="155" width="235" height="100" rx="8" fill="${C.output}" fill-opacity=".1" stroke="${C.output}" stroke-width="3"/><text x="447" y="188" class="shk-label">pretrained trunk + 3 decoder stages</text><text x="447" y="216" class="shk-detail">1,024 bins · crop 64 from each edge</text><text x="447" y="238" class="shk-detail">896 bins × 5,215 tracks · Softplus</text><path d="M565 205 H635" class="shk-arrow"/><path d="M627 199 l8 6-8 6" class="shk-arrow"/><g transform="translate(650 115)">${Array.from({length:14},(_,i)=>`<rect x="${i*15}" y="${100-[25,45,68,40,82,55,18,62,88,44,28,72,50,31][i]}" width="10" height="${[25,45,68,40,82,55,18,62,88,44,28,72,50,31][i]}" fill="${i<8?C.dna:i<11?C.encoder:C.transformer}" opacity=".82"/>`).join('')}<line x1="0" y1="100" x2="210" y2="100" class="shk-grid"/><text x="105" y="128" class="shk-label">predicted coverage</text><text x="105" y="150" class="shk-detail">14,336 bp interior · 16 bp bins</text></g>`;
  }
  return `<svg viewBox="0 0 ${w} ${mobile?455:420}" class="lvz-svg" role="img" aria-label="Shorkie fine-tuning from four assay categories to regulatory coverage tracks">${out}</svg>`;
}

function ensembleScene(mobile=false) {
  const w=mobile?360:920,cx=w/2;let out=`<text x="${cx}" y="28" class="shk-kicker">eight folds × two strands × two shifts → one stable profile</text>`;
  const boxW=mobile?64:72, gap=mobile?16:25, x0=mobile?28:65;
  for(let i=0;i<8;i+=1){const row=mobile?Math.floor(i/4):0,col=mobile?i%4:i,x=x0+col*(boxW+gap),y=mobile?60+row*62:80;out+=`<rect x="${x}" y="${y}" width="${boxW}" height="42" rx="5" fill="${C.transformer}" fill-opacity=".08" stroke="${C.transformer}"/><text x="${x+boxW/2}" y="${y+18}" class="shk-label">fold ${i+1}</text><text x="${x+boxW/2}" y="${y+33}" class="shk-mini">F/R · 0/1</text>`;}
  const mergeY=mobile?225:180;out+=`<path d="M${mobile?55:100} ${mobile?175:122} C${mobile?80:220} ${mergeY},${cx-35} ${mergeY},${cx-15} ${mergeY}" fill="none" stroke="${C.skip}" stroke-width="2"/><circle cx="${cx}" cy="${mergeY}" r="27" fill="${C.skip}" fill-opacity=".12" stroke="${C.skip}" stroke-width="2"/><text x="${cx}" y="${mergeY+5}" class="shk-label">mean</text><path d="M${cx+27} ${mergeY} H${cx+80}" class="shk-arrow"/>`;
  const base=mobile?390:340,start=mobile?28:565,profileW=mobile?304:300;const pts=Array.from({length:22},(_,i)=>{const xx=start+i*profileW/21;const h=15+55*Math.exp(-1*((i-7)/4)**2)+78*Math.exp(-1*((i-16)/3.2)**2);return `${xx},${base-h}`}).join(' ');out+=`<polygon points="${start},${base} ${pts} ${start+profileW},${base}" fill="${C.dna}" opacity=".65"/><line x1="${start}" y1="${base}" x2="${start+profileW}" y2="${base}" class="shk-grid"/><g transform="translate(${start} ${base+10})"><rect width="${profileW*.3}" height="16" fill="${C.encoder}"/><line x1="${profileW*.3}" y1="8" x2="${profileW*.48}" y2="8" stroke="${C.encoder}"/><rect x="${profileW*.48}" width="${profileW*.38}" height="16" fill="${C.encoder}"/><text x="${profileW/2}" y="38" class="shk-detail">gene exons and predicted RNA coverage</text></g>`;
  if(mobile)out+=`<path d="M180 252 V285" class="shk-arrow"/>`;
  return `<svg viewBox="0 0 ${w} ${mobile?450:420}" class="lvz-svg" role="img" aria-label="Eight-fold strand and shift ensemble producing a gene coverage profile">${out}</svg>`;
}

const desktopScenes=[encoderScene(),transformerScene(),lmScene(),fineScene(),ensembleScene()];
const mobileScenes=[encoderScene(true),transformerScene(true),lmScene(true),fineScene(true),ensembleScene(true)];
---

<section class="lvz shk shk-transfer" role="group" aria-label="Interactive: Shorkie architecture and transfer to regulatory prediction" data-print-final-state="true">
  <div class="lvz-head"><p class="lvz-title">Transfer sequence learning to expression</p><span class="lvz-tag">13.7M parameters</span></div>
  <p class="lvz-caption" data-wgi-caption aria-live="polite">{steps[0][1]}</p>
  <nav class="lvz-progress" aria-label="Architecture and transfer steps">{steps.map(([title],i)=><button type="button" class="lvz-jump" data-wgi-jump aria-label={`Step ${i+1}: ${title}`} title={title}>{i+1}</button>)}</nav>
  {steps.map(([title,caption],i)=><div class="lvz-step" data-wgi-step data-caption={caption} data-print-final={i===4?'true':undefined} hidden={i!==0}><p class="lvz-steptitle"><span class="lvz-num">{i+1}</span>{title}</p><div class="lvz-fig lvz-visual--desktop" set:html={desktopScenes[i]} /><div class="lvz-fig lvz-visual--mobile" set:html={mobileScenes[i]} /></div>)}
  <div class="lvz-controls"><button type="button" class="lvz-btn" data-wgi-prev>← Prev</button><button type="button" class="lvz-btn" data-wgi-play aria-pressed="false"><span data-wgi-play-icon>▶</span> <span data-wgi-play-label>Play</span></button><button type="button" class="lvz-btn" data-wgi-next>Next →</button><button type="button" class="lvz-btn" data-wgi-reset>↺ Restart</button><span class="lvz-pos" data-wgi-pos>1 / {steps.length}</span></div>
</section>

<script>
  import { mountStepper } from '../scripts/wgiStepper';
  function boot(){for(const root of document.querySelectorAll<HTMLElement>('.shk-transfer')){if(root.dataset.ready==='true')continue;root.dataset.ready='true';const all=Array.from(root.querySelectorAll<HTMLElement>('[data-wgi-step]'));mountStepper(root,{total:all.length,onShow:(i)=>all.forEach((step,k)=>step.hidden=k!==i),caption:(i)=>all[i]?.dataset.caption||'',interval:6500});}}
  boot();document.addEventListener('astro:page-load',boot);
</script>
