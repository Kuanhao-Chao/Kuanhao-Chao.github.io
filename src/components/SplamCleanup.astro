---
import '../styles/lvz.css';
import '../styles/splam.css';

interface Props { autoPlay?: boolean }
const { autoPlay = false } = Astro.props;

const steps = [
  ['Collect the three required inputs', 'The cleanup workflow uses a sorted RNA-seq alignment file, its coordinate-matched reference genome, and the trained Splam model.'],
  ['Extract candidate junctions from alignments', 'Splam walks the BAM, records distinct introns and their strands, and writes a six-column junction BED file.'],
  ['Score every extracted junction', 'For each candidate, Splam builds the strand-oriented 800 nt input and appends donor and acceptor probabilities to junction_score.bed.'],
  ['Mark low-confidence junctions', 'At the default cleanup threshold of 0.1, a junction is flagged when either its donor or acceptor score is below the cutoff.'],
  ['Remove alignments containing a flagged junction', 'If any intron in an alignment is low confidence, that alignment is discarded. Paired-read flags and NH tags for multimapped reads are updated consistently.'],
  ['Write clean inputs for transcript assembly', 'Splam emits a cleaned, sorted BAM and a separate BAM of discarded alignments. The cleaned BAM proceeds to assemblers such as StringTie.'],
] as const;

const C = { bam: '#3976a8', bed: '#b07d00', model: '#6f62a8', good: '#2f8069', bad: '#b04755', output: '#2f8069', genome: '#8a9491' };

function read(y: number, x: number, good: boolean, label: string) {
  const color = good ? C.good : C.bad;
  return `<g><path d="M${x} ${y} h68 l18 28 h68" fill="none" stroke="${color}" stroke-width="7" stroke-linecap="round"/><circle cx="${x + 77}" cy="${y + 13}" r="6" fill="${color}"/><text x="${x + 77}" y="${y + 50}" class="splam-detail" style="fill:${color}">${label}</text></g>`;
}

function desktop(step: number) {
  let s = `<text x="18" y="27" class="lvz-tl">Splam between spliced alignment and transcript assembly</text>`;
  if (step === 0) {
    const inputs = [[78, C.bam, 'RNA-seq BAM', 'sorted spliced alignments'], [303, C.genome, 'Reference FASTA', 'matching genome coordinates'], [528, C.model, 'Splam model', 'trained PyTorch weights']] as const;
    inputs.forEach(([x, color, title, detail]) => s += `<rect x="${x}" y="90" width="154" height="116" rx="7" fill="${color}" fill-opacity=".08" stroke="${color}" stroke-width="2.5"/><text x="${Number(x) + 77}" y="127" class="splam-label" style="fill:${color}">${title}</text><text x="${Number(x) + 77}" y="153" class="splam-detail">${detail}</text><path d="M${Number(x) + 35} 177 H${Number(x) + 119}" stroke="${color}" stroke-width="9"/>`);
    s += `<path d="M155 230 C240 285 520 285 605 230" fill="none" stroke="${C.model}" stroke-width="2.5"/><text x="380" y="305" class="splam-label" style="fill:${C.model}">three inputs share one coordinate system</text>`;
  }
  if (step === 1) {
    s += `<text x="50" y="67" class="splam-label" style="fill:${C.bam}">alignment records</text>${read(102, 40, true, 'JUNC0001')}${read(178, 40, false, 'JUNC0002')}${read(254, 40, true, 'JUNC0001')}`;
    s += `<path d="M235 190 H332" class="splam-arrow"/><path d="M322 184 L333 190 L322 196" class="splam-arrow"/><rect x="336" y="72" width="374" height="246" rx="6" fill="${C.bed}" fill-opacity=".05" stroke="${C.bed}" stroke-width="2"/><text x="523" y="101" class="splam-label" style="fill:${C.bed}">junction.bed · unique candidate introns</text>`;
    const rows = [['chr9','4,849,549','4,860,125','JUNC0001','3','+'],['chr9','5,923,308','5,924,658','JUNC0002','6','−'],['chr9','5,924,844','5,929,044','JUNC0003','8','−']];
    rows.forEach((row, index) => s += `<text x="523" y="${145 + index * 47}" class="splam-mono">${row.join('   ')}</text>`);
    s += `<text x="523" y="292" class="splam-detail">CHROM · START · END · NAME · COUNT · STRAND</text>`;
  }
  if (step === 2) {
    const rows = [[.99,.98,C.good],[.77,.54,C.good],[.96,.04,C.bad]] as const;
    s += `<rect x="42" y="66" width="676" height="262" rx="7" fill="${C.model}" fill-opacity=".04" stroke="${C.model}"/><text x="380" y="95" class="splam-label" style="fill:${C.model}">junction_score.bed</text><text x="105" y="128" class="splam-detail">junction</text><text x="430" y="128" class="splam-detail">donor score</text><text x="585" y="128" class="splam-detail">acceptor score</text>`;
    rows.forEach(([donor, acceptor, color], index) => { const y = 166 + index * 56; s += `<text x="105" y="${y}" class="splam-mono">JUNC000${index + 1}</text><rect x="337" y="${y - 17}" width="150" height="22" fill="var(--color-rule)"/><rect x="337" y="${y - 17}" width="${150 * donor}" height="22" fill="${C.bam}"/><text x="503" y="${y}" class="splam-detail splam-left">${donor.toFixed(2)}</text><rect x="530" y="${y - 17}" width="150" height="22" fill="var(--color-rule)"/><rect x="530" y="${y - 17}" width="${150 * acceptor}" height="22" fill="${C.good}"/><text x="696" y="${y}" class="splam-detail splam-left" style="fill:${color}">${acceptor.toFixed(2)}</text>`; });
  }
  if (step === 3) {
    const rows = [['JUNC0001', .99, .98], ['JUNC0002', .77, .54], ['JUNC0003', .96, .04]] as const;
    s += `<text x="380" y="75" class="splam-label">default BAM-cleanup threshold t = 0.1</text>`;
    rows.forEach(([name, donor, acceptor], index) => { const y = 112 + index * 72; const good = donor >= .1 && acceptor >= .1; const color = good ? C.good : C.bad; s += `<rect x="92" y="${y}" width="576" height="54" rx="5" fill="${color}" fill-opacity=".05" stroke="${color}" stroke-width="${good ? 1.5 : 2.5}"/><text x="140" y="${y + 33}" class="splam-label splam-left">${name}</text><text x="380" y="${y + 33}" class="splam-mono">min(${donor.toFixed(2)}, ${acceptor.toFixed(2)}) = ${Math.min(donor, acceptor).toFixed(2)}</text><text x="620" y="${y + 33}" class="splam-label" style="fill:${color}">${good ? 'keep' : 'flag'}</text>`; });
    s += `<text x="380" y="344" class="splam-detail">A weak donor or acceptor is enough to flag the paired junction.</text>`;
  }
  if (step === 4) {
    s += `<text x="174" y="64" class="splam-label" style="fill:${C.bam}">original alignments</text><text x="588" y="64" class="splam-label" style="fill:${C.output}">decision</text>`;
    s += read(105, 65, true, 'all junctions pass') + read(190, 65, false, 'contains JUNC0003') + read(275, 65, true, 'all junctions pass');
    s += `<path d="M280 119 H480 M280 204 H480 M280 289 H480" class="splam-arrow"/>`;
    s += `<rect x="500" y="85" width="175" height="67" rx="5" fill="${C.good}" fill-opacity=".08" stroke="${C.good}"/><text x="588" y="112" class="splam-label" style="fill:${C.good}">keep alignment</text><text x="588" y="134" class="splam-detail">all junctions pass</text><rect x="500" y="170" width="175" height="67" rx="5" fill="${C.bad}" fill-opacity=".08" stroke="${C.bad}" stroke-width="2.5"/><text x="588" y="197" class="splam-label" style="fill:${C.bad}">discard alignment</text><text x="588" y="219" class="splam-detail">any junction fails</text><rect x="500" y="255" width="175" height="67" rx="5" fill="${C.good}" fill-opacity=".08" stroke="${C.good}"/><text x="588" y="282" class="splam-label" style="fill:${C.good}">keep alignment</text><text x="588" y="304" class="splam-detail">update NH and mate flags</text>`;
  }
  if (step === 5) {
    const file = (x: number, color: string, title: string, detail: string) => `<path d="M${x} 88 h130 l34 34 v146 h-164z" fill="${color}" fill-opacity=".07" stroke="${color}" stroke-width="2"/><path d="M${x + 130} 88 v34 h34" fill="none" stroke="${color}"/><text x="${x + 82}" y="166" class="splam-label" style="fill:${color}">${title}</text><text x="${x + 82}" y="191" class="splam-detail">${detail}</text>`;
    s += file(62, C.bad, 'removed alignments', 'separate BAM for audit');
    s += file(306, C.good, 'cleaned.bam', 'sorted alignments retained');
    s += `<path d="M470 180 H604" class="splam-arrow"/><path d="M594 174 L605 180 L594 186" class="splam-arrow"/><rect x="606" y="119" width="114" height="122" rx="6" fill="${C.output}" fill-opacity=".08" stroke="${C.output}" stroke-width="2"/><text x="663" y="166" class="splam-label" style="fill:${C.output}">StringTie</text><text x="663" y="190" class="splam-detail">transcript</text><text x="663" y="208" class="splam-detail">assembly</text><text x="380" y="320" class="splam-detail">Only the cleaned BAM proceeds downstream; removed evidence remains available for audit.</text>`;
  }
  return `<svg viewBox="0 0 760 365" class="lvz-svg" role="img" aria-label="Splam BAM cleanup workflow, step ${step + 1}" preserveAspectRatio="xMidYMid meet">${s}</svg>`;
}

function mobile(step: number) {
  const rows = [
    ['BAM + FASTA + model', 'coordinate-matched inputs', C.bam],
    ['extract junctions', 'distinct introns → junction.bed', C.bed],
    ['score each pair', 'append donor + acceptor probabilities', C.model],
    ['apply threshold', 'either score < 0.1 → flag', C.bad],
    ['clean alignments', 'any flagged intron → discard read', C.bad],
    ['write outputs', 'cleaned BAM → transcript assembly', C.output],
  ] as const;
  let s = '';
  rows.forEach(([title, detail, color], index) => { const y = 12 + index * 70; s += `<g opacity="${index === step ? 1 : .58}"><rect x="12" y="${y}" width="336" height="56" rx="5" class="splam-card" stroke="${color}" stroke-width="${index === step ? 2.5 : 1}"/><text x="180" y="${y + 23}" class="splam-label" style="fill:${color}">${title}</text><text x="180" y="${y + 43}" class="splam-detail">${detail}</text></g>`; if (index < rows.length - 1) s += `<path d="M180 ${y + 56} V${y + 66}" class="splam-arrow"/><path d="M175 ${y + 61} L180 ${y + 67} L185 ${y + 61}" class="splam-arrow"/>`; });
  s += `<circle cx="326" cy="${40 + step * 70}" r="7" fill="${rows[step][2]}" class="splam-token"/>`;
  return `<svg viewBox="0 0 360 430" class="lvz-svg" role="img" aria-label="Splam BAM cleanup workflow, step ${step + 1}" preserveAspectRatio="xMidYMid meet">${s}</svg>`;
}
---

<section class="lvz splam-viz splam-cleanup" role="group" aria-label="Interactive: cleaning RNA-seq alignments with Splam" data-autoplay={autoPlay ? 'true' : undefined} data-print-final-state="true">
  <div class="lvz-head"><p class="lvz-title">Clean spliced alignments before assembly</p><span class="lvz-tag">BAM workflow</span></div>
  <p class="lvz-caption" data-wgi-caption aria-live="polite">{steps[0][1]}</p>
  <nav class="lvz-progress" aria-label="Alignment cleanup steps">{steps.map(([title], index) => <button type="button" class="lvz-jump" data-wgi-jump aria-label={`Step ${index + 1}: ${title}`} title={title}>{index + 1}</button>)}</nav>
  {steps.map(([title, caption], index) => (
    <div class="lvz-step" data-wgi-step data-caption={caption} data-print-final={index === steps.length - 1 ? 'true' : undefined} hidden={index !== 0}>
      <p class="lvz-steptitle"><span class="lvz-num">{index + 1}</span>{title}</p><div class="lvz-fig lvz-visual--desktop" set:html={desktop(index)} /><div class="lvz-fig lvz-visual--mobile" set:html={mobile(index)} />
    </div>
  ))}
  <div class="lvz-controls"><button type="button" class="lvz-btn" data-wgi-prev aria-label="Previous step">← Prev</button><button type="button" class="lvz-btn" data-wgi-play aria-pressed="false" aria-label="Play animation"><span data-wgi-play-icon>▶</span> <span data-wgi-play-label>Play</span></button><button type="button" class="lvz-btn" data-wgi-next aria-label="Next step">Next →</button><button type="button" class="lvz-btn" data-wgi-reset aria-label="Restart from first step">↺ Restart</button><span class="lvz-pos" data-wgi-pos>1 / {steps.length}</span></div>
  <div class="lvz-legend"><span><span class="lvz-sw" style={`background:${C.good}`}></span>retained</span><span><span class="lvz-sw" style={`background:${C.bad}`}></span>flagged or removed</span><span><span class="lvz-sw" style={`background:${C.model}`}></span>Splam score</span></div>
</section>

<script>
  import { mountStepper } from '../scripts/wgiStepper';
  function bootSplamCleanup() {
    document.querySelectorAll<HTMLElement>('.splam-cleanup').forEach((root) => {
      const scenes = Array.from(root.querySelectorAll<HTMLElement>('[data-wgi-step]'));
      mountStepper(root, { total: scenes.length, onShow: (index) => scenes.forEach((scene, sceneIndex) => { const current = sceneIndex === index; scene.hidden = !current; scene.setAttribute('aria-current', current ? 'step' : 'false'); }), caption: (index) => scenes[index]?.dataset.caption || '', interval: 6500, autoPlay: root.dataset.autoplay === 'true' });
    });
  }
  bootSplamCleanup();
  document.addEventListener('astro:page-load', bootSplamCleanup);
</script>
