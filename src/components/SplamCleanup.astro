---
import '../styles/lvz.css';
import '../styles/splam.css';

interface Props { autoPlay?: boolean }
const { autoPlay = false } = Astro.props;

const steps = [
  ['Collect junctions from spliced alignments', 'Splam reads a sorted RNA-seq BAM and records the distinct introns proposed by its spliced alignments.'],
  ['Score each unique junction once', 'Each donor-acceptor pair passes through the same paired-junction recognizer, producing donor and acceptor probabilities.'],
  ['Filter alignments with weak junctions', 'An alignment is removed if any of its junctions falls below the threshold. Mate flags and NH tags are updated consistently.'],
  ['Send cleaner evidence to transcript assembly', 'Splam writes a cleaned, sorted BAM for assemblers such as StringTie and a separate BAM containing discarded alignments.'],
] as const;

const C = {
  bam: 'var(--splam-donor)',
  junction: 'var(--splam-signal)',
  model: 'var(--splam-model)',
  good: 'var(--splam-acceptor)',
  bad: 'var(--splam-bad)',
};

function arrow(x1: number, x2: number) {
  return `<path d="M${x1} 143 H${x2 - 11}" class="splam-arrow"/><path d="M${x2 - 11} 137 L${x2} 143 L${x2 - 11} 149" class="splam-arrow"/>`;
}

function card(x: number, title: string, detail: string, color: string, active: boolean, visual: string) {
  return `<g opacity="${active ? 1 : 0.5}"><rect x="${x}" y="54" width="194" height="176" rx="5" class="splam-card" stroke="${color}" stroke-width="${active ? 3 : 1.2}"/><text x="${x + 97}" y="83" class="splam-label" style="fill:${color}">${title}</text><text x="${x + 97}" y="104" class="splam-detail">${detail}</text>${visual}</g>`;
}

function readPath(x: number, y: number, color: string) {
  return `<path d="M${x} ${y} h38 l13 20 h38" fill="none" stroke="${color}" stroke-width="6" stroke-linecap="round"/>`;
}

function desktop(step: number) {
  const x = [18, 254, 490, 726];
  let s = `<text x="20" y="26" class="lvz-tl">Splam reuses one junction recognizer between alignment and transcript assembly</text>`;

  s += card(x[0], 'Spliced BAM', 'candidate introns', C.bam, step === 0,
    `<g transform="translate(${x[0] + 35} 132)">${readPath(0, 0, C.good)}${readPath(34, 40, C.bad)}${readPath(4, 80, C.good)}<text x="62" y="119" class="splam-mini">many alignments · shared junctions</text></g>`);

  s += card(x[1], 'Score junctions', 'paired recognizer', C.model, step === 1,
    `<g transform="translate(${x[1] + 31} 128)"><rect x="0" y="14" width="54" height="34" rx="3" fill="${C.junction}" fill-opacity=".12" stroke="${C.junction}"/><path d="M54 31 H76" class="splam-arrow"/><rect x="76" width="56" height="62" rx="4" fill="${C.model}" fill-opacity=".12" stroke="${C.model}" stroke-width="2"/><text x="104" y="36" class="splam-mini" style="fill:${C.model}">Splam</text><text x="66" y="88" class="splam-mini">score each unique pair once</text></g>`);

  s += card(x[2], 'Filter alignments', 'any weak junction → remove', C.bad, step === 2,
    `<g transform="translate(${x[2] + 36} 126)">${readPath(0, 4, C.good)}<text x="121" y="18" class="splam-mini" style="fill:${C.good}">keep</text>${readPath(0, 48, C.bad)}<path d="M106 45 l17 17 M123 45 l-17 17" stroke="${C.bad}" stroke-width="2.4"/><text x="61" y="101" class="splam-mini">decision returns to every alignment</text></g>`);

  s += card(x[3], 'Write outputs', 'clean evidence downstream', C.good, step === 3,
    `<g transform="translate(${x[3] + 20} 123)"><rect x="0" y="0" width="70" height="35" rx="3" fill="${C.good}" fill-opacity=".1" stroke="${C.good}"/><text x="35" y="22" class="splam-mini" style="fill:${C.good}">cleaned BAM</text><path d="M70 18 H91" class="splam-arrow"/><rect x="91" y="0" width="63" height="35" rx="3" fill="${C.good}" fill-opacity=".1" stroke="${C.good}"/><text x="122.5" y="22" class="splam-mini" style="fill:${C.good}">StringTie</text><rect x="0" y="55" width="70" height="35" rx="3" fill="${C.bad}" fill-opacity=".08" stroke="${C.bad}"/><text x="35" y="77" class="splam-mini" style="fill:${C.bad}">removed BAM</text><text x="119" y="77" class="splam-mini">audit trail</text></g>`);

  for (let i = 0; i < x.length - 1; i += 1) s += arrow(x[i] + 194, x[i + 1]);
  s += `<circle cx="${x[step] + 97}" cy="253" r="8" fill="${[C.bam, C.model, C.bad, C.good][step]}" class="splam-token"/><text x="460" y="298" class="splam-summary">Junctions are scored once; their decisions are then applied back to the alignments that contain them.</text>`;
  return `<svg viewBox="0 0 940 320" class="lvz-svg" role="img" aria-label="Splam RNA-seq alignment cleanup workflow, step ${step + 1}" preserveAspectRatio="xMidYMid meet">${s}</svg>`;
}

function mobile(step: number) {
  const rows = [
    ['Spliced RNA-seq BAM', 'collect distinct candidate introns', C.bam],
    ['Splam recognizer', 'score each unique donor-acceptor pair', C.model],
    ['Alignment filter', 'any flagged junction → remove alignment', C.bad],
    ['Two BAM outputs', 'cleaned → assembly · removed → audit', C.good],
  ] as const;
  let s = '';
  rows.forEach(([title, detail, color], index) => {
    const y = 16 + index * 102;
    s += `<g opacity="${index === step ? 1 : 0.58}"><rect x="12" y="${y}" width="336" height="76" rx="5" class="splam-card" stroke="${color}" stroke-width="${index === step ? 2.8 : 1.2}"/><text x="180" y="${y + 31}" class="splam-label" style="fill:${color}">${title}</text><text x="180" y="${y + 56}" class="splam-detail">${detail}</text></g>`;
    if (index < rows.length - 1) s += `<path d="M180 ${y + 76} V${y + 96}" class="splam-arrow"/><path d="M175 ${y + 90} L180 ${y + 97} L185 ${y + 90}" class="splam-arrow"/>`;
  });
  s += `<circle cx="326" cy="${54 + step * 102}" r="7" fill="${rows[step][2]}" class="splam-token"/>`;
  return `<svg viewBox="0 0 360 408" class="lvz-svg" role="img" aria-label="Splam RNA-seq alignment cleanup workflow, step ${step + 1}" preserveAspectRatio="xMidYMid meet">${s}</svg>`;
}
---

<section class="lvz splam-viz splam-cleanup" role="group" aria-label="Interactive: cleaning RNA-seq alignments with Splam" data-autoplay={autoPlay ? 'true' : undefined} data-print-final-state="true">
  <div class="lvz-head"><p class="lvz-title">Clean RNA-seq alignments with Splam</p><span class="lvz-tag">BAM workflow</span></div>
  <p class="lvz-caption" data-wgi-caption aria-live="polite">{steps[0][1]}</p>
  <nav class="lvz-progress" aria-label="Alignment cleanup steps">{steps.map(([title], index) => <button type="button" class="lvz-jump" data-wgi-jump aria-label={`Step ${index + 1}: ${title}`} title={title}>{index + 1}</button>)}</nav>
  {steps.map(([title, caption], index) => (
    <div class="lvz-step" data-wgi-step data-caption={caption} data-print-final={index === steps.length - 1 ? 'true' : undefined} hidden={index !== 0}>
      <p class="lvz-steptitle"><span class="lvz-num">{index + 1}</span>{title}</p>
      <div class="lvz-fig lvz-visual--desktop" set:html={desktop(index)} />
      <div class="lvz-fig lvz-visual--mobile" set:html={mobile(index)} />
    </div>
  ))}
  <div class="lvz-controls"><button type="button" class="lvz-btn" data-wgi-prev aria-label="Previous step">← Prev</button><button type="button" class="lvz-btn" data-wgi-play aria-pressed="false" aria-label="Play animation"><span data-wgi-play-icon>▶</span> <span data-wgi-play-label>Play</span></button><button type="button" class="lvz-btn" data-wgi-next aria-label="Next step">Next →</button><button type="button" class="lvz-btn" data-wgi-reset aria-label="Restart from first step">↺ Restart</button><span class="lvz-pos" data-wgi-pos>1 / {steps.length}</span></div>
  <div class="lvz-legend"><span><span class="lvz-sw" style={`background:${C.bam}`}></span>alignment evidence</span><span><span class="lvz-sw" style={`background:${C.model}`}></span>Splam recognizer</span><span><span class="lvz-sw" style={`background:${C.good}`}></span>retained</span><span><span class="lvz-sw" style={`background:${C.bad}`}></span>flagged or removed</span></div>
</section>

<script>
  import { mountStepper } from '../scripts/wgiStepper';
  function bootSplamCleanup() {
    document.querySelectorAll<HTMLElement>('.splam-cleanup').forEach((root) => {
      const scenes = Array.from(root.querySelectorAll<HTMLElement>('[data-wgi-step]'));
      mountStepper(root, { total: scenes.length, onShow: (index) => scenes.forEach((scene, sceneIndex) => { const current = sceneIndex === index; scene.hidden = !current; scene.setAttribute('aria-current', current ? 'step' : 'false'); }), caption: (index) => scenes[index]?.dataset.caption || '', interval: 6500, autoPlay: root.dataset.autoplay === 'true' });
    });
  }
  bootSplamCleanup();
  document.addEventListener('astro:page-load', bootSplamCleanup);
</script>
