---
import Icon from './Icon.astro';
import { site, nav } from '../data/site';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href.replace(/\/$/, ''));

// Header (desktop + mobile) shows primary items only; footer keeps the full nav.
const headerNav = nav.filter((item) => !item.footerOnly);
---
<header class="site-header" transition:persist="site-header">
  <div class="container header-inner">
    <a href="/" class="wordmark" aria-label={`${site.name} — home`}>
      <span class="wordmark-mark" aria-hidden="true">
        <img src="/favicon.svg" alt="" width="32" height="32" />
      </span>
      <span class="wordmark-name">{site.name}</span>
    </a>

    <nav class="nav-desktop" aria-label="Primary">
      <ul>
        {
          headerNav.map((item) => (
            <li>
              <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header-actions">
      <button
        class="theme-toggle"
        type="button"
        data-theme-toggle
        data-theme-state="light"
        aria-label="Switch to dark mode"
        aria-pressed="false"
        title="Switch to dark mode"
      >
        <span class="theme-toggle-icon theme-toggle-icon--sun" aria-hidden="true">
          <Icon name="sun" size={19} />
        </span>
        <span class="theme-toggle-icon theme-toggle-icon--moon" aria-hidden="true">
          <Icon name="moon" size={19} />
        </span>
      </button>

      <button
        class="nav-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <Icon name="menu" size={24} />
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu" hidden>
    <nav aria-label="Mobile">
      <ul>
        {
          headerNav.map((item) => (
            <li>
              <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--color-bg) 88%, transparent);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid var(--color-rule);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4.25rem;
  }
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-ink);
    font-family: var(--font-display);
  }
  .wordmark:hover {
    text-decoration: none;
    color: var(--color-ink);
  }
  .wordmark-mark {
    flex: none;
    display: inline-grid;
    place-items: center;
    width: 2.15rem;
    height: 2.15rem;
  }
  .wordmark-mark img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .wordmark-name {
    font-weight: var(--fw-regular);
    font-size: 1.05rem;
    letter-spacing: var(--tracking-tight);
  }
  .nav-desktop ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: clamp(0.75rem, 2vw, 1.75rem);
    margin: 0;
    padding: 0;
  }
  .nav-desktop a {
    color: var(--color-ink);
    font-size: var(--fs-small);
    font-weight: var(--fw-medium);
    padding-block: 0.4rem;
    position: relative;
  }
  .nav-desktop a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
  .nav-desktop a[aria-current='page'] {
    color: var(--color-accent);
  }
  /* Underline "splices" in from the left on hover/focus; active page stays full. */
  .nav-desktop a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1.5px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 200ms ease;
  }
  .nav-desktop a:hover::after,
  .nav-desktop a:focus-visible::after,
  .nav-desktop a[aria-current='page']::after {
    transform: scaleX(1);
  }
  .nav-toggle {
    display: none;
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .theme-toggle,
  .nav-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: none;
    border: none;
    color: var(--color-ink);
    cursor: pointer;
    padding: 0.4rem;
  }
  .theme-toggle {
    display: grid;
    place-items: center;
    border: 1px solid var(--color-rule);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-surface) 72%, transparent);
    transition:
      border-color var(--transition),
      background var(--transition),
      color var(--transition);
  }
  .theme-toggle:hover {
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent) 45%, var(--color-rule));
    background: color-mix(in srgb, var(--color-accent) 9%, var(--color-surface));
  }
  .theme-toggle-icon {
    grid-area: 1 / 1;
    display: grid;
    place-items: center;
    transition:
      opacity var(--transition),
      transform var(--transition);
  }
  .theme-toggle-icon--sun {
    opacity: 0;
    transform: rotate(-90deg) scale(0.75);
  }
  .theme-toggle-icon--moon {
    opacity: 1;
    transform: none;
  }
  .theme-toggle[data-theme-state='dark'] .theme-toggle-icon--sun {
    opacity: 1;
    transform: none;
  }
  .theme-toggle[data-theme-state='dark'] .theme-toggle-icon--moon {
    opacity: 0;
    transform: rotate(90deg) scale(0.75);
  }
  .mobile-menu {
    border-top: 1px solid var(--color-rule);
    background: var(--color-bg);
  }
  .mobile-menu ul {
    list-style: none;
    margin: 0;
    padding: 0.5rem var(--gutter) 1.25rem;
    display: flex;
    flex-direction: column;
  }
  .mobile-menu a {
    display: block;
    padding: 0.9rem 0;
    color: var(--color-ink);
    font-size: 1.05rem;
    border-bottom: 1px solid var(--color-rule);
  }
  .mobile-menu a[aria-current='page'] {
    color: var(--color-accent);
  }

  @media (max-width: 900px) {
    .nav-desktop {
      display: none;
    }
    .nav-toggle {
      display: inline-flex;
    }
  }
</style>

<script>
  type ThemeApi = { toggle: () => void; sync: () => void };
  const themeApi = () => (window as Window & { __khcTheme?: ThemeApi }).__khcTheme;

  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const menu = document.querySelector<HTMLElement>('#mobile-menu');
  const header = document.querySelector<HTMLElement>('.site-header');
  if (toggle && menu && header) {
    const isOpen = () => toggle.getAttribute('aria-expanded') === 'true';
    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      menu.hidden = !open;
    };

    toggle.addEventListener('click', () => setOpen(!isOpen()));

    // Close on Escape (return focus to the button).
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen()) {
        setOpen(false);
        toggle.focus();
      }
    });

    // Close when tapping anywhere outside the header.
    document.addEventListener('click', (e) => {
      if (isOpen() && !header.contains(e.target as Node)) setOpen(false);
    });

    // Reset closed once the desktop nav takes over.
    window.matchMedia('(min-width: 900px)').addEventListener('change', (e) => {
      if (e.matches) setOpen(false);
    });

    // Close the mobile menu when a client-side navigation begins.
    document.addEventListener('astro:before-swap', () => setOpen(false));
  }

  for (const button of document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]')) {
    if (button.dataset.themeBound === 'true') continue;
    button.dataset.themeBound = 'true';
    button.addEventListener('click', () => themeApi()?.toggle());
  }
  themeApi()?.sync();

  // The header persists across view transitions, so refresh the active-nav
  // indicator on each navigation.
  function updateActiveNav() {
    const path = location.pathname;
    for (const a of document.querySelectorAll<HTMLAnchorElement>('.nav-desktop a, .mobile-menu a')) {
      const href = a.getAttribute('href') || '';
      if (!href.startsWith('/')) continue;
      const active = href === '/' ? path === '/' : path.startsWith(href.replace(/\/$/, ''));
      if (active) a.setAttribute('aria-current', 'page');
      else a.removeAttribute('aria-current');
    }
  }
  document.addEventListener('astro:page-load', updateActiveNav);
</script>
