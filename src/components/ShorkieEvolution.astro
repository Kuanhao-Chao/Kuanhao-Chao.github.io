---
import '../styles/lvz.css';
import '../styles/shorkie.css';

const scopes = [
  { id: 'r64', label: 'R64', count: '1 genome', size: '~12 Mb', color: '#3976a8', dots: 1 },
  { id: 'strains', label: '80 strains', count: '80 genomes', size: '~1 Gb', color: '#b07d00', dots: 8 },
  { id: 'order', label: 'Saccharomycetales', count: '165 genomes', size: '~2 Gb', color: '#2f8069', dots: 14 },
  { id: 'fungi', label: 'Fungal kingdom', count: '1,341 genomes', size: '~42 Gb', color: '#6f62a8', dots: 22 },
] as const;

const steps = [
  ['Choose the evolutionary neighborhood', 'Four alternative corpora test how phylogenetic distance and sequence diversity affect transfer back to budding yeast.'],
  ['Turn genomes into overlapping windows', 'Repeat-masked chromosomes are tiled into 16,384 bp examples with a 4,096 bp stride, preserving local sequence context.'],
  ['Remove leakage and define held-out data', 'Windows above 7% repeat content or homologous to held-out yeast sequence are removed before chromosome-level train, validation, and test splits.'],
  ['Hide bases and ask for reconstruction', 'The objective selects 15% of positions: 80% become mask tokens, 10% random bases, and 10% remain unchanged.'],
  ['Measure what evolutionary context taught', 'The model reconstructs A/C/G/T probabilities at selected bases; held-out perplexity identifies the 165-genome Saccharomycetales corpus as the best source.'],
] as const;

function dots(cx: number, cy: number, count: number, radius: number, color: string) {
  let out = '';
  for (let i = 0; i < count; i += 1) {
    const a = (Math.PI * 2 * i) / count - Math.PI / 2;
    const r = radius + (i % 3) * 7;
    out += `<circle cx="${cx + Math.cos(a) * r}" cy="${cy + Math.sin(a) * r}" r="${count === 1 ? 9 : 4.5}" fill="${color}" opacity="${0.72 + (i % 3) * 0.1}"/>`;
  }
  return out;
}

function scopeScene(scope: typeof scopes[number], mobile = false) {
  if (mobile) {
    let out = `<text x="180" y="26" class="shk-kicker">four alternative evolutionary scopes</text>`;
    scopes.forEach((item, i) => {
      const y = 58 + i * 86; const active = item.id === scope.id;
      const mobileLabel = item.id === 'order' ? '165-genome order' : item.label;
      out += `<g opacity="${active ? 1 : 0.3}"><path d="M52 ${y + 26} C95 ${y + 26},98 ${y},142 ${y}" fill="none" stroke="${item.color}" stroke-width="${active ? 3 : 1.5}"/>${dots(202, y + 1, item.dots, item.dots === 1 ? 0 : 28, item.color)}<text x="250" y="${y - 4}" class="shk-label shk-left" fill="${item.color}">${mobileLabel}</text><text x="250" y="${y + 17}" class="shk-detail shk-left">${item.count} · ${item.size}</text></g>`;
    });
    out += `<circle cx="45" cy="256" r="23" fill="#2f8069" fill-opacity="0.12" stroke="#2f8069" stroke-width="2"/><path d="M37 251 q8-14 16 0 q-8 13-16 0 M45 257 v14" fill="none" stroke="#2f8069" stroke-width="2"/><text x="45" y="296" class="shk-detail">S. cerevisiae</text>`;
    return `<svg viewBox="0 0 360 410" class="lvz-svg" role="img" aria-label="Four alternative Shorkie evolutionary scopes with ${scope.label} selected">${out}</svg>`;
  }
  let out = `<text x="460" y="28" class="shk-kicker">same target organism · four alternative sources of evolutionary context</text><circle cx="110" cy="205" r="45" fill="#2f8069" fill-opacity="0.12" stroke="#2f8069" stroke-width="2.5"/><path d="M96 194 q14-24 28 0 q-14 23-28 0 M110 206 v28" fill="none" stroke="#2f8069" stroke-width="3"/><text x="110" y="270" class="shk-label" fill="#2f8069">S. cerevisiae</text>`;
  scopes.forEach((item, i) => {
    const x = 280 + i * 155; const y = 96 + (i % 2) * 210; const active = item.id === scope.id;
    out += `<g opacity="${active ? 1 : 0.28}"><path d="M150 205 C205 205,210 ${y + 24},${x - 54} ${y + 24}" fill="none" stroke="${item.color}" stroke-width="${active ? 3 : 1.4}"/>${dots(x, y + 24, item.dots, item.dots === 1 ? 0 : 43, item.color)}<text x="${x}" y="${y + 90}" class="shk-label" fill="${item.color}">${item.label}</text><text x="${x}" y="${y + 111}" class="shk-detail">${item.count} · ${item.size}</text></g>`;
  });
  return `<svg viewBox="0 0 920 420" class="lvz-svg" role="img" aria-label="Four alternative Shorkie evolutionary scopes with ${scope.label} selected">${out}</svg>`;
}

function tileScene(mobile = false) {
  const w = mobile ? 360 : 920; const x0 = mobile ? 24 : 70; const y = mobile ? 88 : 125; const trackW = mobile ? 312 : 780;
  let out = `<text x="${w / 2}" y="28" class="shk-kicker">repeat-masked genome → overlapping sequence examples</text><line x1="${x0}" y1="${y}" x2="${x0 + trackW}" y2="${y}" stroke="#3976a8" stroke-width="18" stroke-linecap="round"/>`;
  const segments = [[0.08,0.16],[0.28,0.36],[0.48,0.57],[0.72,0.82]];
  segments.forEach(([a,b]) => { out += `<rect x="${x0 + trackW * a}" y="${y - 14}" width="${trackW * (b-a)}" height="28" rx="2" fill="#2f8069"/><text x="${x0 + trackW * (a+b)/2}" y="${y + 5}" class="shk-mini" fill="#fff">gene</text>`; });
  [[0.19,0.23],[0.62,0.68],[0.9,0.95]].forEach(([a,b]) => { out += `<rect x="${x0 + trackW * a}" y="${y - 14}" width="${trackW * (b-a)}" height="28" fill="#8a9491"/><path d="M${x0 + trackW*a} ${y-14} l${trackW*(b-a)} 28 M${x0 + trackW*a} ${y+14} l${trackW*(b-a)} -28" stroke="var(--color-bg)" opacity="0.5"/>`; });
  const winW = mobile ? 180 : 350; const stride = mobile ? 48 : 132; const baseY = mobile ? 178 : 220;
  for (let i=0;i<4;i+=1) { const x=x0+i*stride; out += `<g style="animation-delay:${i*90}ms"><rect x="${x}" y="${baseY+i*(mobile?45:34)}" width="${winW}" height="${mobile?30:24}" rx="4" fill="#3976a8" fill-opacity="0.1" stroke="#3976a8" stroke-width="2"/><line x1="${x+stride}" y1="${baseY+i*(mobile?45:34)-10}" x2="${x+stride}" y2="${baseY+i*(mobile?45:34)+36}" stroke="#b07d00" stroke-dasharray="3 3"/></g>`; }
  out += `<path d="M${x0} ${baseY-20} v-14 h${winW} v14" fill="none" stroke="#3976a8"/><text x="${x0+winW/2}" y="${baseY-40}" class="shk-detail">16,384 bp window</text><text x="${x0+stride}" y="${mobile?390:385}" class="shk-label" fill="#b07d00">4,096 bp stride</text>`;
  return `<svg viewBox="0 0 ${w} ${mobile?420:420}" class="lvz-svg" role="img" aria-label="Genome ribbon tiled into overlapping 16,384 base pair windows">${out}</svg>`;
}

function filterScene(mobile = false) {
  const w=mobile?360:920; let out=`<text x="${w/2}" y="28" class="shk-kicker">keep informative windows · isolate held-out chromosomes</text>`;
  const windows=[0.02,0.11,0.19,0.04,0.09,0.03];
  if (mobile) {
    windows.forEach((r,i)=>{const y=58+i*40; const keep=r<=0.07; out+=`<rect x="24" y="${y}" width="150" height="25" rx="3" fill="#3976a8" fill-opacity="0.1" stroke="${keep?'#2f8069':'#b04755'}"/><rect x="29" y="${y+5}" width="${r/.2*138}" height="15" fill="#8a9491"/><text x="195" y="${y+17}" class="shk-detail shk-left" fill="${keep?'#2f8069':'#b04755'}">${keep?'keep':'remove'} · ${Math.round(r*100)}% repeats</text>`;});
    out+=`<path d="M180 306 v28" class="shk-arrow"/><text x="180" y="325" class="shk-mini">homology filter</text><g transform="translate(20 350)"><rect width="98" height="42" rx="4" fill="#2f8069" fill-opacity=".12" stroke="#2f8069"/><rect x="111" width="98" height="42" rx="4" fill="#b07d00" fill-opacity=".12" stroke="#b07d00"/><rect x="222" width="98" height="42" rx="4" fill="#b04755" fill-opacity=".12" stroke="#b04755"/><text x="49" y="19" class="shk-label">train</text><text x="49" y="34" class="shk-mini">remaining chr.</text><text x="160" y="19" class="shk-label">validation</text><text x="160" y="34" class="shk-mini">XI · XIII · XV</text><text x="271" y="19" class="shk-label">test</text><text x="271" y="34" class="shk-mini">XII · XIV · XVI</text></g>`;
  } else {
    windows.forEach((r,i)=>{const x=45+(i%3)*205,y=70+Math.floor(i/3)*64,keep=r<=.07;out+=`<rect x="${x}" y="${y}" width="170" height="34" rx="3" fill="#3976a8" fill-opacity=".08" stroke="${keep?'#2f8069':'#b04755'}" stroke-width="2"/><rect x="${x+6}" y="${y+8}" width="${r/.2*158}" height="18" fill="#8a9491"/><text x="${x+180}" y="${y+22}" class="shk-detail shk-left" fill="${keep?'#2f8069':'#b04755'}">${Math.round(r*100)}% · ${keep?'keep':'remove'}</text>`;});
    out+=`<path d="M675 80 h65 l22 35-22 35h-65z" fill="#b07d00" fill-opacity=".1" stroke="#b07d00" stroke-width="2"/><text x="715" y="107" class="shk-label">homology</text><text x="715" y="128" class="shk-detail">filter</text><path d="M762 115 H840" class="shk-arrow"/><path d="M832 109 l8 6-8 6" class="shk-arrow"/><text x="825" y="158" class="shk-detail">no evaluation leakage</text><g transform="translate(80 245)"><rect width="230" height="80" rx="5" fill="#2f8069" fill-opacity=".12" stroke="#2f8069"/><rect x="265" width="230" height="80" rx="5" fill="#b07d00" fill-opacity=".12" stroke="#b07d00"/><rect x="530" width="230" height="80" rx="5" fill="#b04755" fill-opacity=".12" stroke="#b04755"/><text x="115" y="31" class="shk-label">training chromosomes</text><text x="115" y="55" class="shk-detail">all remaining chromosomes</text><text x="380" y="31" class="shk-label">validation</text><text x="380" y="55" class="shk-detail">XI · XIII · XV</text><text x="645" y="31" class="shk-label">testing</text><text x="645" y="55" class="shk-detail">XII · XIV · XVI</text></g>`;
  }
  return `<svg viewBox="0 0 ${w} ${mobile?420:380}" class="lvz-svg" role="img" aria-label="Repeat and homology filtering followed by chromosome train validation and test splits">${out}</svg>`;
}

function maskScene(mobile=false) {
  const w=mobile?360:920; const letters='ACTGACCTGTATGCA'; const x0=mobile?22:98; const gap=mobile?21:48; const y=mobile?78:95; const selected=[2,6,11];
  let out=`<text x="${w/2}" y="28" class="shk-kicker">select 15% of positions for reconstruction</text>`;
  [...letters].forEach((letter,i)=>{const sel=selected.includes(i);out+=`<g><circle cx="${x0+i*gap}" cy="${y}" r="${mobile?9:16}" fill="${sel?'#b04755':'var(--color-bg)'}" fill-opacity="${sel ? .15 : 0}" stroke="${sel?'#b04755':'var(--color-rule)'}"/><text x="${x0+i*gap}" y="${y+4}" class="shk-dna" text-anchor="middle" fill="${sel?'#b04755':'var(--color-ink)'}">${letter}</text></g>`;});
  const options=mobile?[[45,205,'MASK','80%','#b04755'],[180,205,'random base','10%','#b07d00'],[315,205,'unchanged','10%','#2f8069']]:[[210,255,'MASK token','80%','#b04755'],[460,255,'random nucleotide','10%','#b07d00'],[710,255,'leave unchanged','10%','#2f8069']];
  options.forEach(([x,oy,label,pct,color])=>{out+=`<path d="M${w/2} ${y+34} C${w/2} ${y+95},${x} ${Number(oy)-55},${x} ${Number(oy)-25}" fill="none" stroke="${color}" stroke-width="2"/><circle cx="${x}" cy="${oy}" r="${mobile?35:50}" fill="${color}" fill-opacity=".12" stroke="${color}" stroke-width="2"/><text x="${x}" y="${Number(oy)-2}" class="shk-label" fill="${color}">${label}</text><text x="${x}" y="${Number(oy)+20}" class="shk-detail">${pct}</text>`;});
  out+=`<text x="${w/2}" y="${mobile?330:365}" class="shk-label" fill="#6f62a8">loss is evaluated only at the selected positions</text>`;
  return `<svg viewBox="0 0 ${w} ${mobile?370:400}" class="lvz-svg" role="img" aria-label="Fifteen percent masking with eighty ten ten corruption strategy">${out}</svg>`;
}

function resultScene(mobile=false) {
  const w=mobile?360:920; let out=`<text x="${w/2}" y="28" class="shk-kicker">reconstruct hidden DNA · compare transfer to held-out yeast</text>`;
  const probs=[.05,.12,.76,.07],labels=['A','C','G','T'],colors=['#3976a8','#b04755','#2f8069','#b07d00'];
  const bx=mobile?45:110, base=mobile?205:255, scale=mobile?120:155, gap=mobile?48:68;
  probs.forEach((p,i)=>{out+=`<rect x="${bx+i*gap}" y="${base-p*scale}" width="${mobile?28:42}" height="${p*scale}" rx="3" fill="${colors[i]}"/><text x="${bx+i*gap+(mobile?14:21)}" y="${base+23}" class="shk-label" fill="${colors[i]}">${labels[i]}</text><text x="${bx+i*gap+(mobile?14:21)}" y="${base-p*scale-8}" class="shk-detail">${p.toFixed(2)}</text>`;});
  out+=`<text x="${mobile?125:225}" y="${mobile?270:315}" class="shk-detail">predicted nucleotide probabilities</text>`;
  const vals=[3.77,3.73,3.55,3.61],names=['R64','80 strains','165 order','1,341 fungi']; const chartX=mobile?35:500, chartY=mobile?420:300, chartW=mobile?280:350;
  vals.forEach((v,i)=>{const width=(4-v)*chartW/0.55; const y=chartY-i*(mobile?42:54); const best=i===2; const barX=chartX+(mobile?88:110);out+=`<text x="${chartX}" y="${y+5}" class="shk-detail shk-left">${names[i]}</text><rect x="${barX}" y="${y-12}" width="${width}" height="22" rx="3" fill="${best?'#2f8069':'#8a9491'}" opacity="${best?1:.45}"/>${best?`<text x="${barX+width-7}" y="${y+4}" class="shk-mini shk-right shk-invert">${mobile?'best':'lowest perplexity'}</text>`:''}`;});
  out+=`<path d="M${mobile?270:415} ${mobile?150:205} H${mobile?330:485}" class="shk-arrow"/><path d="M${mobile?322:477} ${mobile?144:199} l8 6-8 6" class="shk-arrow"/>`;
  return `<svg viewBox="0 0 ${w} ${mobile?470:380}" class="lvz-svg" role="img" aria-label="Nucleotide reconstruction probabilities and evolutionary-scope perplexity comparison">${out}</svg>`;
}

const desktopScenes = scopes.map((scope) => [scopeScene(scope), tileScene(), filterScene(), maskScene(), resultScene()]);
const mobileScenes = scopes.map((scope) => [scopeScene(scope, true), tileScene(true), filterScene(true), maskScene(true), resultScene(true)]);
---

<section class="lvz shk shk-evolution" role="group" aria-label="Interactive: evolution and masked pretraining in Shorkie" data-print-final-state="true">
  <div class="lvz-head"><p class="lvz-title">Borrow regulatory context from evolution</p><label class="shk-selector"><span>Corpus</span><select data-shk-select>{scopes.map((scope) => <option value={scope.id}>{scope.label}</option>)}</select></label></div>
  <p class="lvz-caption" data-wgi-caption aria-live="polite">{steps[0][1]}</p>
  <nav class="lvz-progress" aria-label="Evolution and pretraining steps">{steps.map(([title], i) => <button type="button" class="lvz-jump" data-wgi-jump aria-label={`Step ${i + 1}: ${title}`} title={title}>{i + 1}</button>)}</nav>
  {scopes.map((scope, scopeIndex) => <div data-shk-group={scope.id} hidden={scopeIndex !== 0}>{steps.map(([title, caption], i) => <div class="lvz-step" data-wgi-step data-caption={caption} data-print-final={i === 4 ? 'true' : undefined} hidden={i !== 0}><p class="lvz-steptitle"><span class="lvz-num">{i + 1}</span>{title}</p><div class="lvz-fig lvz-visual--desktop" set:html={desktopScenes[scopeIndex][i]} /><div class="lvz-fig lvz-visual--mobile" set:html={mobileScenes[scopeIndex][i]} /></div>)}</div>)}
  <div class="lvz-controls"><button type="button" class="lvz-btn" data-wgi-prev>← Prev</button><button type="button" class="lvz-btn" data-wgi-play aria-pressed="false"><span data-wgi-play-icon>▶</span> <span data-wgi-play-label>Play</span></button><button type="button" class="lvz-btn" data-wgi-next>Next →</button><button type="button" class="lvz-btn" data-wgi-reset>↺ Restart</button><span class="lvz-pos" data-wgi-pos>1 / {steps.length}</span></div>
</section>

<script>
  import { mountStepper } from '../scripts/wgiStepper';
  function boot() {
    for (const root of document.querySelectorAll<HTMLElement>('.shk-evolution')) {
      if (root.dataset.ready === 'true') continue; root.dataset.ready = 'true';
      const groups = Array.from(root.querySelectorAll<HTMLElement>('[data-shk-group]')); const select = root.querySelector<HTMLSelectElement>('[data-shk-select]'); let active = select?.value || 'r64'; let current = 0;
      const activeSteps = () => Array.from(groups.find((group) => group.dataset.shkGroup === active)?.querySelectorAll<HTMLElement>('[data-wgi-step]') || []);
      const show = (i: number) => { current = i; groups.forEach((group) => { const on = group.dataset.shkGroup === active; group.hidden = !on; Array.from(group.querySelectorAll<HTMLElement>('[data-wgi-step]')).forEach((step, k) => step.hidden = !(on && k === i)); }); };
      const api = mountStepper(root, { total: activeSteps().length, onShow: show, caption: (i) => activeSteps()[i]?.dataset.caption || '', interval: 6500 });
      select?.addEventListener('change', () => { api?.stop(); active = select.value; api?.show(current); });
    }
  }
  boot(); document.addEventListener('astro:page-load', boot);
</script>
