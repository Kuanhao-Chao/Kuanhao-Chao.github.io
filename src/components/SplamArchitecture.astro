---
import '../styles/lvz.css';
import '../styles/splam.css';

interface Props { autoPlay?: boolean }
const { autoPlay = false } = Astro.props;

const steps = [
  ['Project DNA into 64 feature channels', 'A 1 × 1 convolution transforms the 4 × 800 one-hot matrix into 64 channels while preserving all 800 sequence positions.'],
  ['Process sequence through one residual unit', 'Each unit applies two grouped, dilated convolutions. Batch normalization and Leaky ReLU with slope −0.1 follow each convolution, while a shortcut adds the original input back.'],
  ['Expand context through five residual groups', 'Twenty residual units are arranged as five groups of four. Increasing kernel widths and dilation rates expand context without pooling away nucleotide resolution.'],
  ['Aggregate features from every residual group', 'Each group output passes through Conv(64, 1, 1). The projected outputs are added through the long residual path before classification.'],
  ['Predict three probabilities at every base', 'A final Conv(3, 1, 1) and softmax produce donor, acceptor, and neither probabilities at each of 800 positions. The complete model contains 651,715 parameters.'],
] as const;

const C = { input: '#3976a8', model: '#6f62a8', donor: '#3976a8', acceptor: '#2f8069', neither: '#8a9491', skip: '#b04755', signal: '#b07d00' };
const groups = [
  { color: '#3976a8', w: 11, d: 1 },
  { color: '#2f8069', w: 11, d: 5 },
  { color: '#b26b32', w: 11, d: 10 },
  { color: '#b07d00', w: 21, d: 15 },
  { color: '#6f62a8', w: 21, d: 20 },
] as const;

function arrow(x1: number, y: number, x2: number) {
  return `<path d="M${x1} ${y} H${x2 - 9}" class="splam-arrow"/><path d="M${x2 - 9} ${y - 6} L${x2} ${y} L${x2 - 9} ${y + 6}" class="splam-arrow"/>`;
}

function desktop(step: number) {
  let s = '';
  if (step === 0) {
    s += `<text x="18" y="28" class="lvz-tl">Preserve base resolution while increasing feature width</text>`;
    s += `<g transform="translate(52 72)"><text x="90" y="0" class="splam-label" style="fill:${C.input}">one-hot DNA · 4 × 800</text>`;
    for (let row = 0; row < 4; row += 1) for (let col = 0; col < 10; col += 1) s += `<rect x="${col * 18}" y="${20 + row * 18}" width="14" height="14" fill="${(row + col * 2) % 5 === 0 ? C.input : 'var(--color-bg)'}" fill-opacity="${(row + col * 2) % 5 === 0 ? .75 : 1}" stroke="var(--color-rule)"/>`;
    s += `</g>`;
    s += `<path d="M250 145 H342" class="splam-arrow"/><path d="M333 139 L343 145 L333 151" class="splam-arrow"/><rect x="345" y="101" width="150" height="88" rx="6" fill="${C.model}" fill-opacity=".1" stroke="${C.model}" stroke-width="2.5"/><text x="420" y="137" class="splam-label" style="fill:${C.model}">Conv(64, 1, 1)</text><text x="420" y="162" class="splam-detail">position-wise projection</text>`;
    s += `<path d="M498 145 H574" class="splam-arrow"/><path d="M565 139 L575 145 L565 151" class="splam-arrow"/>`;
    s += `<g transform="translate(582 72)"><text x="66" y="0" class="splam-label" style="fill:${C.model}">features · 64 × 800</text>${Array.from({ length: 8 }, (_, row) => `<rect x="0" y="${20 + row * 17}" width="132" height="11" fill="${C.model}" fill-opacity="${.08 + row * .025}" stroke="${C.model}"/>`).join('')}</g>`;
    s += `<text x="380" y="292" class="splam-detail">No pooling: sequence length remains 800 throughout the network.</text>`;
  }
  if (step === 1) {
    s += `<text x="18" y="28" class="lvz-tl">One residual unit RU(F, W, D, G)</text>`;
    s += `<path d="M110 74 H260" class="splam-arrow"/><text x="112" y="63" class="splam-detail splam-left">unit input</text>`;
    const blocks = [
      ['Grouped Conv1D', 'F=64 · width W · dilation D · G=4'],
      ['Batch normalization', 'stabilize channel activations'],
      ['Leaky ReLU', 'negative slope = −0.1'],
      ['Grouped Conv1D', 'F=64 · width W · dilation D · G=4'],
      ['Batch normalization + Leaky ReLU', 'second nonlinear transform'],
    ];
    blocks.forEach(([title, detail], index) => {
      const y = 54 + index * 53;
      s += `<rect x="260" y="${y}" width="240" height="40" rx="4" fill="${C.model}" fill-opacity="${index === 0 || index === 3 ? .13 : .06}" stroke="${C.model}"/><text x="380" y="${y + 17}" class="splam-label">${title}</text><text x="380" y="${y + 32}" class="splam-detail">${detail}</text>`;
      if (index < blocks.length - 1) s += `<path d="M380 ${y + 40} V${y + 52}" class="splam-arrow"/>`;
    });
    s += `<path d="M260 74 H198 V300 H518" fill="none" stroke="${C.skip}" stroke-width="2.5"/><circle cx="520" cy="300" r="13" fill="${C.skip}"/><text x="520" y="305" class="splam-label" style="fill:#fff">+</text><path d="M500 286 L508 295" stroke="${C.skip}" stroke-width="2"/><path d="M533 300 H650" class="splam-arrow"/><text x="648" y="289" class="splam-detail">unit output</text>`;
  }
  if (step === 2) {
    s += `<text x="18" y="28" class="lvz-tl">Five residual groups · four units per group · 64 channels × 800 positions</text>`;
    groups.forEach((group, index) => {
      const x = 24 + index * 145;
      s += `<g><rect x="${x}" y="70" width="126" height="195" rx="6" fill="${group.color}" fill-opacity=".06" stroke="${group.color}" stroke-width="2"/><text x="${x + 63}" y="94" class="splam-label" style="fill:${group.color}">Group ${index + 1}</text>`;
      for (let unit = 0; unit < 4; unit += 1) s += `<rect x="${x + 22}" y="${108 + unit * 31}" width="82" height="23" rx="3" fill="${group.color}" fill-opacity="${.12 + unit * .04}" stroke="${group.color}"/><text x="${x + 63}" y="${124 + unit * 31}" class="splam-detail">RU ${unit + 1}</text>`;
      s += `<text x="${x + 63}" y="250" class="splam-detail">W=${group.w} · D=${group.d} · G=4</text></g>`;
      if (index < groups.length - 1) s += `<path d="M${x + 126} 168 H${x + 144}" class="splam-arrow"/><path d="M${x + 136} 162 L${x + 145} 168 L${x + 136} 174" class="splam-arrow"/>`;
    });
    s += `<path d="M80 305 C190 338 570 338 680 305" fill="none" stroke="${C.signal}" stroke-width="3"/><text x="380" y="348" class="splam-label" style="fill:${C.signal}">dilation expands context without reducing resolution</text>`;
  }
  if (step === 3) {
    s += `<text x="18" y="28" class="lvz-tl">Multi-scale group outputs feed one additive residual path</text>`;
    groups.forEach((group, index) => {
      const y = 58 + index * 54;
      s += `<rect x="50" y="${y}" width="142" height="36" rx="4" fill="${group.color}" fill-opacity=".1" stroke="${group.color}"/><text x="121" y="${y + 23}" class="splam-label" style="fill:${group.color}">Group ${index + 1} output</text><path d="M192 ${y + 18} H278" class="splam-arrow"/><rect x="280" y="${y}" width="142" height="36" rx="4" fill="${C.model}" fill-opacity=".08" stroke="${C.model}"/><text x="351" y="${y + 23}" class="splam-label">Conv(64, 1, 1)</text><path d="M422 ${y + 18} H524" stroke="${C.skip}" stroke-width="2"/>`;
    });
    s += `<path d="M524 76 V292" stroke="${C.skip}" stroke-width="3"/><circle cx="524" cy="292" r="15" fill="${C.skip}"/><text x="524" y="297" class="splam-label" style="fill:#fff">+</text><path d="M539 292 H680" class="splam-arrow"/><rect x="620" y="258" width="100" height="68" rx="5" fill="${C.model}" fill-opacity=".1" stroke="${C.model}" stroke-width="2"/><text x="670" y="286" class="splam-label">64 × 800</text><text x="670" y="307" class="splam-detail">summed features</text>`;
  }
  if (step === 4) {
    s += `<text x="18" y="28" class="lvz-tl">Per-base three-class prediction</text><rect x="45" y="94" width="154" height="86" rx="6" fill="${C.model}" fill-opacity=".1" stroke="${C.model}" stroke-width="2"/><text x="122" y="128" class="splam-label">summed features</text><text x="122" y="153" class="splam-detail">64 × 800</text>${arrow(199, 137, 270)}<rect x="270" y="94" width="154" height="86" rx="6" fill="${C.model}" fill-opacity=".1" stroke="${C.model}" stroke-width="2"/><text x="347" y="128" class="splam-label">Conv(3, 1, 1)</text><text x="347" y="153" class="splam-detail">class logits</text>${arrow(424, 137, 495)}<rect x="495" y="94" width="154" height="86" rx="6" fill="${C.signal}" fill-opacity=".09" stroke="${C.signal}" stroke-width="2"/><text x="572" y="128" class="splam-label">Softmax</text><text x="572" y="153" class="splam-detail">probabilities sum to 1</text>`;
    const tracks = [[C.neither, 'neither'], [C.donor, 'donor'], [C.acceptor, 'acceptor']] as const;
    tracks.forEach(([color, label], index) => { const y = 225 + index * 40; s += `<text x="70" y="${y + 6}" class="splam-label splam-left" style="fill:${color}">${label}</text><path d="M155 ${y} C240 ${y - 5} 280 ${y - 28 + index * 12} 350 ${y} S500 ${y + 18 - index * 9} 680 ${y}" fill="none" stroke="${color}" stroke-width="${index === 0 ? 2 : 3}"/>`; });
    s += `<text x="650" y="347" class="splam-detail">output shape 3 × 800</text><text x="120" y="347" class="splam-detail">651,715 parameters total</text>`;
  }
  return `<svg viewBox="0 0 760 365" class="lvz-svg" role="img" aria-label="Splam model architecture, step ${step + 1}" preserveAspectRatio="xMidYMid meet">${s}</svg>`;
}

function mobile(step: number) {
  const rows = [
    ['4 × 800 input', 'Conv(64, 1, 1) → 64 × 800', C.input],
    ['Residual unit', '2 grouped dilated convolutions + shortcut', C.model],
    ['Five residual groups', '4 units each · D = 1, 5, 10, 15, 20', C.signal],
    ['Group aggregation', 'five Conv(64, 1, 1) outputs are added', C.skip],
    ['3 × 800 softmax', 'neither · donor · acceptor', C.acceptor],
  ] as const;
  let s = '<text x="180" y="23" class="splam-detail">651,715 parameters · no pooling</text>';
  rows.forEach(([title, detail, color], index) => {
    const y = 40 + index * 76;
    s += `<g opacity="${index === step ? 1 : .58}"><rect x="12" y="${y}" width="336" height="62" rx="5" class="splam-card" stroke="${color}" stroke-width="${index === step ? 2.5 : 1}"/><text x="180" y="${y + 25}" class="splam-label" style="fill:${color}">${title}</text><text x="180" y="${y + 47}" class="splam-detail">${detail}</text></g>`;
    if (index < rows.length - 1) s += `<path d="M180 ${y + 62} V${y + 72}" class="splam-arrow"/><path d="M175 ${y + 67} L180 ${y + 73} L185 ${y + 67}" class="splam-arrow"/>`;
  });
  s += `<circle cx="326" cy="${71 + step * 76}" r="7" fill="${rows[step][2]}" class="splam-token"/>`;
  return `<svg viewBox="0 0 360 430" class="lvz-svg" role="img" aria-label="Splam model architecture, step ${step + 1}" preserveAspectRatio="xMidYMid meet">${s}</svg>`;
}
---

<section class="lvz splam-viz splam-architecture" role="group" aria-label="Interactive: Splam model architecture" data-autoplay={autoPlay ? 'true' : undefined} data-print-final-state="true">
  <div class="lvz-head"><p class="lvz-title">Follow sequence through the Splam network</p><span class="lvz-tag">Deep residual CNN</span></div>
  <p class="lvz-caption" data-wgi-caption aria-live="polite">{steps[0][1]}</p>
  <nav class="lvz-progress" aria-label="Model architecture steps">{steps.map(([title], index) => <button type="button" class="lvz-jump" data-wgi-jump aria-label={`Step ${index + 1}: ${title}`} title={title}>{index + 1}</button>)}</nav>
  {steps.map(([title, caption], index) => (
    <div class="lvz-step" data-wgi-step data-caption={caption} data-print-final={index === steps.length - 1 ? 'true' : undefined} hidden={index !== 0}>
      <p class="lvz-steptitle"><span class="lvz-num">{index + 1}</span>{title}</p>
      <div class="lvz-fig lvz-visual--desktop" set:html={desktop(index)} />
      <div class="lvz-fig lvz-visual--mobile" set:html={mobile(index)} />
    </div>
  ))}
  <div class="lvz-controls"><button type="button" class="lvz-btn" data-wgi-prev aria-label="Previous step">← Prev</button><button type="button" class="lvz-btn" data-wgi-play aria-pressed="false" aria-label="Play animation"><span data-wgi-play-icon>▶</span> <span data-wgi-play-label>Play</span></button><button type="button" class="lvz-btn" data-wgi-next aria-label="Next step">Next →</button><button type="button" class="lvz-btn" data-wgi-reset aria-label="Restart from first step">↺ Restart</button><span class="lvz-pos" data-wgi-pos>1 / {steps.length}</span></div>
  <div class="lvz-legend"><span><span class="lvz-sw" style={`background:${C.model}`}></span>learned features</span><span><span class="lvz-sw" style={`background:${C.skip}`}></span>residual path</span><span><span class="lvz-sw" style={`background:${C.donor}`}></span>donor</span><span><span class="lvz-sw" style={`background:${C.acceptor}`}></span>acceptor</span></div>
</section>

<script>
  import { mountStepper } from '../scripts/wgiStepper';
  function bootSplamArchitecture() {
    document.querySelectorAll<HTMLElement>('.splam-architecture').forEach((root) => {
      const scenes = Array.from(root.querySelectorAll<HTMLElement>('[data-wgi-step]'));
      mountStepper(root, { total: scenes.length, onShow: (index) => scenes.forEach((scene, sceneIndex) => { const current = sceneIndex === index; scene.hidden = !current; scene.setAttribute('aria-current', current ? 'step' : 'false'); }), caption: (index) => scenes[index]?.dataset.caption || '', interval: 6500, autoPlay: root.dataset.autoplay === 'true' });
    });
  }
  bootSplamArchitecture();
  document.addEventListener('astro:page-load', bootSplamArchitecture);
</script>
