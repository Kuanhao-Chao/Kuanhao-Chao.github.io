---
import Icon from './Icon.astro';
import ResearchMotif from './genomic/ResearchMotif.astro';
import { resolveRelatedPosts } from '../lib/relatedPosts';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'research'>;
  variant: 'home' | 'index';
  showPosts?: boolean;
}
const { entry, variant, showPosts = false } = Astro.props;
const d = entry.data;
const href = `/research/${entry.id}/`;
const blogLinks = showPosts ? await resolveRelatedPosts(d.relatedPosts.map((r) => r.id)) : [];
---
{
  variant === 'home' ? (
    <article class="rcard rcard--home">
      <a href={href} class="rcard-home-link">
        <span class="rcard-media">
          <ResearchMotif id={entry.id} class="research-motif" />
        </span>
        <span class="rcard-home-copy">
          <span class="eyebrow">{d.area}</span>
          <span class="rcard-title">{d.title}</span>
        </span>
      </a>
    </article>
  ) : (
    <article class="rcard rcard--index">
      <a href={href} class="rcard-media" aria-hidden="true" tabindex="-1">
        <ResearchMotif id={entry.id} class="research-motif" />
      </a>
      <div class="rcard-body">
        <p class="eyebrow">{d.area}</p>
        <h3 class="rcard-title"><a href={href}>{d.title}</a></h3>
        <p class="rcard-summary muted">{d.summary}</p>
      </div>
      {(d.relatedPublications.length > 0 || blogLinks.length > 0) && (
        <nav class="rcard-links" aria-label={`${d.title} resources`}>
          {d.relatedPublications.length > 0 && (
            <a href={`${href}#related-work`}>
              <Icon name="arrow-right" size={15} />
              Related work
            </a>
          )}
          {blogLinks.map((b) => (
            <a href={b.href} title={b.title} aria-label={`Read the blog post: ${b.title}`}>
              <Icon name="pencil" size={15} />
              {b.label}
            </a>
          ))}
        </nav>
      )}
    </article>
  )
}

<style>
  .rcard {
    min-width: 0;
  }
  .rcard-media {
    display: block;
    overflow: hidden;
    background: color-mix(in srgb, var(--color-accent) 6%, var(--color-bg));
  }
  .rcard-media :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }
  .rcard-title {
    color: var(--color-ink);
    font-size: 1.12rem;
    font-weight: var(--fw-semibold);
    line-height: 1.3;
    letter-spacing: 0;
  }

  .rcard--home {
    background: var(--color-surface);
  }
  .rcard-home-link {
    display: flex;
    min-height: 12.5rem;
    height: 100%;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-4);
    color: var(--color-ink);
    transition: background-color var(--transition), color var(--transition);
  }
  .rcard-home-link:hover {
    color: var(--color-accent);
    text-decoration: none;
    background: color-mix(in srgb, var(--color-accent) 4%, var(--color-surface));
  }
  .rcard-home-link:focus-visible {
    position: relative;
    z-index: 1;
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }
  .rcard--home .rcard-media {
    height: 5.75rem;
    flex: none;
    background: transparent;
  }
  .rcard-home-copy {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .rcard--home .rcard-title {
    color: inherit;
    font-size: 1.02rem;
  }

  .rcard--index {
    display: grid;
    grid-template-columns: minmax(9rem, 11rem) minmax(0, 1fr) minmax(12rem, 16rem);
    align-items: center;
    gap: clamp(1.25rem, 3vw, 2.25rem);
    padding-block: var(--space-5);
    border-top: 1px solid var(--color-rule);
  }
  .rcard--index .rcard-media {
    aspect-ratio: 16 / 10;
    border-radius: var(--radius-lg);
  }
  .rcard--index .rcard-media:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .rcard-body {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.4rem;
  }
  .rcard-title a {
    color: inherit;
  }
  .rcard-title a:hover {
    color: var(--color-accent);
  }
  .rcard-summary {
    display: -webkit-box;
    overflow: hidden;
    font-size: var(--fs-small);
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    line-clamp: 3;
  }
  .rcard-links {
    display: flex;
    align-content: center;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
  }
  .rcard-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: var(--fs-small);
    color: var(--color-ink);
  }
  .rcard-links a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  @media (max-width: 959px) {
    .rcard--index {
      grid-template-columns: 8.5rem minmax(0, 1fr);
      gap: var(--space-5);
    }
    .rcard--index .rcard-links {
      grid-column: 2;
      margin-top: calc(-1 * var(--space-3));
    }
  }

  @media (max-width: 639px) {
    .rcard-home-link {
      min-height: 7.25rem;
      flex-direction: row;
      align-items: center;
      gap: var(--space-4);
      padding: 0.75rem;
    }
    .rcard--home .rcard-media {
      width: 6.5rem;
      height: 5.75rem;
    }
    .rcard--home .rcard-title {
      font-size: 1rem;
    }

    .rcard--index {
      grid-template-columns: 6.5rem minmax(0, 1fr);
      gap: var(--space-4);
      padding-block: 0.85rem;
    }
    .rcard--index .rcard-title {
      font-size: 1rem;
    }
    .rcard--index .rcard-summary {
      font-size: var(--fs-meta);
      -webkit-line-clamp: 2;
      line-clamp: 2;
    }
    .rcard--index .rcard-links {
      display: none;
    }
  }
</style>
