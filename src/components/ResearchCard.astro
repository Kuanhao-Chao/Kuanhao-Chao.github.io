---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'research'>;
}
const { entry } = Astro.props;
const d = entry.data;
const href = `/research/${entry.id}/`;
const links = [
  { label: 'Paper', icon: 'link', href: d.paper },
  { label: 'Code', icon: 'code', href: d.code },
  { label: 'Talk', icon: 'play', href: d.talk },
  { label: 'News', icon: 'external', href: d.news },
].filter((l) => l.href);
---
<article class="rcard">
  <a href={href} class="rcard-media" aria-hidden="true" tabindex="-1">
    {
      d.image ? (
        <Image src={d.image} alt="" widths={[420, 840]} sizes="(max-width: 720px) 100vw, 420px" />
      ) : (
        <div class="rcard-fallback"><span>{d.area}</span></div>
      )
    }
  </a>
  <div class="rcard-body">
    <p class="eyebrow">{d.area}</p>
    <h3 class="rcard-title"><a href={href}>{d.title}</a></h3>
    <p class="rcard-summary muted">{d.summary}</p>
    {
      links.length > 0 && (
        <div class="rcard-links">
          {links.map((l) => (
            <a href={l.href} target="_blank" rel="noopener">
              <Icon name={l.icon} size={15} />
              {l.label}
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>

<style>
  .rcard {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-surface);
    transition: border-color var(--transition), transform var(--transition);
  }
  .rcard:hover {
    border-color: color-mix(in srgb, var(--color-accent) 45%, var(--color-rule));
  }
  .rcard-media {
    display: block;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: color-mix(in srgb, var(--color-accent) 6%, var(--color-bg));
  }
  .rcard-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
  }
  .rcard:hover .rcard-media :global(img) {
    transform: scale(1.03);
  }
  .rcard-fallback {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    background:
      radial-gradient(120% 120% at 20% 0%, color-mix(in srgb, var(--color-accent) 22%, transparent), transparent 60%),
      var(--color-accent);
  }
  .rcard-fallback span {
    font-family: var(--font-display);
    color: #fff;
    font-size: 1.4rem;
    font-weight: var(--fw-light);
    letter-spacing: var(--tracking-tight);
  }
  .rcard-body {
    padding: 1.4rem 1.5rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    flex: 1;
  }
  .rcard-title {
    font-size: 1.2rem;
    font-weight: var(--fw-semibold);
    line-height: 1.3;
    letter-spacing: 0;
  }
  .rcard-title a {
    color: var(--color-ink);
  }
  .rcard-title a:hover {
    color: var(--color-accent);
  }
  .rcard-summary {
    font-size: var(--fs-small);
    flex: 1;
  }
  .rcard-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    margin-top: 0.4rem;
  }
  .rcard-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: var(--fs-small);
    color: var(--color-ink);
  }
  .rcard-links a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
</style>
