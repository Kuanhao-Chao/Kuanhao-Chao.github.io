---
import Icon from './Icon.astro';
import ResearchMotif from './genomic/ResearchMotif.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'research'>;
  compact?: boolean;
}
const { entry, compact = false } = Astro.props;
const d = entry.data;
const href = `/research/${entry.id}/`;
const links = [
  { label: 'Paper', icon: 'link', href: d.paper },
  { label: 'Code', icon: 'code', href: d.code },
  { label: 'Talk', icon: 'play', href: d.talk },
  { label: 'News', icon: 'external', href: d.news },
].filter((l) => l.href);
---
<article class:list={['rcard', { 'rcard--compact': compact }]}>
  <a href={href} class="rcard-media" aria-hidden="true" tabindex="-1">
    <ResearchMotif id={entry.id} />
  </a>
  <div class="rcard-body">
    <p class="eyebrow">{d.area}</p>
    <h3 class="rcard-title"><a href={href}>{d.title}</a></h3>
    <p class="rcard-summary muted">{d.summary}</p>
    {
      links.length > 0 && (
        <div class="rcard-links">
          {links.map((l) => (
            <a href={l.href} target="_blank" rel="noopener">
              <Icon name={l.icon} size={15} />
              {l.label}
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>

<style>
  .rcard {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-surface);
    transition: border-color var(--transition), transform var(--transition);
  }
  .rcard:hover {
    border-color: color-mix(in srgb, var(--color-accent) 45%, var(--color-rule));
  }
  .rcard-media {
    display: block;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: color-mix(in srgb, var(--color-accent) 6%, var(--color-bg));
  }
  .rcard-media :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }
  .rcard-body {
    padding: 1.4rem 1.5rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    flex: 1;
  }
  .rcard-title {
    font-size: 1.2rem;
    font-weight: var(--fw-semibold);
    line-height: 1.3;
    letter-spacing: 0;
  }
  .rcard-title a {
    color: var(--color-ink);
  }
  .rcard-title a:hover {
    color: var(--color-accent);
  }
  .rcard-summary {
    font-size: var(--fs-small);
    flex: 1;
  }
  .rcard-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    margin-top: 0.4rem;
  }
  .rcard-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: var(--fs-small);
    color: var(--color-ink);
  }
  .rcard-links a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  /* Homepage "compact" variant. On wide screens it just clamps the summary so the
     featured cards have even heights; on phones it collapses each card into a tight
     thumbnail row so the 5 items don't stack into a long, bulky scroll. */
  .rcard--compact .rcard-summary {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 620px) {
    .rcard--compact {
      flex-direction: row;
      align-items: stretch;
    }
    .rcard--compact .rcard-media {
      aspect-ratio: auto;
      width: 38%;
      max-width: 116px;
      flex: none;
    }
    .rcard--compact .rcard-body {
      padding: 0.85rem 1rem;
      gap: 0.3rem;
      justify-content: center;
    }
    .rcard--compact .rcard-title {
      font-size: 1.05rem;
    }
    .rcard--compact .rcard-summary {
      -webkit-line-clamp: 2;
      line-clamp: 2;
      font-size: var(--fs-meta);
    }
    .rcard--compact .rcard-links {
      display: none;
    }
  }
</style>
