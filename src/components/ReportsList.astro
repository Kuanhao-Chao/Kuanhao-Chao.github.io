---
import ReportItem from './ReportItem.astro';
import Icon from './Icon.astro';
import { readingTime } from '../lib/format';
import { POST_TOPICS } from '../lib/postTopics';
import type { CollectionEntry } from 'astro:content';

interface Props {
  reports: CollectionEntry<'reports'>[];
}
const { reports } = Astro.props;
const topics = [{ slug: 'all', label: 'All' }, ...POST_TOPICS];
---
<div class="report-tools" data-report-tools>
  <div class="report-filters" role="group" aria-label="Filter by topic">
    {
      topics.map((t) => (
        <button
          type="button"
          class="filter-pill"
          data-filter={t.slug}
          aria-pressed={t.slug === 'all' ? 'true' : 'false'}
        >
          {t.label}
        </button>
      ))
    }
  </div>

  <div class="report-controls">
    <label class="search">
      <Icon name="search" size={18} />
      <input type="search" placeholder="Search reports..." data-search-input aria-label="Search reports" />
    </label>
    <label class="sort">
      <span class="visually-hidden">Sort reports</span>
      <select data-sort>
        <option value="newest">Newest first</option>
        <option value="oldest">Oldest first</option>
        <option value="az">A-Z</option>
      </select>
      <Icon name="chevron-down" size={16} />
    </label>
  </div>
</div>

<ol class="report-list" data-report-list>
  {reports.map((entry) => <li><ReportItem entry={entry} minutes={readingTime(entry.body ?? '')} /></li>)}
</ol>

<p class="report-empty" data-report-empty hidden>No reports match your search.</p>

<style>
  .report-tools {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: var(--space-4);
  }
  .report-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .filter-pill {
    font-size: var(--fs-small);
    font-weight: var(--fw-medium);
    padding: 0.4em 0.9em;
    border: 1px solid var(--color-rule);
    border-radius: 999px;
    background: transparent;
    color: var(--color-muted);
    cursor: pointer;
    transition: all var(--transition);
  }
  .filter-pill:hover {
    border-color: var(--color-ink);
    color: var(--color-ink);
  }
  .filter-pill[aria-pressed='true'] {
    background: var(--color-ink);
    border-color: var(--color-ink);
    color: var(--color-bg);
  }
  .report-controls {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .search {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45em 0.8em;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
    background: var(--color-surface);
    color: var(--color-muted);
  }
  .search:focus-within {
    border-color: var(--color-accent);
    color: var(--color-ink);
  }
  .search input {
    border: none;
    outline: none;
    background: transparent;
    font-size: var(--fs-small);
    width: min(15rem, 50vw);
  }
  .sort {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  .sort select {
    appearance: none;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
    background: var(--color-surface);
    padding: 0.5em 2.2em 0.5em 0.8em;
    font-size: var(--fs-small);
    cursor: pointer;
  }
  .sort :global(svg) {
    position: absolute;
    right: 0.6em;
    pointer-events: none;
    color: var(--color-muted);
  }
  .report-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-rule);
  }
  .report-list li.is-hidden {
    display: none;
  }
  :global(.report-year) {
    font-size: var(--fs-h3);
    color: var(--color-muted);
    font-weight: var(--fw-medium);
    padding-bottom: var(--space-3);
    margin-top: var(--space-10);
    border-bottom: 1px solid var(--color-rule);
  }
  :global(.report-year:first-child) {
    margin-top: var(--space-5);
  }
  .report-empty {
    padding: var(--space-8) 0;
    color: var(--color-muted);
  }

  @media (pointer: coarse) {
    .filter-pill,
    .search,
    .sort select {
      padding-block: 0.6em;
    }
  }
  @media (max-width: 640px) {
    .report-tools {
      align-items: stretch;
    }
    .report-filters {
      gap: 0.45rem;
    }
    .report-controls {
      width: 100%;
      flex-direction: column;
      gap: 0.5rem;
    }
    .search,
    .sort,
    .sort select {
      width: 100%;
    }
    .search input {
      width: 100%;
      min-width: 0;
    }
    :global(.report-year) {
      margin-top: var(--space-8);
      padding-bottom: var(--space-2);
    }
  }
</style>

<script>
  function init() {
    const root = document.querySelector<HTMLElement>('[data-report-tools]');
    const list = document.querySelector<HTMLOListElement>('[data-report-list]');
    const empty = document.querySelector<HTMLElement>('[data-report-empty]');
    if (!root || !list) return;
    const items = Array.from(list.querySelectorAll<HTMLLIElement>('li'));
    const pills = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-filter]'));
    const searchInput = root.querySelector<HTMLInputElement>('[data-search-input]');
    const sortSelect = root.querySelector<HTMLSelectElement>('[data-sort]');

    const meta = (li: HTMLLIElement) => {
      const el = li.querySelector<HTMLElement>('.report')!;
      return {
        ts: Number(el.dataset.ts ?? 0),
        year: Number(el.dataset.year ?? 0),
        topics: (el.dataset.topics ?? '').split(' ').filter(Boolean),
        title: el.querySelector('.report-title')?.textContent?.trim().toLowerCase() ?? '',
        search: el.dataset.search ?? '',
      };
    };
    const order = new Map(items.map((li, i) => [li, i]));

    let activeTopic = 'all';
    let query = '';

    const makeSep = (year: number) => {
      const li = document.createElement('li');
      li.className = 'report-year';
      li.dataset.sep = '';
      li.setAttribute('aria-hidden', 'true');
      li.textContent = String(year);
      return li;
    };

    const apply = () => {
      list.querySelectorAll('[data-sep]').forEach((s) => s.remove());

      let visible = 0;
      for (const li of items) {
        const m = meta(li);
        const ok =
          (activeTopic === 'all' || m.topics.includes(activeTopic)) &&
          (query === '' || m.search.includes(query));
        li.classList.toggle('is-hidden', !ok);
        if (ok) visible++;
      }
      if (empty) empty.hidden = visible !== 0;

      const mode = sortSelect?.value ?? 'newest';
      const sorted = [...items].sort((a, b) => {
        const ma = meta(a);
        const mb = meta(b);
        if (mode === 'oldest') return ma.ts - mb.ts || order.get(a)! - order.get(b)!;
        if (mode === 'az') return ma.title.localeCompare(mb.title);
        return mb.ts - ma.ts || order.get(a)! - order.get(b)!;
      });
      sorted.forEach((li) => list.appendChild(li));

      if (mode === 'newest' || mode === 'oldest') {
        let lastYear: number | null = null;
        for (const li of sorted) {
          if (li.classList.contains('is-hidden')) continue;
          const y = meta(li).year;
          if (y !== lastYear) {
            list.insertBefore(makeSep(y), li);
            lastYear = y;
          }
        }
      }
    };

    pills.forEach((pill) =>
      pill.addEventListener('click', () => {
        activeTopic = pill.dataset.filter ?? 'all';
        pills.forEach((p) => p.setAttribute('aria-pressed', String(p === pill)));
        apply();
      })
    );
    searchInput?.addEventListener('input', () => {
      query = searchInput.value.trim().toLowerCase();
      apply();
    });
    sortSelect?.addEventListener('change', apply);

    apply();
  }
  document.addEventListener('astro:page-load', init);
</script>
