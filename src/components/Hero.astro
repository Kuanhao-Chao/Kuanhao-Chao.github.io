---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import Socials from './Socials.astro';
import HeroBackground from './HeroBackground.astro';
import { site } from '../data/site';
import portrait from '../assets/profile/portrait.jpg';
---
<section class="hero">
  <HeroBackground />
  <div class="container hero-inner">
    <div class="hero-text">
      <p class="eyebrow hero-eyebrow">{site.role}</p>
      <h1 class="hero-title">{site.name}</h1>
      <p class="hero-lead">
        I build machine learning for genomics — sequence-to-function models,
        genome annotation, and DNA language models.
      </p>
      <p class="hero-bio muted">{site.bio}</p>

      <div class="hero-actions">
        <a class="btn btn--accent" href="/research/">
          Explore the research
          <Icon name="arrow-right" size={18} />
        </a>
        <a class="btn" href="/cv/">View CV</a>
        <div class="hero-icons">
          <Socials
            class="hero-socials"
            keys={['scholar', 'github', 'linkedin', 'twitter', 'bluesky', 'email']}
          />
          <a class="hero-photos" href="/photos/" aria-label="Photos" title="Photos">
            <Icon name="image" size={20} />
          </a>
        </div>
      </div>
    </div>

    <div class="hero-portrait">
      <Image src={portrait} alt={site.name} widths={[384, 576]} sizes="(max-width: 880px) 12rem, 18rem" />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-top: clamp(2.5rem, 7vw, 5rem);
    padding-bottom: var(--section-y);
    border-bottom: 1px solid var(--color-rule);
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(2rem, 6vw, 5rem);
  }
  .hero-text {
    max-width: 42rem;
  }
  .hero-eyebrow {
    margin-bottom: 1.25rem;
  }
  .hero-title {
    font-size: var(--fs-hero);
    margin-bottom: 1.5rem;
  }
  .hero-lead {
    font-size: clamp(1.25rem, 2.2vw, 1.7rem);
    line-height: 1.32;
    font-family: var(--font-display);
    font-weight: var(--fw-light);
    max-width: 38ch;
    margin-bottom: 1.5rem;
    text-wrap: balance;
  }
  .hero-bio {
    max-width: var(--measure);
    font-size: var(--fs-body);
    margin-bottom: 2rem;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1.25rem;
  }
  .hero-icons {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .hero-photos {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: var(--radius);
    color: var(--color-muted);
    transition: color var(--transition), background var(--transition);
  }
  .hero-photos:hover {
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 9%, transparent);
  }
  @media (pointer: coarse) {
    .hero-photos {
      width: 2.75rem;
      height: 2.75rem;
    }
  }
  .hero-portrait {
    flex: none;
  }
  .hero-portrait :global(img) {
    width: clamp(11rem, 20vw, 18rem);
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius-lg);
    filter: grayscale(12%);
  }

  /* Phone + tablet: centered profile-card layout with a circular avatar. */
  @media (max-width: 880px) {
    .hero-inner {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
      gap: clamp(1.5rem, 5vw, 2.25rem);
    }
    .hero-text {
      max-width: 38rem;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .hero-portrait {
      order: -1;
    }
    .hero-portrait :global(img) {
      width: clamp(9rem, 28vw, 12rem);
      aspect-ratio: 1 / 1;
      border-radius: 50%;
    }
    .hero-eyebrow {
      margin-bottom: 0.7rem;
    }
    .hero-title {
      margin-bottom: 0.9rem;
    }
    .hero-lead {
      margin-inline: auto;
      margin-bottom: 1.25rem;
    }
    /* Long bio reads better left-aligned, but keep the block centered. */
    .hero-bio {
      order: 5;
      width: 100%;
      text-align: left;
      margin-inline: auto;
      margin-top: 1rem;
      margin-bottom: 0;
      font-size: 1rem;
    }
    .hero-actions {
      order: 4;
      justify-content: center;
    }
    .hero-actions .hero-icons {
      flex-basis: 100%;
      justify-content: center;
    }
  }
</style>
