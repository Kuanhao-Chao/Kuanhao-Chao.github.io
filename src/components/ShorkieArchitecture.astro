---
import '../styles/lvz.css';
import '../styles/shorkie.css';

const modes = [
  { id: 'lm', label: 'Language model', input: '16,384 × 170', decoder: '7 upsampling stages', output: '16,384 × 4 softmax' },
  { id: 'fine', label: 'Fine-tuned model', input: '16,384 × 4', decoder: '3 upsampling stages', output: '896 × 5,215 Softplus' },
] as const;
const steps = [
  ['Read a 16,384 bp sequence window', 'The language model adds mask and species channels to DNA; fine-tuning uses four one-hot DNA channels.'],
  ['Compress sequence into learned features', 'An 11 nt Conv1D stem and seven residual downsampling stages reduce 16,384 positions to 128 while increasing width to 384 channels.'],
  ['Integrate long-range context', 'Eight Transformer blocks operate on the 128 × 384 bottleneck. The released Shorkie configuration uses four attention heads per block.'],
  ['Reconnect local and global information', 'U-Net skip connections return high-resolution encoder features to matching decoder stages.'],
  ['Choose the resolution for the task', 'The language model uses seven upsampling stages to recover single bases; the fine-tuned model uses three stages to produce 16 bp bins.'],
  ['Produce task-specific outputs', 'A four-base softmax reconstructs DNA for pretraining; a positive Softplus head predicts 5,215 regulatory tracks after fine-tuning.'],
] as const;

const C = { input: '#3976a8', encoder: '#2f8069', transformer: '#6f62a8', skip: '#b07d00', decoder: '#b26b32', output: '#b04755' };

function block(x: number, y: number, w: number, h: number, title: string, detail: string, color: string, focus: boolean) {
  return `<g opacity="${focus ? 1 : 0.3}"><rect x="${x}" y="${y}" width="${w}" height="${h}" rx="5" fill="${color}" fill-opacity="0.1" stroke="${color}" stroke-width="${focus ? 2.8 : 1.2}"/><text x="${x + w / 2}" y="${y + h / 2 - 6}" class="shk-label" fill="${color}">${title}</text><text x="${x + w / 2}" y="${y + h / 2 + 16}" class="shk-detail">${detail}</text></g>`;
}

function desktop(mode: typeof modes[number], step: number) {
  const items = [
    ['input', mode.input, C.input], ['Conv + residual', '16,384 → 128 positions', C.encoder], ['Transformer × 8', '128 × 384 · 4 heads', C.transformer],
    ['U-Net skips', 'encoder → decoder', C.skip], ['decoder', mode.decoder, C.decoder], ['output head', mode.output, C.output],
  ] as const;
  let s = `<text x="20" y="27" class="lvz-tl">One backbone, two task-specific decoders</text>`;
  items.forEach(([title, detail, color], i) => { const x = 12 + i * 150; s += block(x, 92, 134, 104, title, detail, color, i === step); if (i < 5) s += `<path d="M${x + 134} 144 H${x + 150}" class="shk-arrow"/><path d="M${x + 143} 138 l7 6-7 6" class="shk-arrow"/>`; });
  s += `<path d="M160 92 V55 H735 V92" fill="none" stroke="${C.skip}" stroke-width="${step === 3 ? 3 : 1.2}" opacity="${step === 3 ? 1 : 0.28}"/><text x="450" y="49" class="shk-detail" fill="${C.skip}">multi-resolution skip features</text>`;
  const notes = [mode.id === 'lm' ? '4 DNA + 1 mask + 165 species channels' : '4 one-hot DNA channels', 'seven MaxPool stages halve length each time', 'eight blocks · model width 384 · four heads', 'skip connections restore local sequence detail', mode.id === 'lm' ? '128 → 16,384 · one-base resolution' : '128 → 1,024 · crop to 896 bins', mode.id === 'lm' ? 'P(A), P(C), P(G), P(T) at each base' : 'positive coverage for 5,215 tracks'];
  s += `<rect x="100" y="235" width="720" height="86" rx="5" class="shk-card"/><text x="460" y="266" class="shk-label">${mode.label} · step ${step + 1}</text><text x="460" y="294" class="shk-detail">${notes[step]}</text>`;
  return `<svg viewBox="0 0 920 340" class="lvz-svg" role="img" aria-label="${mode.label} architecture, step ${step + 1}">${s}</svg>`;
}

function mobile(mode: typeof modes[number], step: number) {
  const items = [
    ['input', mode.input, C.input], ['Conv + residual encoder', '16,384 → 128 · width 384', C.encoder], ['Transformer × 8', '128 × 384 · 4 heads', C.transformer],
    ['U-Net skip connections', 'local encoder features', C.skip], ['decoder', mode.decoder, C.decoder], ['output head', mode.output, C.output],
  ] as const;
  let s = '';
  items.forEach(([title, detail, color], i) => { s += block(18, 14 + i * 70, 324, 54, title, detail, color, i === step); if (i < 5) s += `<path d="M180 ${68 + i * 70} V${82 + i * 70}" class="shk-arrow"/>`; });
  return `<svg viewBox="0 0 360 435" class="lvz-svg" role="img" aria-label="${mode.label} architecture, step ${step + 1}">${s}</svg>`;
}
---

<section class="lvz shk shk-architecture" role="group" aria-label="Interactive: Shorkie language model and fine-tuned architecture" data-print-final-state="true">
  <div class="lvz-head"><p class="lvz-title">Follow Shorkie through the network</p><label class="shk-selector"><span>View</span><select data-shk-select>{modes.map((mode) => <option value={mode.id}>{mode.label}</option>)}</select></label></div>
  <p class="lvz-caption" data-wgi-caption aria-live="polite">{steps[0][1]}</p>
  <nav class="lvz-progress" aria-label="Architecture steps">{steps.map(([title], i) => <button type="button" class="lvz-jump" data-wgi-jump aria-label={`Step ${i + 1}: ${title}`} title={title}>{i + 1}</button>)}</nav>
  {modes.map((mode, modeIndex) => <div data-shk-group={mode.id} hidden={modeIndex !== 0}>{steps.map(([title, caption], i) => <div class="lvz-step" data-wgi-step data-print-final={i === 5 ? 'true' : undefined} data-caption={caption} hidden={i !== 0}><p class="lvz-steptitle"><span class="lvz-num">{i + 1}</span>{title}</p><div class="lvz-fig lvz-visual--desktop" set:html={desktop(mode, i)} /><div class="lvz-fig lvz-visual--mobile" set:html={mobile(mode, i)} /></div>)}</div>)}
  <div class="lvz-controls"><button type="button" class="lvz-btn" data-wgi-prev>← Prev</button><button type="button" class="lvz-btn" data-wgi-play aria-pressed="false"><span data-wgi-play-icon>▶</span> <span data-wgi-play-label>Play</span></button><button type="button" class="lvz-btn" data-wgi-next>Next →</button><button type="button" class="lvz-btn" data-wgi-reset>↺ Restart</button><span class="lvz-pos" data-wgi-pos>1 / {steps.length}</span></div>
</section>

<script>
  import { mountStepper } from '../scripts/wgiStepper';
  function boot() {
    for (const root of document.querySelectorAll<HTMLElement>('.shk-architecture')) {
      if (root.dataset.ready === 'true') continue; root.dataset.ready = 'true';
      const groups = Array.from(root.querySelectorAll<HTMLElement>('[data-shk-group]')); const select = root.querySelector<HTMLSelectElement>('[data-shk-select]'); let active = select?.value || 'lm'; let current = 0;
      const activeSteps = () => Array.from(groups.find((g) => g.dataset.shkGroup === active)?.querySelectorAll<HTMLElement>('[data-wgi-step]') || []);
      const show = (i: number) => { current = i; groups.forEach((g) => { const on = g.dataset.shkGroup === active; g.hidden = !on; Array.from(g.querySelectorAll<HTMLElement>('[data-wgi-step]')).forEach((el, k) => el.hidden = !(on && k === i)); }); };
      const api = mountStepper(root, { total: activeSteps().length, onShow: show, caption: (i) => activeSteps()[i]?.dataset.caption || '', interval: 7000 });
      select?.addEventListener('change', () => { api?.stop(); active = select.value; api?.show(current); });
    }
  }
  boot(); document.addEventListener('astro:page-load', boot);
</script>
