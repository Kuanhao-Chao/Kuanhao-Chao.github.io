---
import '../styles/lvz.css';
import '../styles/shorkie.css';

const modes = [
  { id: 'lm', label: 'LM reconstruction', color: '#6f62a8', steps: [
    ['Reconstruct every position', 'Iterative 15% masks eventually cover the full sequence; forward and reverse-complement probabilities are averaged.'],
    ['Build the nucleotide probability matrix', 'At each base, Shorkie LM returns P(A), P(C), P(G), and P(T), describing how strongly context constrains the sequence.'],
    ['Convert certainty into information', 'Entropy becomes information content from 0 to 2 bits, producing a nucleotide logo whose taller letters mark more constrained sequence.'],
    ['Locate recognizable regulatory grammar', 'At RPL26A, high-information patterns align with Fhl1, Rap1, and the 5′ splice donor, connecting reconstruction to known biology.'],
  ]},
  { id: 'ism', label: 'Promoter mutagenesis', color: '#b26b32', steps: [
    ['Focus on one promoter', 'The analysis spans 500 bp around a transcription start site: 450 bp upstream and 50 bp downstream.'],
    ['Try every possible single-base change', 'Each of 500 positions is replaced by its three alternative nucleotides, creating 1,500 mutant promoter sequences.'],
    ['Measure the signed expression effect', 'Reference and mutant predictions are compared as log2 expression differences, revealing bases that increase or decrease predicted output.'],
    ['Read motifs from the effect landscape', 'Zero-centered nucleotide effects form signed logos; recurring patterns recover Fhl1, Rap1, splice signals, and other yeast motifs.'],
  ]},
  { id: 'variant', label: 'Variant effect', color: '#b04755', steps: [
    ['Center a candidate SNP in genomic context', 'A 16,384 bp window is centered on the variant and the reference allele is checked against the yeast genome.'],
    ['Predict the reference and alternate alleles', 'Two otherwise identical sequences are evaluated in forward and reverse-complement orientations.'],
    ['Summarize coverage over the target gene', 'Predicted 16 bp bins overlapping annotated exons are summed separately for the reference and alternate alleles.'],
    ['Report a directional logSED score', 'log2(coverage alternate + 1) − log2(coverage reference + 1) is positive when the alternate allele increases predicted expression.'],
  ]},
] as const;

const baseColors = ['#3976a8','#b04755','#2f8069','#b07d00'];

function sequenceLetters(x0:number,y:number,gap:number,letters:string,masks:number[]=[]){return [...letters].map((letter,i)=>`<g><rect x="${x0+i*gap-gap*.38}" y="${y-gap*.58}" width="${gap*.76}" height="${gap*.82}" rx="3" fill="${masks.includes(i)?'#6f62a8':'var(--color-bg)'}" fill-opacity="${masks.includes(i) ? .17 : 1}" stroke="${masks.includes(i)?'#6f62a8':'var(--color-rule)'}"/><text x="${x0+i*gap}" y="${y}" class="shk-dna" text-anchor="middle" fill="${masks.includes(i)?'#6f62a8':'var(--color-ink)'}">${masks.includes(i)?'?':letter}</text></g>`).join('');}

function lmScene(step:number,mobile=false){
  const w=mobile?360:920,cx=w/2,letters='ACGTACCTGATCGTA';let out=`<text x="${cx}" y="28" class="shk-kicker">RPL26A · language-model view</text>`;
  if(step===0){
    const x0=mobile?30:105,gap=mobile?21:50,y=mobile?95:110;out+=sequenceLetters(x0,y,gap,letters,[2,6,11]);
    const y2=mobile?215:250;out+=sequenceLetters(x0,y2,gap,letters,[]);out+=`<path d="M${cx} ${y+35} V${y2-40}" class="shk-arrow"/><text x="${cx}" y="${mobile?165:190}" class="shk-label" fill="#6f62a8">average forward + reverse predictions</text><text x="${cx}" y="${mobile?315:355}" class="shk-detail">repeat masking rounds until every position has been reconstructed</text>`;
  }else if(step===1){
    const cols=mobile?9:15,x0=mobile?58:145,y0=mobile?75:68,cw=mobile?28:42,ch=mobile?44:55;for(let r=0;r<4;r++){out+=`<text x="${x0-24}" y="${y0+r*ch+ch*.65}" class="shk-label" fill="${baseColors[r]}">${'ACGT'[r]}</text>`;for(let c=0;c<cols;c++){const p=.08+Math.abs(Math.sin(c*1.7+r*2.1))*.25+(r===(c*3)%4?.45:0);out+=`<rect x="${x0+c*cw}" y="${y0+r*ch}" width="${cw-3}" height="${ch-4}" rx="2" fill="${baseColors[r]}" opacity="${Math.min(.92,p)}"/><text x="${x0+c*cw+(cw-3)/2}" y="${y0+r*ch+ch*.62}" class="shk-mini" fill="#fff">${p.toFixed(1)}</text>`;}}
    out+=`<text x="${cx}" y="${mobile?330:325}" class="shk-label">position-probability matrix</text><text x="${cx}" y="${mobile?355:350}" class="shk-detail">each column sums to 1 across A, C, G, and T</text>`;
  }else if(step===2){
    const count=mobile?10:18,x0=mobile?36:95,gap=mobile?30:42,base=mobile?300:310;for(let i=0;i<count;i++){const heights=[18,55,88,32,70,40,96,24][i%8];const color=baseColors[i%4];out+=`<text x="${x0+i*gap}" y="${base}" text-anchor="middle" textLength="${gap*.75}" lengthAdjust="spacingAndGlyphs" style="fill:${color}" font-size="${14+heights*.45}" font-weight="700" transform="translate(0 ${-heights*.35})">${'ACGT'[i%4]}</text><line x1="${x0+i*gap-gap*.35}" y1="${base+8}" x2="${x0+i*gap+gap*.35}" y2="${base+8}" stroke="var(--color-rule)"/>`;}
    out+=`<line x1="${mobile?28:70}" y1="${base+10}" x2="${mobile?335:850}" y2="${base+10}" class="shk-grid"/><text x="${cx}" y="${mobile?375:375}" class="shk-label" fill="#6f62a8">information content = 2 − entropy</text><text x="${cx}" y="${mobile?400:400}" class="shk-detail">taller letters mark sequence that the evolutionary context constrains more strongly</text>`;
  }else{
    const x0=mobile?28:75,trackW=mobile?304:770,y=mobile?290:300;out+=`<line x1="${x0}" y1="${y}" x2="${x0+trackW}" y2="${y}" stroke="#182c67" stroke-width="3"/><rect x="${x0+trackW*.79}" y="${y-13}" width="${trackW*.18}" height="26" fill="#182c67"/><text x="${x0+trackW*.88}" y="${y+5}" class="shk-mini" fill="#fff">RPL26A</text>`;
    const peaks=mobile?[[.25,'Fhl1'],[.47,'Rap1'],[.82,'5′ donor']]:[[.28,'Fhl1'],[.48,'Rap1'],[.83,'5′ splice donor']];peaks.forEach(([p,label],j)=>{const px=x0+trackW*Number(p);const hs=[90,68,105][j];out+=`<path d="M${px-22} ${y-25} q11-${hs} 22 0 q11-${hs*.7} 22 0" fill="none" stroke="${baseColors[j]}" stroke-width="4"/><rect x="${px-30}" y="${y-hs-48}" width="60" height="24" rx="3" fill="var(--color-bg)" stroke="${baseColors[j]}"/><text x="${px}" y="${y-hs-32}" class="shk-label" fill="${baseColors[j]}">${label}</text>`;});
    out+=`<text x="${cx}" y="${mobile?370:375}" class="shk-detail">high-information sequence aligns with known regulatory and splicing features</text>`;
  }
  return `<svg viewBox="0 0 ${w} ${mobile?430:420}" class="lvz-svg" role="img" aria-label="Shorkie language-model interpretation step ${step+1}">${out}</svg>`;
}

function ismScene(step:number,mobile=false){
  const w=mobile?360:920,cx=w/2;let out=`<text x="${cx}" y="28" class="shk-kicker">RPL26A · promoter in-silico mutagenesis</text>`;
  if(step===0){
    const x0=mobile?25:80,tw=mobile?310:760,y=mobile?215:220;out+=`<line x1="${x0}" y1="${y}" x2="${x0+tw}" y2="${y}" stroke="#3976a8" stroke-width="4"/><line x1="${x0+tw*.9}" y1="${y-35}" x2="${x0+tw*.9}" y2="${y+35}" stroke="#b04755" stroke-width="3"/><text x="${x0}" y="${y+35}" class="shk-detail shk-left">−450 bp</text><text x="${x0+tw*.9}" y="${y+35}" class="shk-detail">TSS</text><text x="${x0+tw}" y="${y+35}" class="shk-detail">+50</text><rect x="${x0+tw*.9}" y="${y-14}" width="${tw*.1}" height="28" fill="#182c67"/><text x="${x0+tw*.95}" y="${y+5}" class="shk-mini" fill="#fff">RPL26A</text>`;
    [[.27,'Fhl1'],[.53,'Rap1']].forEach(([p,l],i)=>{const x=x0+tw*Number(p);out+=`<circle cx="${x}" cy="${y}" r="10" fill="${baseColors[i]}"/><path d="M${x} ${y-12} V${y-65}" stroke="${baseColors[i]}"/><text x="${x}" y="${y-75}" class="shk-label" fill="${baseColors[i]}">${l}</text>`;});
    out+=`<path d="M${x0} ${y-100} v-18 h${tw*.9} v18" fill="none" stroke="#3976a8" stroke-width="2"/><text x="${x0+tw*.45}" y="${y-128}" class="shk-label" fill="#3976a8">500 bp promoter window</text>`;
  }else if(step===1){
    const x=mobile?180:180,y=mobile?105:190;out+=`<circle cx="${x}" cy="${y}" r="45" fill="#3976a8" fill-opacity=".1" stroke="#3976a8" stroke-width="2"/><text x="${x}" y="${y-8}" class="shk-detail">reference</text><text x="${x}" y="${y+20}" class="shk-dna" text-anchor="middle">… A C <tspan fill="#b04755" font-weight="700">G</tspan> T A …</text>`;
    const alts=['A','C','T'], positions=mobile?[[65,255],[180,300],[295,255]]:[[430,90],[620,190],[430,300]];alts.forEach((alt,i)=>{const [ax,ay]=positions[i];out+=`<path d="M${x+45} ${y} C${(x+ax)/2} ${y},${(x+ax)/2} ${ay},${ax-42} ${ay}" fill="none" stroke="${baseColors[i]}" stroke-width="2"/><circle cx="${ax}" cy="${ay}" r="40" fill="${baseColors[i]}" fill-opacity=".12" stroke="${baseColors[i]}"/><text x="${ax}" y="${ay+7}" text-anchor="middle" font-size="26" font-weight="700" fill="${baseColors[i]}">${alt}</text>`;});
    out+=`<text x="${cx}" y="${mobile?385:380}" class="shk-label" fill="#b26b32">3 alternatives × 500 positions = 1,500 mutant promoters</text>`;
  }else if(step===2){
    const x0=mobile?25:85,y0=mobile?80:70,cols=mobile?13:26,cw=mobile?23:28,rh=mobile?44:55;['A','C','G','T'].forEach((b,r)=>{out+=`<text x="${x0-14}" y="${y0+r*rh+rh*.58}" class="shk-label" fill="${baseColors[r]}">${b}</text>`;for(let c=0;c<cols;c++){const v=Math.sin(c*.92+r*1.7)*.8;out+=`<rect x="${x0+c*cw}" y="${y0+r*rh}" width="${cw-2}" height="${rh-3}" fill="${v>0?'#2f8069':'#b04755'}" opacity="${.12+Math.abs(v)*.72}"/>`;}});
    out+=`<text x="${mobile?95:235}" y="${mobile?310:320}" class="shk-label" fill="#b04755">decrease</text><path d="M${mobile?145:300} ${mobile?304:314} H${mobile?215:620}" stroke="var(--color-rule)" stroke-width="8"/><text x="${mobile?265:685}" y="${mobile?310:320}" class="shk-label" fill="#2f8069">increase</text><text x="${cx}" y="${mobile?365:370}" class="shk-detail">signed log2(mutant + 1) − log2(reference + 1) effect at every base</text>`;
  }else{
    const motifs=mobile?[[65,'Fhl1'],[180,'Rap1'],[295,'5′ donor']]:[[190,'Fhl1'],[460,'Rap1'],[730,'5′ splice donor']];motifs.forEach(([x,label],j)=>{const xx=Number(x),letterGap=mobile?18:24;out+=`<text x="${xx}" y="75" class="shk-label" style="fill:${baseColors[j]}">${label}</text>`;for(let i=0;i<6;i++){const h=[28,66,42,82,35,54][(i+j)%6],color=baseColors[(i+j)%4];out+=`<text x="${xx-letterGap*2.5+i*letterGap}" y="${mobile?215:230}" text-anchor="middle" textLength="${letterGap*.82}" lengthAdjust="spacingAndGlyphs" font-size="${12+h*.42}" font-weight="700" style="fill:${color}">${'ACGT'[(i*3+j)%4]}</text>`;}out+=`<line x1="${xx-letterGap*3.1}" y1="${mobile?230:245}" x2="${xx+letterGap*3.1}" y2="${mobile?230:245}" class="shk-grid"/>`;});
    out+=`<text x="${cx}" y="${mobile?320:330}" class="shk-label" fill="#b26b32">recurring signed effects become recognizable motif logos</text><text x="${cx}" y="${mobile?355:365}" class="shk-detail">the same RPL26A features are supported by LM reconstruction and fine-tuned ISM</text>`;
  }
  return `<svg viewBox="0 0 ${w} ${mobile?420:420}" class="lvz-svg" role="img" aria-label="Shorkie promoter mutagenesis step ${step+1}">${out}</svg>`;
}

function variantScene(step:number,mobile=false){
  const w=mobile?360:920,cx=w/2;let out=`<text x="${cx}" y="28" class="shk-kicker">YER080W example · chrV:321901 G→T</text>`;
  if(step===0){
    const x0=mobile?25:75,tw=mobile?310:770,y=mobile?220:220,snp=x0+tw*.5;out+=`<line x1="${x0}" y1="${y}" x2="${x0+tw}" y2="${y}" stroke="#3976a8" stroke-width="5"/><rect x="${x0+tw*.58}" y="${y-14}" width="${tw*.28}" height="28" fill="#182c67"/><text x="${x0+tw*.72}" y="${y+5}" class="shk-mini" fill="#fff">YER080W exons</text><path d="M${snp} ${y-75} l9 20 22 2-17 14 6 22-20-12-20 12 6-22-17-14 22-2z" fill="#b04755"/><line x1="${snp}" y1="${y-52}" x2="${snp}" y2="${y+35}" stroke="#b04755" stroke-dasharray="4 3"/><text x="${snp}" y="${y-90}" class="shk-label" fill="#b04755">candidate SNP</text><path d="M${x0} ${y-120} v-18 h${tw} v18" fill="none" stroke="#3976a8"/><text x="${cx}" y="${y-148}" class="shk-label" fill="#3976a8">16,384 bp genomic window</text>`;
  }else if(step===1){
    const x0=mobile?84:185,gap=mobile?20:42,y1=mobile?130:140,y2=mobile?285:280;out+=sequenceLetters(x0,y1,gap,'ACCTAGGTACGT',[6]).replace('?','G')+sequenceLetters(x0,y2,gap,'ACCTATGTACGT',[6]).replace('?','T');out+=`<text x="${mobile?28:80}" y="${y1+5}" class="shk-label shk-left" fill="#3976a8">REF</text><text x="${mobile?28:80}" y="${y2+5}" class="shk-label shk-left" fill="#b04755">ALT</text><path d="M${cx} ${y1+35} V${y2-40}" class="shk-arrow"/><text x="${cx}" y="${mobile?220:215}" class="shk-detail">one nucleotide changes · genomic context stays fixed</text>`;
  }else if(step===2){
    const x0=mobile?35:110,tw=mobile?290:700,base1=mobile?175:170,base2=mobile?330:315;const points=(base:number,scale:number,phase:number)=>Array.from({length:24},(_,i)=>`${x0+i*tw/23},${base-(18+scale*Math.exp(-1*((i-8-phase)/4)**2)+scale*.75*Math.exp(-1*((i-17)/3)**2))}`).join(' ');out+=`<polygon points="${x0},${base1} ${points(base1,mobile?55:72,0)} ${x0+tw},${base1}" fill="#3976a8" opacity=".68"/><polygon points="${x0},${base2} ${points(base2,mobile?72:96,1)} ${x0+tw},${base2}" fill="#b04755" opacity=".68"/><text x="${x0}" y="${base1+28}" class="shk-label shk-left" fill="#3976a8">reference coverage</text><text x="${x0}" y="${base2+28}" class="shk-label shk-left" fill="#b04755">alternate coverage</text><g transform="translate(${x0+tw*.3} ${mobile?375:365})"><rect width="${tw*.18}" height="16" fill="#182c67"/><line x1="${tw*.18}" y1="8" x2="${tw*.36}" y2="8" stroke="#182c67"/><rect x="${tw*.36}" width="${tw*.28}" height="16" fill="#182c67"/><text x="${tw*.32}" y="38" class="shk-detail">sum bins overlapping target-gene exons</text></g>`;
  }else{
    out+=`<text x="${cx}" y="105" class="shk-equation">logSED = log₂(Cov<tspan baseline-shift="sub" font-size="13">ALT</tspan> + 1) − log₂(Cov<tspan baseline-shift="sub" font-size="13">REF</tspan> + 1)</text><line x1="${mobile?40:160}" y1="245" x2="${mobile?320:760}" y2="245" stroke="var(--color-rule)" stroke-width="14" stroke-linecap="round"/><line x1="${cx}" y1="225" x2="${cx}" y2="265" stroke="var(--color-ink)"/><text x="${mobile?45:165}" y="280" class="shk-detail shk-left">lower expression</text><text x="${mobile?315:755}" y="280" class="shk-detail shk-right">higher expression</text><circle cx="${mobile?265:660}" cy="245" r="17" fill="#b04755"/><path d="M${mobile?265:660} 215 v-22" stroke="#b04755" stroke-width="3"/><text x="${mobile?265:660}" y="180" class="shk-label" fill="#b04755">positive score</text><text x="${cx}" y="350" class="shk-detail">sign = direction · magnitude = predicted change</text>`;
  }
  return `<svg viewBox="0 0 ${w} ${mobile?420:420}" class="lvz-svg" role="img" aria-label="Shorkie variant-effect scoring step ${step+1}">${out}</svg>`;
}

const desktop=modes.map((mode)=>mode.steps.map((_,i)=>mode.id==='lm'?lmScene(i):mode.id==='ism'?ismScene(i):variantScene(i)));
const mobile=modes.map((mode)=>mode.steps.map((_,i)=>mode.id==='lm'?lmScene(i,true):mode.id==='ism'?ismScene(i,true):variantScene(i,true)));
---

<section class="lvz shk shk-interpretation" role="group" aria-label="Interactive: three ways to interpret Shorkie" data-print-final-state="true">
  <div class="lvz-head"><p class="lvz-title">Read the learned regulatory grammar</p><div class="shk-segments" role="group" aria-label="Interpretation method">{modes.map((mode,i)=><button type="button" data-shk-mode={mode.id} aria-pressed={i===0?'true':'false'}>{mode.label}</button>)}</div></div>
  <p class="lvz-caption" data-wgi-caption aria-live="polite">{modes[0].steps[0][1]}</p>
  <nav class="lvz-progress" aria-label="Interpretation steps">{modes[0].steps.map(([title],i)=><button type="button" class="lvz-jump" data-wgi-jump aria-label={`Step ${i+1}: ${title}`}>{i+1}</button>)}</nav>
  {modes.map((mode,mi)=><div data-shk-group={mode.id} hidden={mi!==0}>{mode.steps.map(([title,caption],i)=><div class="lvz-step" data-wgi-step data-caption={caption} data-print-final={i===3?'true':undefined} hidden={i!==0}><p class="lvz-steptitle"><span class="lvz-num">{i+1}</span>{title}</p><div class="lvz-fig lvz-visual--desktop" set:html={desktop[mi][i]} /><div class="lvz-fig lvz-visual--mobile" set:html={mobile[mi][i]} /></div>)}</div>)}
  <div class="lvz-controls"><button type="button" class="lvz-btn" data-wgi-prev>← Prev</button><button type="button" class="lvz-btn" data-wgi-play aria-pressed="false"><span data-wgi-play-icon>▶</span> <span data-wgi-play-label>Play</span></button><button type="button" class="lvz-btn" data-wgi-next>Next →</button><button type="button" class="lvz-btn" data-wgi-reset>↺ Restart</button><span class="lvz-pos" data-wgi-pos>1 / 4</span></div>
</section>

<script>
  import { mountStepper } from '../scripts/wgiStepper';
  function boot(){for(const root of document.querySelectorAll<HTMLElement>('.shk-interpretation')){if(root.dataset.ready==='true')continue;root.dataset.ready='true';const groups=Array.from(root.querySelectorAll<HTMLElement>('[data-shk-group]'));const modes=Array.from(root.querySelectorAll<HTMLButtonElement>('[data-shk-mode]'));const jumps=Array.from(root.querySelectorAll<HTMLButtonElement>('[data-wgi-jump]'));let active='lm',current=0;const activeSteps=()=>Array.from(groups.find((g)=>g.dataset.shkGroup===active)?.querySelectorAll<HTMLElement>('[data-wgi-step]')||[]);const show=(i:number)=>{current=i;groups.forEach((group)=>{const on=group.dataset.shkGroup===active;group.hidden=!on;Array.from(group.querySelectorAll<HTMLElement>('[data-wgi-step]')).forEach((step,k)=>step.hidden=!(on&&k===i));});jumps.forEach((jump,k)=>{const title=activeSteps()[k]?.querySelector('.lvz-steptitle')?.textContent?.trim()||`Step ${k+1}`;jump.title=title;jump.setAttribute('aria-label',`Step ${k+1}: ${title}`);});};const api=mountStepper(root,{total:4,onShow:show,caption:(i)=>activeSteps()[i]?.dataset.caption||'',interval:6500});modes.forEach((button)=>button.addEventListener('click',()=>{api?.stop();active=button.dataset.shkMode||'lm';modes.forEach((item)=>item.setAttribute('aria-pressed',String(item===button)));api?.show(current);}));}}
  boot();document.addEventListener('astro:page-load',boot);
</script>
